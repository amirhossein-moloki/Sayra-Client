{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "SayraClient": "Information"
    },
    "File": {
      "Path": "logs/client-.log",
      "RetainedFileCountLimit": 30,
      "RollingInterval": "Day"
    }
  },
  "ServerConfig": {
    "IpAddress": "SAYRA_SERVER_IP",
    "Port": 5000,
    "HeartbeatIntervalSeconds": 10,
    "ReconnectIntervalSeconds": 5,
    "MaxReconnectAttempts": -1
  },
  "SecurityConfig": {
    "MasterKey": "PLACEHOLDER_SET_VIA_ENV_OR_USER_SECRETS"
  },
  "UpdateConfig": {
    "UpdateUrl": "http://SAYRA_SERVER_IP:5000/api/updates",
    "CheckIntervalMinutes": 60,
    "AutoUpdate": true,
    "VerifySignature": true
  }
}
