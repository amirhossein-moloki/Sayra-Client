<Window x:Class="Sayra.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sayra.UI.Views"
        xmlns:c="clr-namespace:Sayra.UI.Controls"
        xmlns:vm="clr-namespace:Sayra.UI.ViewModels"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        mc:Ignorable="d"
        Title="SAYRA"
        Height="1080" Width="1920"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="LeftToRight">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Style for SVG Logo Breathing Glow -->
        <Style x:Key="BreathingLogoStyle" TargetType="svgc:SvgViewbox">
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                             From="0.4" To="0.95" Duration="0:0:2.5" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                             From="15" To="35" Duration="0:0:2.5" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Fade-in animation for Window content -->
        <Storyboard x:Key="WindowFadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1.2" />
        </Storyboard>

        <!-- Circular Action Minimize / Close Button Styles -->
        <Style x:Key="WindowActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="18" BorderThickness="1" BorderBrush="#1AFFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeInStoryboard}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootGrid">
        <!-- Live Video Background Control -->
        <c:VideoBackground />

        <!-- Top Right Control Buttons (Minimize, Close) for immersive mode -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="30">
            <Button Width="36" Height="36" Style="{StaticResource WindowActionButtonStyle}" Background="Transparent" Click="MinimizeButton_Click">
                <Path Data="M0 8h14v2H0V8z" Fill="White" Width="14" Height="2" Stretch="Uniform" Opacity="0.7"/>
            </Button>
            <Button Width="36" Height="36" Style="{StaticResource WindowActionButtonStyle}" Background="Transparent" Margin="10,0,0,0" Click="CloseButton_Click">
                <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                      Fill="White" Width="14" Height="14" Stretch="Uniform" Opacity="0.7"/>
            </Button>
        </StackPanel>

        <!-- Main centered layout structure -->
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="460">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Logo Row -->
                <RowDefinition Height="Auto" /> <!-- Spacing / Header Row -->
                <RowDefinition Height="Auto" /> <!-- Login Panel Container Row -->
            </Grid.RowDefinitions>

            <!-- 1. Logo (Center horizontally, Upper-middle area, large size, SVG vector, yellow glow effect) -->
            <Grid Grid.Row="0" Margin="0,0,0,30" HorizontalAlignment="Center">
                <svgc:SvgViewbox Source="/Assets/sayra.svg"
                                 Width="320" Height="80"
                                 Style="{StaticResource BreathingLogoStyle}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                    <svgc:SvgViewbox.Effect>
                        <DropShadowEffect Color="#F5FF00" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                    </svgc:SvgViewbox.Effect>
                </svgc:SvgViewbox>
            </Grid>

            <!-- Subtitle/Atmospheric hint -->
            <StackPanel Grid.Row="1" Margin="0,0,0,25" HorizontalAlignment="Center">
                <TextBlock Text="SYSTEM TERMINAL ACCESS"
                           FontFamily="{StaticResource PeydaBold}"
                           FontSize="14"
                           Foreground="#F5FF00"
                           HorizontalAlignment="Center"
                           Opacity="0.8"/>
                <TextBlock Text="Enter credentials to activate station"
                           FontFamily="{StaticResource PeydaLight}"
                           FontSize="12"
                           Foreground="#A1A1AA"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"
                           Opacity="0.6"/>
            </StackPanel>

            <!-- 2. Centered Premium Gaming Login Container (Glassmorphism, rounded, low-opacity yellow border) -->
            <Border Grid.Row="2"
                    Background="#A60A0A0A"
                    BorderBrush="#29F5FF00"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="35,40"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="10" Opacity="0.65" />
                </Border.Effect>

                <StackPanel>
                    <!-- Username Input field (User outline icon) -->
                    <TextBlock Text="USERNAME"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="11"
                               Foreground="#A1A1AA"
                               Margin="5,0,0,2"
                               Opacity="0.8" />
                    <c:GlassInput Text="{Binding Username, Mode=TwoWay}"
                                  Placeholder="Enter user handle..."
                                  IsPassword="False"
                                  Margin="0,0,0,20">
                        <c:GlassInput.Icon>
                            <!-- User outline vector path -->
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"
                                  Fill="#A1A1AA" Width="18" Height="18" Stretch="Uniform" Opacity="0.7"/>
                        </c:GlassInput.Icon>
                    </c:GlassInput>

                    <!-- Password Input field (Key/Lock icon) -->
                    <TextBlock Text="PASSWORD"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="11"
                               Foreground="#A1A1AA"
                               Margin="5,0,0,2"
                               Opacity="0.8" />
                    <c:GlassInput Text="{Binding Password, Mode=TwoWay}"
                                  Placeholder="Enter secure code..."
                                  IsPassword="True"
                                  Margin="0,0,0,15">
                        <c:GlassInput.Icon>
                            <!-- Lock vector path -->
                            <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                                  Fill="#A1A1AA" Width="16" Height="18" Stretch="Uniform" Opacity="0.7"/>
                        </c:GlassInput.Icon>
                    </c:GlassInput>

                    <!-- Error Message Indicator if login fails -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontFamily="{StaticResource PeydaMedium}"
                               FontSize="13"
                               Foreground="#EF4444"
                               Margin="5,0,0,15"
                               HorizontalAlignment="Left"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=HasValue}" />

                    <!-- Loading / Progress Ring (Futuristic Accent) -->
                    <Grid Height="20" Margin="0,0,0,15" Visibility="{Binding IsLoggingIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="20" Height="20" BorderThickness="0" Background="Transparent" Foreground="#F5FF00" />
                            <TextBlock Text="Authorizing connection..." FontFamily="{StaticResource PeydaMedium}" FontSize="13" Foreground="#F5FF00" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- 3. Primary Futuristic Action Button (Yellow outline, dark bg, yellow text) -->
                    <c:PrimaryButton ButtonContent="LOGIN TO STATION"
                                     Command="{Binding LoginCommand}"
                                     IsEnabled="{Binding IsLoggingIn, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                                     Height="54" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
