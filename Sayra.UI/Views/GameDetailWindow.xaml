<Window x:Class="Sayra.UI.Views.GameDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:Sayra.UI.Controls"
        xmlns:suis="clr-namespace:Sayra.UI.Services"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        xmlns:vm="clr-namespace:Sayra.UI.ViewModels"
        mc:Ignorable="d"
        Title="Game Details"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="LeftToRight">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Fade-in animation for Window content -->
        <Storyboard x:Key="WindowFadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6" />
        </Storyboard>

        <!-- Glassmorphic Action Button Style -->
        <Style x:Key="GlassDetailButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect x:Name="GlowEffect" Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="10" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brushes.Border.Translucent}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brushes.White.Opacity30}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brushes.White.Opacity20}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium End Session Button Style -->
        <Style x:Key="EndSessionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect x:Name="GlowEffect" Color="{DynamicResource Theme.Colors.Status.Error}" BlurRadius="10" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Specified End Session Button Icon with stroke style, 1.5 thickness, and transparent fill -->
                                <Path Grid.Column="0"
                                      Data="{DynamicResource EndSessionIconGeometry}"
                                      Stroke="{DynamicResource RedBrush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"/>

                                <!-- Text with Peyda Bold, Numbers/Buttons -->
                                <TextBlock Grid.Column="2"
                                           Text="پایان دادن به استفاده"
                                           Foreground="{DynamicResource RedBrush}"
                                           FontFamily="{StaticResource PeydaBold}"
                                           FontSize="15"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brushes.Status.Error.Opacity10}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="1.5"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.6" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="15" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brushes.Status.Error.Opacity20}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeInStoryboard}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootGrid" Background="{DynamicResource Theme.Brushes.Background.Primary}">
        <!-- 1. Atmospheric heavily blurred game backdrop -->
        <Grid IsHitTestVisible="False">
            <Image x:Name="DetailBackgroundImage" Stretch="UniformToFill" Opacity="0.18">
                <Image.Effect>
                    <BlurEffect Radius="45" RenderingBias="Quality" />
                </Image.Effect>
            </Image>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="{DynamicResource Theme.Colors.Background.Primary}" Offset="0.0" />
                        <GradientStop Color="{DynamicResource Theme.Colors.Background.Primary}" Offset="0.65" />
                        <GradientStop Color="{DynamicResource Theme.Colors.Background.Primary}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>

        <!-- 2. CONTENT CONTAINER -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Top Bar Row -->
                <RowDefinition Height="*" />    <!-- Content Row -->
            </Grid.RowDefinitions>

            <!-- EXACT SAME HEADER: Top bar reusable component -->
            <c:TopBar Grid.Row="0" />

            <!-- CONTENT BODY (Left-to-Right layout for columns, RTL internally inside columns/boxes) -->
            <Grid Grid.Row="1" FlowDirection="LeftToRight" Margin="75,30,75,60">
                <Grid.RowDefinitions>
                    <!-- Row 0: Header with Back button and Breadcrumb -->
                    <RowDefinition Height="Auto" />
                    <!-- Row 1: Spacer -->
                    <RowDefinition Height="35" />
                    <!-- Row 2: Content Row containing columns -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Row 0: Header -->
                <!-- Left side: Back Button -->
                <Button Grid.Row="0"
                        Style="{StaticResource GlassDetailButtonStyle}"
                        Click="Back_Click"
                        HorizontalAlignment="Left"
                        Width="160">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="M10 19l-7-7m0 0l7-7m-7 7h18"
                              Stroke="{DynamicResource DarkerWhiteBrush}"
                              StrokeThickness="2"
                              Width="16" Height="16"
                              Stretch="Uniform"
                              Margin="0,0,10,0"/>
                        <TextBlock Text="بازگشت"
                                   FontFamily="{StaticResource PeydaMedium}"
                                   FontSize="15"
                                   Foreground="{DynamicResource DarkerWhiteBrush}"/>
                    </StackPanel>
                </Button>

                <!-- Right side: Breadcrumb -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" FlowDirection="RightToLeft">
                    <TextBlock Text="داشبورد / بازی ها / "
                               FontFamily="{StaticResource PeydaMedium}"
                               FontSize="16"
                               Foreground="{DynamicResource SecondaryWhiteBrush}"/>
                    <TextBlock x:Name="BreadcrumbGameTitle"
                               Text="ولورانت"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="16"
                               Foreground="{DynamicResource PrimaryYellowBrush}"/>
                </StackPanel>

                <!-- Row 2: Columns -->
                <Grid Grid.Row="2" VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <!-- Left Column: Large Game Box & Logo (Width: 1296) -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Spacer -->
                        <ColumnDefinition Width="*" />
                        <!-- Right Column: Session Box & Hardware Panel (Width: 454) -->
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Column Content -->
                    <Grid Grid.Column="0" VerticalAlignment="Stretch" Width="1296">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <!-- Large Box (Game Details - Width: 1296, Height: 406, CornerRadius: 20, Border: 1) -->
                        <Border Grid.Row="0" CornerRadius="20" Background="#CC1F1F23" BorderBrush="{DynamicResource Theme.Brushes.Border.Default}" BorderThickness="1" Padding="30" Height="406">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource Theme.Colors.Shadow}" BlurRadius="25" ShadowDepth="4" Opacity="0.5" />
                            </Border.Effect>
                            <Grid FlowDirection="RightToLeft">
                                <Grid.ColumnDefinitions>
                                    <!-- Right Column of the box (RTL Column 0): Name, Genre, Description, Play Button -->
                                    <ColumnDefinition Width="*" />
                                    <!-- Spacer -->
                                    <ColumnDefinition Width="30" />
                                    <!-- Left Column of the box (RTL Column 2): Cover Image, Title, Genre -->
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Left Column Content: Cover Image ONLY, styled to fill entire height of details box -->
                                <Border Grid.Column="2" CornerRadius="16" Width="248" VerticalAlignment="Stretch" BorderThickness="1.5" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource SecondaryBackgroundBrush}" ClipToBounds="True" HorizontalAlignment="Left" Margin="0,10,0,10">
                                    <Grid Background="{DynamicResource Theme.Brushes.White.Opacity10}">
                                        <!-- Gamepad Fallback Vector Graphic -->
                                        <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                              Fill="{DynamicResource Theme.Brushes.White.Opacity20}"
                                              Width="50" Height="50"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                        <Image x:Name="DetailCoverImage" Stretch="UniformToFill" ImageFailed="DetailCoverImage_ImageFailed"/>
                                    </Grid>
                                </Border>

                                <!-- Right Column Content (Title/Genre Stacked at top, Description below, Play Button at bottom) -->
                                <Grid Grid.Column="0" VerticalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" /> <!-- Title / Genre & Logo Segment -->
                                        <RowDefinition Height="*" />    <!-- Description Segment -->
                                        <RowDefinition Height="Auto" /> <!-- Rich Metadata Segment (Developer, Year, Launcher) -->
                                        <RowDefinition Height="Auto" /> <!-- Play / Status Button -->
                                    </Grid.RowDefinitions>

                                    <!-- Title / Genre Stack on the right, and high resolution logo on the left (RTL) -->
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Title and Genre Stack -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock x:Name="DetailTitle"
                                                       Text="عنوان بازی"
                                                       FontFamily="{StaticResource PeydaBold}"
                                                       FontSize="32"
                                                       Foreground="White"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock x:Name="DetailGenre"
                                                       Text="دسته بندی"
                                                       FontFamily="{StaticResource PeydaLight}"
                                                       FontSize="17"
                                                       Foreground="{DynamicResource SecondaryWhiteBrush}"
                                                       Margin="0,2,0,0"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>

                                        <!-- High-resolution Game Logo (displays side-by-side with Title/Genre) -->
                                        <Image x:Name="DetailLogoImage"
                                               Grid.Column="0"
                                               Height="60"
                                               MaxWidth="240"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="1" Opacity="0.5"/>
                                            </Image.Effect>
                                        </Image>
                                    </Grid>

                                    <!-- Description Segment -->
                                    <TextBlock x:Name="DetailDescription"
                                               Grid.Row="1"
                                               Text="توضیحات تکمیلی و خلاصه بازی در این قسمت قرار می‌گیرد."
                                               FontFamily="{StaticResource PeydaLight}"
                                               FontSize="18"
                                               Foreground="{DynamicResource DarkerWhiteBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="28"
                                               FlowDirection="RightToLeft"
                                               TextAlignment="Right"
                                               HorizontalAlignment="Stretch"
                                               Margin="0,5,0,15"/>

                                    <!-- Rich Metadata Segment (Developer, Release Year, Launcher Badge) -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" FlowDirection="RightToLeft" Margin="0,0,0,20">
                                        <!-- Developer Pill -->
                                        <Border Background="{DynamicResource Theme.Brushes.Track.Hover}" BorderBrush="{DynamicResource Theme.Brushes.Border.Default}" BorderThickness="1" CornerRadius="12" Padding="14,6" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="سازنده: " FontFamily="{StaticResource PeydaMedium}" FontSize="13" Foreground="{DynamicResource SecondaryWhiteBrush}" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="DetailDeveloper" Text="CD PROJEKT RED" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Year Pill -->
                                        <Border Background="{DynamicResource Theme.Brushes.Track.Hover}" BorderBrush="{DynamicResource Theme.Brushes.Border.Default}" BorderThickness="1" CornerRadius="12" Padding="14,6" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="سال انتشار: " FontFamily="{StaticResource PeydaMedium}" FontSize="13" Foreground="{DynamicResource SecondaryWhiteBrush}" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="DetailReleaseYear" Text="2020" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Launcher Platform Pill -->
                                        <Border Background="{DynamicResource Theme.Brushes.Track.Hover}" BorderBrush="{DynamicResource Theme.Brushes.Border.Default}" BorderThickness="1" CornerRadius="12" Padding="14,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="لانچر: " FontFamily="{StaticResource PeydaMedium}" FontSize="13" Foreground="{DynamicResource SecondaryWhiteBrush}" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="DetailLauncher" Text="Steam" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="{DynamicResource PrimaryYellowBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Game Status Badge / Button -->
                                    <Button Grid.Row="3"
                                            Click="PlayGame_Click"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            HorizontalAlignment="Right"
                                            Padding="0"
                                            Cursor="Hand"
                                            Margin="0,0,0,10">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Border x:Name="StatusBadgeBorder"
                                                Width="288"
                                                Height="50"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Background="{DynamicResource Theme.Brushes.Status.Success}"
                                                BorderBrush="{DynamicResource SuccessBrush}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse x:Name="StatusBadgeDot" Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="DetailStatus"
                                                           Text="وضعیت"
                                                           FontFamily="{StaticResource PeydaMedium}"
                                                           FontSize="15"
                                                           Foreground="{DynamicResource SuccessBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Sayra Logo below the box aligned and sized proportionally (Width: 400, Height: 100) -->
                        <svgc:SvgViewbox Grid.Row="1" Source="/Assets/sayra.svg"
                                         Width="Auto" Height="Auto"
                                         Opacity="0.2"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Margin="0,20,0,0"
                                         IsHitTestVisible="False" />
                    </Grid>

                    <!-- Right Column Content -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top" Width="454">
                        <!-- Session Info Box (Width: 454, Height: 406, CornerRadius: 20, Border: 1) -->
                        <Border CornerRadius="20" Background="#CC1F1F23" BorderBrush="{DynamicResource Theme.Brushes.Border.Default}" BorderThickness="1" Padding="25" Height="406">
                            <Border.DataContext>
                                <vm:SessionHeroViewModel />
                            </Border.DataContext>
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="12" ShadowDepth="0" Opacity="0.1" />
                            </Border.Effect>

                            <Grid FlowDirection="RightToLeft">
                                <Grid.RowDefinitions>
                                    <!-- Row 0: Header (PC Name & Session Info with Icon) -->
                                    <RowDefinition Height="Auto" />
                                    <!-- Row 1: Time Used & Timer (Left Aligned) -->
                                    <RowDefinition Height="Auto" />
                                    <!-- Row 2: Yellow Divider Line -->
                                    <RowDefinition Height="Auto" />
                                    <!-- Row 3: Stats Details Key/Value list -->
                                    <RowDefinition Height="*" />
                                    <!-- Row 4: Centered End Session Button -->
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Row 0: Header -->
                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <!-- PC Name (Aligned to the physical right under RTL using HorizontalAlignment="Left") -->
                                    <TextBlock Text="PC-08"
                                               FontFamily="{StaticResource PeydaBold}"
                                               FontSize="24"
                                               Foreground="{DynamicResource PrimaryYellowBrush}"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center" />

                                    <!-- Session Information + Icon (Aligned to the physical left under RTL using HorizontalAlignment="Right") -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <!-- Suitable clock icon to the right of text in StackPanel -->
                                        <Path Data="M12 6v6h4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                              Stroke="{DynamicResource PrimaryYellowBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"
                                              Width="22" Height="22"
                                              Stretch="Uniform"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                                        <!-- Text -->
                                        <TextBlock Text="session information"
                                                   FontFamily="{StaticResource PeydaBold}"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource PrimaryYellowBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>

                                <!-- Row 1: Time Used & Timer (Aligned to physical left using HorizontalAlignment="Right") -->
                                <StackPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,0,0,15">
                                    <TextBlock Text="زمان استفاده شده"
                                               FontFamily="{StaticResource PeydaMedium}"
                                               FontSize="18"
                                               Foreground="{DynamicResource PrimaryYellowBrush}"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding SessionTime}"
                                               FontFamily="{StaticResource BlackOpsOne}"
                                               FontSize="54"
                                               Foreground="{DynamicResource PrimaryYellowBrush}"
                                               HorizontalAlignment="Right"
                                               Margin="0,4,0,0">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="15" ShadowDepth="0" Opacity="0.4" />
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Row 2: Yellow Divider Line -->
                                <Border Grid.Row="2"
                                        Height="1.5"
                                        Background="{DynamicResource PrimaryYellowBrush}"
                                        Margin="0,0,0,15" />

                                <!-- Row 3: Stats Details Key/Value list -->
                                <Grid Grid.Row="3" Margin="0,0,0,15">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Hourly Rate -->
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Path Data="{DynamicResource HourlyRateIconGeometry}"
                                                  Stroke="{DynamicResource PrimaryYellowBrush}"
                                                  StrokeThickness="1.5"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Fill="Transparent"
                                                  Width="18" Height="18"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0">
                                                <Path.Effect>
                                                    <DropShadowEffect Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                                </Path.Effect>
                                            </Path>
                                            <TextBlock Text="نرخ ساعتی"
                                                       FontFamily="{StaticResource PeydaMedium}"
                                                       FontSize="19"
                                                       Foreground="{DynamicResource PrimaryYellowBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding HourlyRate}"
                                                   FontFamily="{StaticResource PeydaBold}"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource PrimaryYellowBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Cost so far -->
                                    <Grid Grid.Row="1" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Path Data="{DynamicResource CurrentCostIconGeometry}"
                                                  Stroke="{DynamicResource PrimaryYellowBrush}"
                                                  StrokeThickness="1.5"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Fill="Transparent"
                                                  Width="18" Height="18"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0">
                                                <Path.Effect>
                                                    <DropShadowEffect Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                                </Path.Effect>
                                            </Path>
                                            <TextBlock Text="هزینه تا کنون"
                                                       FontFamily="{StaticResource PeydaMedium}"
                                                       FontSize="19"
                                                       Foreground="{DynamicResource PrimaryYellowBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding CurrentCost}"
                                                   FontFamily="{StaticResource PeydaBold}"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource PrimaryYellowBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Start Time -->
                                    <Grid Grid.Row="2" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Path Data="{DynamicResource StartTimeIconGeometry}"
                                                  Stroke="{DynamicResource PrimaryYellowBrush}"
                                                  StrokeThickness="1.5"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Fill="Transparent"
                                                  Width="18" Height="18"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0">
                                                <Path.Effect>
                                                    <DropShadowEffect Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                                </Path.Effect>
                                            </Path>
                                            <TextBlock Text="زمان شروع"
                                                       FontFamily="{StaticResource PeydaMedium}"
                                                       FontSize="19"
                                                       Foreground="{DynamicResource PrimaryYellowBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding StartTime}"
                                                   FontFamily="{StaticResource PeydaBold}"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource PrimaryYellowBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>

                                <!-- Row 4: Centered End Session Button -->
                                <Button Grid.Row="4"
                                        Style="{StaticResource EndSessionButtonStyle}"
                                        Click="EndSession_Click"
                                        Width="240" Height="48"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <!-- Hardware Panel directly below -->
                        <!-- Scaled and margin-aligned to right column width -->
                        <c:HardwarePanel x:Name="Hardware" Width="454" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="0,20,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
