<Window x:Class="Sayra.UI.Views.GameDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:Sayra.UI.Controls"
        xmlns:suis="clr-namespace:Sayra.UI.Services"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        xmlns:vm="clr-namespace:Sayra.UI.ViewModels"
        mc:Ignorable="d"
        Title="Game Details"
        Height="1080" Width="1920"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="LeftToRight">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Fade-in animation for Window content -->
        <Storyboard x:Key="WindowFadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6" />
        </Storyboard>

        <!-- Glassmorphic Action Button Style -->
        <Style x:Key="GlassDetailButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect x:Name="GlowEffect" Color="#ffff3d" BlurRadius="10" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1AFFFFFF"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#80FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium End Session Button Style -->
        <Style x:Key="EndSessionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect x:Name="GlowEffect" Color="#F46B6B" BlurRadius="10" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Specified End Session Button Icon with stroke style, 1.5 thickness, and transparent fill -->
                                <Path Grid.Column="0"
                                      Data="{DynamicResource EndSessionIconGeometry}"
                                      Stroke="{DynamicResource RedBrush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"/>

                                <!-- Text with Peyda Bold, Numbers/Buttons -->
                                <TextBlock Grid.Column="2"
                                           Text="پایان"
                                           Foreground="{DynamicResource RedBrush}"
                                           FontFamily="{StaticResource PeydaBold}"
                                           FontSize="15"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1AF46B6B"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="1.5"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.6" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="15" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#33F46B6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeInStoryboard}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootGrid" Background="#08090D">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Top Bar Row -->
                <RowDefinition Height="*" />    <!-- Content Row -->
            </Grid.RowDefinitions>

            <!-- EXACT SAME HEADER: Top bar reusable component -->
            <c:TopBar Grid.Row="0" />

            <!-- CONTENT BODY (Left-to-Right layout for columns, RTL internally inside columns/boxes) -->
            <Grid Grid.Row="1" FlowDirection="LeftToRight" Margin="75,30,75,60">
                <Grid.RowDefinitions>
                    <!-- Row 0: Header with Back button and Breadcrumb -->
                    <RowDefinition Height="Auto" />
                    <!-- Row 1: Spacer -->
                    <RowDefinition Height="35" />
                    <!-- Row 2: Content Row containing columns -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Row 0: Header -->
                <!-- Left side: Back Button -->
                <Button Grid.Row="0"
                        Style="{StaticResource GlassDetailButtonStyle}"
                        Click="Back_Click"
                        HorizontalAlignment="Left"
                        Width="160">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="M10 19l-7-7m0 0l7-7m-7 7h18"
                              Stroke="{DynamicResource DarkerWhiteBrush}"
                              StrokeThickness="2"
                              Width="16" Height="16"
                              Stretch="Uniform"
                              Margin="0,0,10,0"/>
                        <TextBlock Text="بازگشت"
                                   FontFamily="{StaticResource PeydaMedium}"
                                   FontSize="15"
                                   Foreground="{DynamicResource DarkerWhiteBrush}"/>
                    </StackPanel>
                </Button>

                <!-- Right side: Breadcrumb -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" FlowDirection="RightToLeft">
                    <TextBlock Text="داشبورد / بازی ها / "
                               FontFamily="{StaticResource PeydaMedium}"
                               FontSize="16"
                               Foreground="{DynamicResource SecondaryWhiteBrush}"/>
                    <TextBlock x:Name="BreadcrumbGameTitle"
                               Text="ولورانت"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="16"
                               Foreground="{DynamicResource PrimaryYellowBrush}"/>
                </StackPanel>

                <!-- Row 2: Columns -->
                <Grid Grid.Row="2" VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <!-- Left Column: Large Game Box & Logo (Width: 1296) -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Spacer -->
                        <ColumnDefinition Width="*" />
                        <!-- Right Column: Session Box & Hardware Panel (Width: 454) -->
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Column Content -->
                    <Grid Grid.Column="0" VerticalAlignment="Stretch" Width="1296">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <!-- Large Box (Game Details - Width: 1296, Height: 406, CornerRadius: 20, Border: 1) -->
                        <Border Grid.Row="0" CornerRadius="20" Background="#CC1F1F23" BorderBrush="#252528" BorderThickness="1" Padding="30" Height="406">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="25" ShadowDepth="4" Opacity="0.5" />
                            </Border.Effect>
                            <Grid FlowDirection="RightToLeft">
                                <Grid.ColumnDefinitions>
                                    <!-- Right Column of the box (RTL Column 0): Name, Genre, Description, Play Button -->
                                    <ColumnDefinition Width="*" />
                                    <!-- Spacer -->
                                    <ColumnDefinition Width="30" />
                                    <!-- Left Column of the box (RTL Column 2): Cover Image, Title, Genre -->
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Left Column Content: Cover Image ONLY, styled to fill entire height of details box -->
                                <Border Grid.Column="2" CornerRadius="16" Width="248" VerticalAlignment="Stretch" BorderThickness="1.5" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource SecondaryBackgroundBrush}" ClipToBounds="True" HorizontalAlignment="Left" Margin="0,10,0,10">
                                    <Grid Background="#10FFFFFF">
                                        <!-- Gamepad Fallback Vector Graphic -->
                                        <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                              Fill="#33FFFFFF"
                                              Width="50" Height="50"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                        <Image x:Name="DetailCoverImage" Stretch="UniformToFill" ImageFailed="DetailCoverImage_ImageFailed"/>
                                    </Grid>
                                </Border>

                                <!-- Right Column Content (Title/Genre Stacked at top, Description below, Play Button at bottom) -->
                                <Grid Grid.Column="0" VerticalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" /> <!-- Title / Genre Segment -->
                                        <RowDefinition Height="*" />    <!-- Description Segment -->
                                        <RowDefinition Height="Auto" /> <!-- Play / Status Button -->
                                    </Grid.RowDefinitions>

                                    <!-- Title / Genre -->
                                    <StackPanel Grid.Row="0" HorizontalAlignment="Right" Margin="0,0,0,15">
                                        <TextBlock x:Name="DetailTitle"
                                                   Text="عنوان بازی"
                                                   FontFamily="{StaticResource PeydaBold}"
                                                   FontSize="34"
                                                   Foreground="White"
                                                   HorizontalAlignment="Right" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                            <!-- Genre text -->
                                            <TextBlock x:Name="DetailGenre"
                                                       Text="دسته بندی"
                                                       FontFamily="{StaticResource PeydaLight}"
                                                       FontSize="18"
                                                       Foreground="{DynamicResource SecondaryWhiteBrush}"
                                                       VerticalAlignment="Center" />
                                            <!-- Gamepad Icon (shows on the left in RTL) -->
                                            <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                                  Fill="{DynamicResource PrimaryYellowBrush}"
                                                  Width="22" Height="22"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Margin="10,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Description Segment -->
                                    <TextBlock x:Name="DetailDescription"
                                               Grid.Row="1"
                                               Text="توضیحات تکمیلی و خلاصه بازی در این قسمت قرار می‌گیرد."
                                               FontFamily="{StaticResource PeydaLight}"
                                               FontSize="19"
                                               Foreground="{DynamicResource DarkerWhiteBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="30"
                                               FlowDirection="RightToLeft"
                                               TextAlignment="Right"
                                               HorizontalAlignment="Stretch"
                                               Margin="0,10,0,20"/>

                                    <!-- Game Status Badge / Button -->
                                    <Button Grid.Row="2"
                                            Click="PlayGame_Click"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            HorizontalAlignment="Right"
                                            Padding="0"
                                            Cursor="Hand"
                                            Margin="0,0,0,10">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Border x:Name="StatusBadgeBorder"
                                                Width="288"
                                                Height="50"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Background="#1014BE78"
                                                BorderBrush="{DynamicResource SuccessBrush}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse x:Name="StatusBadgeDot" Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="DetailStatus"
                                                           Text="وضعیت"
                                                           FontFamily="{StaticResource PeydaMedium}"
                                                           FontSize="15"
                                                           Foreground="{DynamicResource SuccessBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Sayra Logo below the box aligned and sized proportionally (Width: 400, Height: 100) -->
                        <svgc:SvgViewbox Grid.Row="1" Source="/Assets/sayra.svg"
                                         Width="Auto" Height="Auto"
                                         Opacity="0.25"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Margin="0,20,0,0"
                                         IsHitTestVisible="False" />
                    </Grid>

                    <!-- Right Column Content -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top" Width="454">
                        <!-- Session Info Box (Width: 454, Height: 406, CornerRadius: 20, Border: 1) -->
                        <Border CornerRadius="20" Background="#CC1F1F23" BorderBrush="#252528" BorderThickness="1" Padding="25" Height="406">
                            <Border.DataContext>
                                <vm:SessionHeroViewModel />
                            </Border.DataContext>
                            <Border.Effect>
                                <DropShadowEffect Color="#ffff3d" BlurRadius="12" ShadowDepth="0" Opacity="0.1" />
                            </Border.Effect>

                            <Grid FlowDirection="RightToLeft">
                                <Grid.RowDefinitions>
                                    <!-- Row 0: End Session Button & Timer -->
                                    <RowDefinition Height="*" />
                                    <!-- Row 1: Sub stats (Start Time, Hourly Rate, Cost) -->
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Top area with Timer and End Session Button -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <!-- Right side (RTL Column 0): End Session Button -->
                                        <ColumnDefinition Width="Auto" />
                                        <!-- Spacer -->
                                        <ColumnDefinition Width="*" />
                                        <!-- Left side (RTL Column 2): Timer Display -->
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- End Session Button on the right -->
                                    <Button Grid.Column="0"
                                            Style="{StaticResource EndSessionButtonStyle}"
                                            Click="EndSession_Click"
                                            Width="120" Height="48"
                                            VerticalAlignment="Center"/>

                                    <!-- Timer Display on the left -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <TextBlock Text="زمان گذرانده" FontFamily="{StaticResource PeydaMedium}" FontSize="13" Foreground="{DynamicResource SecondaryWhiteBrush}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding SessionTime}" FontFamily="{StaticResource BlackOpsOne}" FontSize="36" Foreground="{DynamicResource WhiteBrush}">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#FFFFFF" BlurRadius="10" ShadowDepth="0" Opacity="0.3" />
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>

                                <!-- Bottom area: Sub stats (Start Time, Hourly Rate, Cost) -->
                                <Grid Grid.Row="1" Margin="0,20,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Start Time -->
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="زمان شروع" FontFamily="{StaticResource PeydaMedium}" FontSize="12" Foreground="{DynamicResource SecondaryWhiteBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding StartTime}" FontFamily="{StaticResource PeydaBlack}" FontSize="15" Foreground="{DynamicResource WhiteBrush}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Hourly Rate -->
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="نرخ ساعتی" FontFamily="{StaticResource PeydaMedium}" FontSize="12" Foreground="{DynamicResource SecondaryWhiteBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding HourlyRate}" FontFamily="{StaticResource PeydaBlack}" FontSize="15" Foreground="{DynamicResource WhiteBrush}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Current Cost -->
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="هزینه تاکنون" FontFamily="{StaticResource PeydaMedium}" FontSize="12" Foreground="{DynamicResource SecondaryWhiteBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding CurrentCost}" FontFamily="{StaticResource PeydaBlack}" FontSize="15" Foreground="{DynamicResource WhiteBrush}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Hardware Panel directly below -->
                        <!-- Scaled and margin-aligned to right column width -->
                        <c:HardwarePanel x:Name="Hardware" Width="454" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="0,20,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
