<Window x:Class="Sayra.UI.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sayra.UI.Views"
        xmlns:c="clr-namespace:Sayra.UI.Controls"
        xmlns:vm="clr-namespace:Sayra.UI.ViewModels"
        xmlns:suis="clr-namespace:Sayra.UI.Services"
        mc:Ignorable="d"
        Title="SAYRA - Administrative Console"
        Height="1080" Width="1920"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Centralized High-Fidelity SVG Icon Geometries -->
        <Geometry x:Key="SearchIconGeometry">m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z</Geometry>
        <Geometry x:Key="ClearIconGeometry">M6 18L18 6M6 6l12 12</Geometry>
        <Geometry x:Key="RefreshIconGeometry">M16 3h5v5 M21 3l-7 7 M8 21H3v-5 M3 21l7-7 M18.5 15.5a7 7 0 1 1-13-7</Geometry>
        <Geometry x:Key="FilterIconGeometry">M3 4.5h18l-7.5 9v5.25L9.75 21v-7.5l-6.75-9Z</Geometry>
        <Geometry x:Key="ScanIconGeometry">M12 3v3 M12 18v3 M3 12h3 M18 12h3 M5.6 5.6l2.1 2.1 M16.3 16.3l2.1 2.1 M18.4 5.6l-2.1 2.1 M7.7 16.3l-2.1 2.1</Geometry>
        <Geometry x:Key="SteamIconGeometry">M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm-1.8 11.2a2.3 2.3 0 1 1-1.3-3.1 2.3 2.3 0 0 1 1.3 3.1z</Geometry>
        <Geometry x:Key="EpicGamesIconGeometry">M12 2L3 5v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V5zm0 15a3 3 0 1 1 3-3 3 3 0 0 1-3 3z</Geometry>
        <Geometry x:Key="RiotGamesIconGeometry">M4 4h6l2 8 2-8h6l-4 16H8z</Geometry>
        <Geometry x:Key="BattleNetIconGeometry">M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm3.5 11h-7a1.5 1.5 0 0 1 0-3h7a1.5 1.5 0 0 1 0 3z</Geometry>
        <Geometry x:Key="UbisoftIconGeometry">M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 15a5 5 0 1 1 5-5 5 5 0 0 1-5 5z</Geometry>
        <Geometry x:Key="XboxIconGeometry">M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm6 12a13 13 0 0 1-12 0c1.2-2.3 4.2-4 6-4s4.8 1.7 6 4z</Geometry>
        <Geometry x:Key="EAIconGeometry">M2 12h20M12 2v20</Geometry>
        <Geometry x:Key="FolderIconGeometry">M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z</Geometry>
        <Geometry x:Key="AddIconGeometry">M12 5v14M5 12h14</Geometry>
        <Geometry x:Key="DuplicateIconGeometry">M8 4h10a2 2 0 012 2v10a2 2 0 01-2 2H8a2 2 0 01-2-2V6a2 2 0 012-2z M4 8h2v12H4z</Geometry>
        <Geometry x:Key="EditIconGeometry">M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7 M18.5 2.5a2.12 2.12 0 113 3L12 15l-4 1 1-4z</Geometry>
        <Geometry x:Key="RemoveIconGeometry">M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7M10 11v6M14 11v6 M4 7h16 M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3</Geometry>
        <Geometry x:Key="PowerIconGeometry">M18.36 6.64a9 9 0 11-12.73 0 M12 2v10</Geometry>
        <Geometry x:Key="ImportIconGeometry">M12 3v12m0 0l-4-4m4 4l4-4M4 17h16</Geometry>
        <Geometry x:Key="ExportIconGeometry">M12 15V3m0 12l-4-4m4 4l4-4M4 17h16</Geometry>
        <Geometry x:Key="BackupIconGeometry">M12 16.5V9.75m0 0l3 3m-3-3l-3 3M4 12a8 8 0 1116 0v4.5A2.25 2.25 0 0117.75 19H6.25A2.25 2.25 0 014 16.75V12z</Geometry>
        <Geometry x:Key="RestoreIconGeometry">M12 9.75v6.75m0 0l3-3m-3 3l-3-3M4 12a8 8 0 1116 0v4.5A2.25 2.25 0 0117.75 19H6.25A2.25 2.25 0 014 16.75V12z</Geometry>
        <Geometry x:Key="MetadataIconGeometry">M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z</Geometry>
        <Geometry x:Key="SyncIconGeometry">M4 4v5h.582m15.356 2A8.001 8.001 0 1021 12h-1.5M20 20v-5h-.581m0 0a8.003 8.003 0 11-15.355-2H3.5</Geometry>
        <Geometry x:Key="CompareIconGeometry">M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4</Geometry>
        <Geometry x:Key="ValidateIconGeometry">M9 12l2 2 4-4m5 2a9 9 0 11-18 0 9 9 0 0118 0z</Geometry>

        <!-- Base Action Button Style (For Title Bar) -->
        <Style x:Key="ConsoleActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#171A20"/>
            <Setter Property="Foreground" Value="#E1E1E6"/>
            <Setter Property="BorderBrush" Value="#2B3039"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#252932"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#F7E733"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#0E1015"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standard High-Fidelity Button Style -->
        <Style x:Key="ConsoleButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#1D2027"/>
            <Setter Property="Foreground" Value="#C5CBD5"/>
            <Setter Property="BorderBrush" Value="#2B3039"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaBold}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#252932"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#0E1015"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#121418"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#1B1E24"/>
                                <Setter Property="Foreground" Value="#8E95A1"/>
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style (Yellow Accent) -->
        <Style x:Key="PrimaryConsoleButtonStyle" TargetType="Button" BasedOn="{StaticResource ConsoleButtonStyle}">
            <Setter Property="Background" Value="#F7E733"/>
            <Setter Property="Foreground" Value="#0E1015"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#FFFF5F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#E0D12E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style (Red Accent) -->
        <Style x:Key="DangerConsoleButtonStyle" TargetType="Button" BasedOn="{StaticResource ConsoleButtonStyle}">
            <Setter Property="Background" Value="#E65C5C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#F57A7A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#C24444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Mock Showcase Button States (Group 2) -->
        <Style x:Key="HoverMockButtonStyle" TargetType="Button" BasedOn="{StaticResource ConsoleButtonStyle}">
            <Setter Property="Background" Value="#252932"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <Style x:Key="PressedMockButtonStyle" TargetType="Button" BasedOn="{StaticResource ConsoleButtonStyle}">
            <Setter Property="Background" Value="#0E1015"/>
            <Setter Property="Foreground" Value="#C5CBD5"/>
        </Style>

        <Style x:Key="FocusedMockButtonStyle" TargetType="Button" BasedOn="{StaticResource ConsoleButtonStyle}">
            <Setter Property="Background" Value="#1D2027"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#F7E733"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
    </Window.Resources>

    <Grid Background="#0E1015">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" /> <!-- 1. Window Title Header -->
            <RowDefinition Height="*" />  <!-- 2. Workspace Area -->
        </Grid.RowDefinitions>

        <!-- ================= 1. ADMINISTRATIVE TITLE BAR ================= -->
        <Grid Grid.Row="0" Background="#171A20" SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Brand Logo & Context Indicator -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="SAYRA CLIENT"
                           FontFamily="{StaticResource PeydaBlack}"
                           FontSize="18"
                           Foreground="#F7E733"
                           VerticalAlignment="Center" />
                <Border Width="1" Height="20" Background="#2B3039" Margin="15,0" />
                <TextBlock Text="ADMINISTRATIVE WORKSPACE"
                           FontFamily="{StaticResource PeydaBold}"
                           FontSize="14"
                           Foreground="#9A9A9A"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Server Connection Indicator / Global Actions -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                <Border Background="#14BE78" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Local Client Online"
                           FontFamily="{StaticResource PeydaMedium}"
                           FontSize="12"
                           Foreground="#E1E1E6"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- Logout / Exit Console button -->
                <Button Style="{StaticResource ConsoleActionButtonStyle}"
                        Click="Exit_Click"
                        Padding="15,6"
                        Background="#2B1B1B"
                        BorderBrush="#F46B6B"
                        Foreground="#F46B6B"
                        Content="خروج از کنسول مدیریت" />
            </StackPanel>
        </Grid>

        <!-- ================= 2. CONSOLE WORKSPACE (TOP ONLY) ================= -->
        <Grid Grid.Row="1" Background="#0E1015">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Search Area Row -->
                <RowDefinition Height="Auto" /> <!-- Toolbar Row -->
                <RowDefinition Height="*" />    <!-- Rest of Canvas (Empty as Requested) -->
            </Grid.RowDefinitions>

            <!-- ================= A. SEARCH AREA ================= -->
            <Border Grid.Row="0"
                    Height="64"
                    Margin="32,32,32,0"
                    Padding="20,0"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="#2B3039"
                    Background="#171A20"
                    VerticalAlignment="Center">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="7*" />  <!-- Search Box occupies ~70% -->
                        <ColumnDefinition Width="3*" />  <!-- Aligned Right Actions -->
                    </Grid.ColumnDefinitions>

                    <!-- Left: Large Search Box (70% Width) -->
                    <Border Grid.Column="0"
                            Background="#1D2027"
                            BorderBrush="#2B3039"
                            BorderThickness="1"
                            CornerRadius="8"
                            Height="44"
                            Padding="12,0"
                            VerticalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left Search Icon -->
                            <Path Grid.Column="0"
                                  Data="{StaticResource SearchIconGeometry}"
                                  Width="18"
                                  Height="18"
                                  Fill="#8E95A1"
                                  Stretch="Uniform"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center" />

                            <!-- Text Area & Placeholder -->
                            <Grid Grid.Column="1">
                                <TextBlock IsHitTestVisible="False"
                                           Text="Search by game name, executable, publisher, launcher or category..."
                                           Foreground="#8E95A1"
                                           FontSize="13"
                                           FontFamily="{StaticResource PeydaMedium}"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBox x:Name="SearchTextBox"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#FFFFFF"
                                         CaretBrush="#F7E733"
                                         FontSize="13"
                                         FontFamily="{StaticResource PeydaMedium}"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Right: Aligned Buttons (Clear Search, Refresh, Quick Filter) -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <!-- Clear Search Button -->
                        <Button Style="{StaticResource ConsoleButtonStyle}"
                                Command="{Binding ClearSearchCommand}"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource ClearIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Clear Search" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                            </StackPanel>
                        </Button>

                        <!-- Refresh Button -->
                        <Button Style="{StaticResource ConsoleButtonStyle}"
                                Command="{Binding RefreshCommand}"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource RefreshIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Refresh" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                            </StackPanel>
                        </Button>

                        <!-- Quick Filter Button -->
                        <Button Style="{StaticResource ConsoleButtonStyle}"
                                Command="{Binding QuickFilterCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource FilterIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Quick Filter" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================= B. ADMINISTRATION TOOLBAR ================= -->
            <Border Grid.Row="1"
                    Height="88"
                    Margin="32,24,32,0"
                    Padding="20,12"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="#2B3039"
                    Background="#171A20"
                    VerticalAlignment="Center">

                <!-- Smooth Horizontal Scrollbar for Toolbar command groups -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- GROUP 1: DISCOVERY -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Button Style="{StaticResource PrimaryConsoleButtonStyle}" Command="{Binding ScanAllCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource ScanIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Scan All" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ScanSteamCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource SteamIconGeometry}" Width="16" Height="16" Fill="#66c0f4" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Steam" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ScanEpicCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource EpicGamesIconGeometry}" Width="16" Height="16" Fill="#FFFFFF" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Epic Games" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ScanRiotCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource RiotGamesIconGeometry}" Width="16" Height="16" Fill="#D11F36" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Riot Games" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ScanBattleNetCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource BattleNetIconGeometry}" Width="16" Height="16" Fill="#00AEFF" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Battle.net" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ScanUbisoftCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource UbisoftIconGeometry}" Width="16" Height="16" Fill="#0070FF" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Ubisoft Connect" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ScanXboxCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource XboxIconGeometry}" Width="16" Height="16" Fill="#107C11" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Xbox" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ScanEACommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource EAIconGeometry}" Width="16" Height="16" Fill="#F55734" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="EA App" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ScanCustomCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource FolderIconGeometry}" Width="16" Height="16" Fill="#FFB900" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Custom Folder" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Text="DISCOVERY" FontSize="11" FontFamily="{StaticResource PeydaBold}" Foreground="#8E95A1" HorizontalAlignment="Center" Margin="0,6,0,0" />
                        </Grid>

                        <!-- Vertical Divider Group 1 to 2 -->
                        <Border Width="1" Height="40" Background="#303641" Margin="16,0"/>

                        <!-- GROUP 2: MANAGEMENT (Showcasing all Button Interaction States) -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <!-- Add Game (Normal - Primary yellow button style) -->
                                <Button Style="{StaticResource PrimaryConsoleButtonStyle}" Command="{Binding RegisterSoftwareCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource AddIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Add Game" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <!-- Add Application (Hover State representation) -->
                                <Button Style="{StaticResource HoverMockButtonStyle}" Command="{Binding AddApplicationCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource AddIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Add Application" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <!-- Duplicate (Pressed State representation) -->
                                <Button Style="{StaticResource PressedMockButtonStyle}" Command="{Binding DuplicateCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource DuplicateIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Duplicate" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <!-- Edit (Focused State representation) -->
                                <Button Style="{StaticResource FocusedMockButtonStyle}" Command="{Binding EditAppCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource EditIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Edit" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <!-- Remove (Disabled State - using red danger style but clearly muted via IsEnabled=False) -->
                                <Button Style="{StaticResource ConsoleButtonStyle}" IsEnabled="False" Command="{Binding RemoveSelectedCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource RemoveIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Remove" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <!-- Enable (Loading State - containing live rotation animation on spinner icon) -->
                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding EnableAppCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Active Spinning Loader -->
                                        <Path Data="{StaticResource RefreshIconGeometry}" Width="16" Height="16" Fill="#C5CBD5" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                            <Path.RenderTransform>
                                                <RotateTransform x:Name="LoaderSpinTransform" Angle="0"/>
                                            </Path.RenderTransform>
                                            <Path.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetName="LoaderSpinTransform"
                                                                             Storyboard.TargetProperty="Angle"
                                                                             From="0" To="360" Duration="0:0:1.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Path.Triggers>
                                        </Path>
                                        <TextBlock Text="Enable..." VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}" Foreground="#8E95A1"/>
                                    </StackPanel>
                                </Button>

                                <!-- Disable (Normal State) -->
                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding DisableAppCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource PowerIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Disable" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Text="MANAGEMENT" FontSize="11" FontFamily="{StaticResource PeydaBold}" Foreground="#8E95A1" HorizontalAlignment="Center" Margin="0,6,0,0" />
                        </Grid>

                        <!-- Vertical Divider Group 2 to 3 -->
                        <Border Width="1" Height="40" Background="#303641" Margin="16,0"/>

                        <!-- GROUP 3: IMPORT / EXPORT -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ImportAppCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource ImportIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Import" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ExportAppCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource ExportIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Export" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding BackupAppCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource BackupIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Backup" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding RestoreAppCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource RestoreIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Restore" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ImportMetadataCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource MetadataIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Import Metadata" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ExportConfigCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource MetadataIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Export Configuration" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Text="IMPORT / EXPORT" FontSize="11" FontFamily="{StaticResource PeydaBold}" Foreground="#8E95A1" HorizontalAlignment="Center" Margin="0,6,0,0" />
                        </Grid>

                        <!-- Vertical Divider Group 3 to 4 -->
                        <Border Width="1" Height="40" Background="#303641" Margin="16,0"/>

                        <!-- GROUP 4: SYNCHRONIZATION -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding SyncFromServerCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource SyncIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Sync From Server" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding SyncToServerCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource SyncIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Sync To Server" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding CompareConfigsCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource CompareIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Compare" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding ValidatePathsCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource ValidateIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Validate" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding RescanAllCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource RefreshIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Rescan" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource ConsoleButtonStyle}" Command="{Binding RepairMetadataCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource MetadataIconGeometry}" Width="16" Height="16" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Repair Metadata" VerticalAlignment="Center" FontSize="13" FontFamily="{StaticResource PeydaBold}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Text="SYNCHRONIZATION" FontSize="11" FontFamily="{StaticResource PeydaBold}" Foreground="#8E95A1" HorizontalAlignment="Center" Margin="0,6,0,0" />
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ================= C. CANVAS WORKSPACE (REST FILLER) ================= -->
            <Grid Grid.Row="2" Background="#0E1015"/>
        </Grid>

        <!-- Floating Horizontal Notification Card (Overlays bottom of UI) -->
        <Grid Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40" Panel.ZIndex="1000" IsHitTestVisible="True"
              DataContext="{Binding Source={x:Static suis:NotificationService.Instance}}"
              Visibility="{Binding IsNotificationVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <c:NotificationCard DataContext="{Binding CurrentNotification}" />
        </Grid>
    </Grid>
</Window>