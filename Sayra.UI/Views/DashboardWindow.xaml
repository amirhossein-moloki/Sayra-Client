<Window x:Class="Sayra.UI.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sayra.UI.Views"
        xmlns:c="clr-namespace:Sayra.UI.Controls"
        xmlns:components="clr-namespace:Sayra.UI.Views.Components"
        xmlns:suis="clr-namespace:Sayra.UI.Services"
        mc:Ignorable="d"
        Title="SAYRA Dashboard"
        Height="1080" Width="1920"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="LeftToRight">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Fade-in animation for Window content -->
        <Storyboard x:Key="WindowFadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1.0" />
        </Storyboard>

        <!-- Premium End Session Button Style -->
        <Style x:Key="EndSessionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect x:Name="GlowEffect" Color="#F46B6B" BlurRadius="10" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Specified End Session Button Icon with stroke style, 1.5 thickness, and transparent fill -->
                                <Path Grid.Column="0"
                                      Data="{DynamicResource EndSessionIconGeometry}"
                                      Stroke="{DynamicResource RedBrush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"/>

                                <!-- Text with Peyda Bold, Numbers/Buttons -->
                                <TextBlock Grid.Column="2"
                                           Text="پایان دادن به استفاده"
                                           Foreground="{DynamicResource RedBrush}"
                                           FontFamily="{StaticResource PeydaBold}"
                                           FontSize="15"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1AF46B6B"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="1.5"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.6" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="15" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#33F46B6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeInStoryboard}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootGrid" Background="#08090D">
        <!-- 2. MAIN LAYOUT GRID -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Top Bar Row -->
                <RowDefinition Height="Auto" /> <!-- Session Hero Row -->
                <RowDefinition Height="*" />    <!-- Content Row -->
            </Grid.RowDefinitions>

            <!-- HEADER LAYER: Top bar reusable component -->
            <c:TopBar Grid.Row="0" />

            <!-- SESSION HERO PANEL: Full width gaming banner directly below header -->
            <components:SessionHero x:Name="SessionHeroCtrl" Grid.Row="1" Height="240" Margin="0" />

            <!-- CONTENT ROW: Prepared structure for layout sections (Games, Hardware) -->
            <Grid Grid.Row="2" Margin="30,20,30,30">
                <Grid.ColumnDefinitions>
                    <!-- Column 0: Left Game Navigation Sidebar (Fixed 300px width) -->
                    <ColumnDefinition Width="Auto" />

                    <!-- Column 1: Middle/Center Games Library Area (Stretches to fill remaining space) -->
                    <ColumnDefinition Width="*" />

                    <!-- Column 2: Right Hardware System Detail Panel Area (Fixed 300px width) -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar Grid Column -->
                <Grid Grid.Column="0" Margin="0,0,15,0">
                    <components:AdPanel x:Name="AdPanelCtrl" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="0,24,0,0" />
                </Grid>

                <!-- Middle Games Library Grid Column -->
                <!-- Panel.ZIndex set to 2 to display above adjacent panels if they overlap / scale -->
                <Grid Grid.Column="1" Margin="15,0,15,0" Panel.ZIndex="2">
                    <c:GameLibrary x:Name="GameLib" />
                </Grid>

                <!-- Right Hardware Area Grid Column -->
                <!-- Panel.ZIndex set to 1 to stay layered under middle column when overlapped -->
                <Grid Grid.Column="2" Margin="15,0,0,0" Panel.ZIndex="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Label Area -->
                        <RowDefinition Height="Auto" /> <!-- HardwarePanel Area -->
                        <RowDefinition Height="20" />   <!-- Spacing (20px below System Detail) -->
                        <RowDefinition Height="Auto" /> <!-- End Session Button -->
                    </Grid.RowDefinitions>

                    <!-- "کتابخانه بازی ها" Label at the top right, aligned with the right edge -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,24,0,20">
                        <TextBlock Text="کتابخانه بازی ها"
                                   FontFamily="{StaticResource PeydaBold}"
                                   FontSize="26"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                        <!-- Subtle yellow accent indicator bar -->
                        <Border Width="4" Height="26" Background="#F5FF00" CornerRadius="2" Margin="12,0,0,0"/>
                    </StackPanel>

                    <!-- Shifted HardwarePanel (System Detail) to align with Game Cards (22px down from top label row) -->
                    <c:HardwarePanel x:Name="Hardware" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="0,22,0,0" />

                    <Button Grid.Row="3"
                            Style="{StaticResource EndSessionButtonStyle}"
                            Click="EndSession_Click"
                            HorizontalAlignment="Stretch" />
                </Grid>
            </Grid>
        </Grid>

        <!-- Floating Horizontal Notification Card -->
        <Grid VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40" Panel.ZIndex="1000" IsHitTestVisible="True"
              DataContext="{Binding Source={x:Static suis:NotificationService.Instance}}"
              Visibility="{Binding IsNotificationVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <c:NotificationCard DataContext="{Binding CurrentNotification}" />
        </Grid>
    </Grid>
</Window>
