<Window x:Class="Sayra.UI.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sayra.UI.Views"
        xmlns:c="clr-namespace:Sayra.UI.Controls"
        xmlns:components="clr-namespace:Sayra.UI.Views.Components"
        mc:Ignorable="d"
        Title="SAYRA Dashboard"
        Height="1080" Width="1920"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="LeftToRight">

    <Window.Resources>
        <!-- Fade-in animation for Window content -->
        <Storyboard x:Key="WindowFadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1.0" />
        </Storyboard>

        <!-- Premium End Session Button Style -->
        <Style x:Key="EndSessionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1AEF4444"/>
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect x:Name="GlowEffect" Color="#EF4444" BlurRadius="10" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Power Icon -->
                                <Path Grid.Column="0"
                                      Data="M12,2V12 M16.24,7.76A6,6 0 1,1 7.76,7.76"
                                      Stroke="#EF4444"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"/>

                                <!-- Text -->
                                <TextBlock Grid.Column="2"
                                           Text="پایان دادن به استفاده"
                                           Foreground="White"
                                           FontFamily="{StaticResource PeydaMedium}"
                                           FontSize="15"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#33EF4444"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="1.5"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.4" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#4AEF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeInStoryboard}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootGrid">
        <!-- 1. BACKGROUND LAYER: Live Video Background with cinematic dark overlay (#08090D at 60% opacity) -->
        <c:VideoBackground x:Name="VideoBg" VideoName="Video/DashboardBg.mp4" OverlayBackground="#9908090D" />

        <!-- 2. MAIN LAYOUT GRID -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Top Bar Row -->
                <RowDefinition Height="Auto" /> <!-- Session Hero Row -->
                <RowDefinition Height="*" />    <!-- Content Row -->
            </Grid.RowDefinitions>

            <!-- HEADER LAYER: Top bar reusable component -->
            <c:TopBar Grid.Row="0" />

            <!-- SESSION HERO PANEL: Full width gaming banner directly below header -->
            <components:SessionHero x:Name="SessionHeroCtrl" Grid.Row="1" Height="240" Margin="0" />

            <!-- CONTENT ROW: Prepared structure for layout sections (Games, Hardware) -->
            <Grid Grid.Row="2" Margin="30,20,30,30">
                <Grid.ColumnDefinitions>
                    <!-- Column 0: Left Game Navigation Sidebar (Fixed 300px width) -->
                    <ColumnDefinition Width="Auto" />

                    <!-- Column 1: Middle/Center Games Library Area (Stretches to fill remaining space) -->
                    <ColumnDefinition Width="*" />

                    <!-- Column 2: Right Hardware System Detail Panel Area (Fixed 235.2px width) -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar Grid Column -->
                <Grid Grid.Column="0" Margin="0,0,15,0">
                    <components:GameSidebar x:Name="SidebarCtrl" HorizontalAlignment="Left" VerticalAlignment="Top" />
                </Grid>

                <!-- Middle Games Library Grid Column -->
                <Grid Grid.Column="1" Margin="15,0,15,0">
                    <c:GameLibrary x:Name="GameLib" />
                </Grid>

                <!-- Right Hardware Area Grid Column -->
                <Grid Grid.Column="2" Margin="15,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- HardwarePanel -->
                        <RowDefinition Height="20" />   <!-- Spacing (20px below System Detail) -->
                        <RowDefinition Height="Auto" /> <!-- End Session Button -->
                    </Grid.RowDefinitions>

                    <c:HardwarePanel x:Name="Hardware" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Top" />

                    <Button Grid.Row="2"
                            Style="{StaticResource EndSessionButtonStyle}"
                            Click="EndSession_Click"
                            HorizontalAlignment="Stretch" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
