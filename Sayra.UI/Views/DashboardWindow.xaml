<Window x:Class="Sayra.UI.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sayra.UI.Views"
        xmlns:c="clr-namespace:Sayra.UI.Controls"
        xmlns:components="clr-namespace:Sayra.UI.Views.Components"
        xmlns:suis="clr-namespace:Sayra.UI.Services"
        mc:Ignorable="d"
        Title="SAYRA Dashboard"
        Height="1080" Width="1920"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Normal"
        WindowStartupLocation="CenterScreen"
        FlowDirection="LeftToRight">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Premium Color Palette Solid Color Brushes -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#0E1015"/>
        <SolidColorBrush x:Key="MainSurfaceBrush" Color="#171A20"/>
        <SolidColorBrush x:Key="SecondarySurfaceBrush" Color="#1D2027"/>
        <SolidColorBrush x:Key="BordersBrush" Color="#2B3039"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#252932"/>
        <SolidColorBrush x:Key="SelectedBrush" Color="#2F3542"/>
        <SolidColorBrush x:Key="DividerBrush" Color="#303641"/>
        <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#F7E733"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#FFE84F"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E55B5B"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#33D17A"/>
        <SolidColorBrush x:Key="InformationBrush" Color="#63C5FF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#BFC5D0"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8D95A3"/>

        <!-- Typography Fallbacks utilizing Segoe UI Variable -->
        <FontFamily x:Key="SegoeUIVariable">Segoe UI Variable, Segoe UI, Arial</FontFamily>

        <!-- Typography Styles -->
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SegoeUIVariable}"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SegoeUIVariable}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="SubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SegoeUIVariable}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>

        <Style x:Key="BodyStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SegoeUIVariable}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>

        <Style x:Key="SmallTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SegoeUIVariable}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        </Style>

        <!-- Premium Surface Panel Styling -->
        <Style x:Key="PremiumPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource MainSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BordersBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="2" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Placeholder Nested Block Styling -->
        <Style x:Key="PlaceholderBlockStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SecondarySurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BordersBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Width="1920" Height="1080" Background="{StaticResource BackgroundBrush}" ClipToBounds="True">
        <!-- Spacing System Margin: 32px Outer Margin -->
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- SECTION 1: Search Area (64px) -->
                <RowDefinition Height="Auto" /> <!-- SECTION 2: Toolbar Area (92px) -->
                <RowDefinition Height="*" />    <!-- SECTION 3: Main Workspace (Flexible, fills remaining height) -->
                <RowDefinition Height="Auto" /> <!-- SECTION 4: Footer Statistics (90px) -->
            </Grid.RowDefinitions>

            <!-- SECTION 1: Search Area (Height: 64px) -->
            <Border Grid.Row="0" Height="64" Style="{StaticResource PremiumPanelStyle}">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Search Icon (Using requested stroke geometry style) -->
                    <Path Grid.Column="0"
                          Data="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
                          Stroke="{StaticResource TextMutedBrush}"
                          StrokeThickness="1.5"
                          Width="18" Height="18"
                          Stretch="Uniform"
                          VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="SEARCH PLACEHOLDER BLOCK"
                               Style="{StaticResource SubtitleStyle}"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"/>
                </Grid>
            </Border>

            <!-- SECTION 2: Toolbar Area (Height: 92px, Margin Top: 24px) -->
            <Grid Grid.Row="1" Height="92" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28*" />
                    <ColumnDefinition Width="18*" />
                    <ColumnDefinition Width="22*" />
                    <ColumnDefinition Width="32*" />
                </Grid.ColumnDefinitions>

                <!-- Group 1 (28% Width) -->
                <Border Grid.Column="0" Margin="0,0,16,0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="24,0">
                        <TextBlock Text="TOOLBAR GROUP 1 — 28%" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" />
                    </Grid>
                </Border>

                <!-- Group 2 (18% Width) -->
                <Border Grid.Column="1" Margin="0,0,16,0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="24,0">
                        <TextBlock Text="TOOLBAR GROUP 2 — 18%" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" />
                    </Grid>
                </Border>

                <!-- Group 3 (22% Width) -->
                <Border Grid.Column="2" Margin="0,0,16,0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="24,0">
                        <TextBlock Text="TOOLBAR GROUP 3 — 22%" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" />
                    </Grid>
                </Border>

                <!-- Group 4 (32% Width) -->
                <Border Grid.Column="3" Margin="0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="24,0">
                        <TextBlock Text="TOOLBAR GROUP 4 — 32%" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" />
                    </Grid>
                </Border>
            </Grid>

            <!-- SECTION 3: Main Workspace (Margin Top: 24px) -->
            <Grid Grid.Row="2" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" /> <!-- LEFT PANEL: 260px (Fixed) -->
                    <ColumnDefinition Width="24" />  <!-- Gap: 24px -->
                    <ColumnDefinition Width="*" MinWidth="900" /> <!-- CENTER PANEL: Flexible -->
                    <ColumnDefinition Width="24" />  <!-- Gap: 24px -->
                    <ColumnDefinition Width="420" /> <!-- RIGHT PANEL: 420px (Fixed) -->
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL -->
                <Border Grid.Column="0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="24">
                        <TextBlock Text="LEFT PANEL PLACEHOLDER (260px)" Style="{StaticResource SubtitleStyle}" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <!-- CENTER PANEL -->
                <Border Grid.Column="2" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="24">
                        <!-- Main workspace indicator -->
                        <TextBlock Text="CENTER PANEL MAIN WORKSPACE" Style="{StaticResource SectionTitleStyle}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Top right reserve space for future toolbar -->
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="320" Height="40" Style="{StaticResource PlaceholderBlockStyle}">
                            <TextBlock Text="RESERVED FOR FUTURE TOOLBAR" Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <!-- Bottom reserve space for pagination -->
                        <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Width="400" Height="40" Style="{StaticResource PlaceholderBlockStyle}">
                            <TextBlock Text="RESERVED FOR PAGINATION" Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- RIGHT PANEL -->
                <Border Grid.Column="4" Style="{StaticResource PremiumPanelStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="16" Padding="0,0,8,0">
                        <StackPanel>
                            <!-- 1. General: 120px -->
                            <Border Height="120" Margin="0,0,0,16" Style="{StaticResource PlaceholderBlockStyle}">
                                <Grid Margin="16">
                                    <TextBlock Text="GENERAL" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                    <TextBlock Text="Height: 120px" Style="{StaticResource SmallTextStyle}" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>

                            <!-- 2. Executable: 120px -->
                            <Border Height="120" Margin="0,0,0,16" Style="{StaticResource PlaceholderBlockStyle}">
                                <Grid Margin="16">
                                    <TextBlock Text="EXECUTABLE" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                    <TextBlock Text="Height: 120px" Style="{StaticResource SmallTextStyle}" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>

                            <!-- 3. Launcher: 90px -->
                            <Border Height="90" Margin="0,0,0,16" Style="{StaticResource PlaceholderBlockStyle}">
                                <Grid Margin="16">
                                    <TextBlock Text="LAUNCHER" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                    <TextBlock Text="Height: 90px" Style="{StaticResource SmallTextStyle}" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>

                            <!-- 4. Launch Settings: 170px -->
                            <Border Height="170" Margin="0,0,0,16" Style="{StaticResource PlaceholderBlockStyle}">
                                <Grid Margin="16">
                                    <TextBlock Text="LAUNCH SETTINGS" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                    <TextBlock Text="Height: 170px" Style="{StaticResource SmallTextStyle}" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>

                            <!-- 5. Runtime: 140px -->
                            <Border Height="140" Margin="0,0,0,16" Style="{StaticResource PlaceholderBlockStyle}">
                                <Grid Margin="16">
                                    <TextBlock Text="RUNTIME" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                    <TextBlock Text="Height: 140px" Style="{StaticResource SmallTextStyle}" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>

                            <!-- 6. Images: 170px -->
                            <Border Height="170" Margin="0,0,0,16" Style="{StaticResource PlaceholderBlockStyle}">
                                <Grid Margin="16">
                                    <TextBlock Text="IMAGES" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                    <TextBlock Text="Height: 170px" Style="{StaticResource SmallTextStyle}" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>

                            <!-- 7. Metadata: 130px -->
                            <Border Height="130" Margin="0,0,0,16" Style="{StaticResource PlaceholderBlockStyle}">
                                <Grid Margin="16">
                                    <TextBlock Text="METADATA" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                    <TextBlock Text="Height: 130px" Style="{StaticResource SmallTextStyle}" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>

                            <!-- 8. Tags: 90px -->
                            <Border Height="90" Margin="0,0,0,16" Style="{StaticResource PlaceholderBlockStyle}">
                                <Grid Margin="16">
                                    <TextBlock Text="TAGS" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                    <TextBlock Text="Height: 90px" Style="{StaticResource SmallTextStyle}" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>

                            <!-- 9. Security: 120px -->
                            <Border Height="120" Margin="0,0,0,16" Style="{StaticResource PlaceholderBlockStyle}">
                                <Grid Margin="16">
                                    <TextBlock Text="SECURITY" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                    <TextBlock Text="Height: 120px" Style="{StaticResource SmallTextStyle}" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>

                            <!-- 10. Visibility: 100px -->
                            <Border Height="100" Margin="0" Style="{StaticResource PlaceholderBlockStyle}">
                                <Grid Margin="16">
                                    <TextBlock Text="VISIBILITY" Style="{StaticResource SubtitleStyle}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                    <TextBlock Text="Height: 100px" Style="{StaticResource SmallTextStyle}" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- SECTION 4: Footer Statistics (Height: 90px, Margin Top: 24px) -->
            <Grid Grid.Row="3" Height="90" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,16,0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="16,0">
                        <TextBlock Text="STAT 1" Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Margin="0,0,16,0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="16,0">
                        <TextBlock Text="STAT 2" Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border Grid.Column="2" Margin="0,0,16,0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="16,0">
                        <TextBlock Text="STAT 3" Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border Grid.Column="3" Margin="0,0,16,0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="16,0">
                        <TextBlock Text="STAT 4" Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border Grid.Column="4" Margin="0,0,16,0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="16,0">
                        <TextBlock Text="STAT 5" Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border Grid.Column="5" Margin="0,0,16,0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="16,0">
                        <TextBlock Text="STAT 6" Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border Grid.Column="6" Margin="0,0,16,0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="16,0">
                        <TextBlock Text="STAT 7" Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border Grid.Column="7" Margin="0" Style="{StaticResource PremiumPanelStyle}">
                    <Grid Margin="16,0">
                        <TextBlock Text="STAT 8" Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
