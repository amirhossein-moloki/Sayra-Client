<UserControl x:Class="Sayra.UI.Views.Components.AdPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="300"
             Width="300">

    <UserControl.Resources>
        <!-- Standard Button Template/Style with explicit internal Foreground binding -->
        <Style x:Key="AdButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#ffff3d"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect x:Name="Glow" Color="#ffff3d" BlurRadius="12" ShadowDepth="0" Opacity="0" />
                            </Border.Effect>
                            <ContentPresenter x:Name="ContentPresenter"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <!-- Bind internal TextBlock foreground explicitly to templated parent -->
                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f4f46b"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Glow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.6" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Glow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Main Glass Container mimicking the original GameSidebar layout -->
    <Border Background="#0DFFFFFF"
            BorderBrush="#1EFFFFFF"
            BorderThickness="1"
            CornerRadius="22"
            Padding="16,20"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="3" Opacity="0.4" />
        </Border.Effect>

        <Grid FlowDirection="RightToLeft">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="12" />   <!-- Spacer -->
                <RowDefinition Height="*" />    <!-- Content Area (Graphic / Offer Details) -->
                <RowDefinition Height="Auto" /> <!-- CTA Button -->
            </Grid.RowDefinitions>

            <!-- 1. HEADER SECTION -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="4" Height="16" Background="#F5FF00" CornerRadius="2" Margin="0,0,8,0"/>
                <TextBlock Text="پیشنهاد ویژه سایرا"
                           FontFamily="{StaticResource PeydaBold}"
                           FontSize="16"
                           Foreground="White"
                           Margin="0,0,0,0"/>
            </StackPanel>

            <!-- 2. CONTENT AREA -->
            <Grid Grid.Row="2" Margin="0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Promotion Title / Badge -->
                    <RowDefinition Height="Auto" /> <!-- Description -->
                    <RowDefinition Height="*" />    <!-- Illustrated/Decorative box -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="شارژ کیف پول با ۲۰٪ هدیه"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="18"
                               Foreground="#ffff3d"
                               TextAlignment="Right"
                               TextWrapping="Wrap" />
                    <TextBlock Text="به مدت محدود"
                               FontFamily="{StaticResource PeydaLight}"
                               FontSize="11"
                               Foreground="#9A9A9A"
                               TextAlignment="Right"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- Detailed offer description using premium fonts -->
                <TextBlock Grid.Row="1"
                           Text="با شارژ حساب خود در جشنواره تابستانه سایرا، از ۲۰٪ اعتبار هدیه بدون سقف بهره‌مند شوید. این اعتبار بلافاصله فعال شده و برای تمام بازی‌ها قابل استفاده است."
                           FontFamily="{StaticResource PeydaMedium}"
                           FontSize="13"
                           Foreground="#E1E1E6"
                           TextAlignment="Right"
                           TextWrapping="Wrap"
                           LineHeight="20" />

                <!-- Stylized decorative container illustrating cafe buffet / buffet ordering -->
                <Border Grid.Row="2"
                        Margin="0,15,0,0"
                        Background="#15FFFFFF"
                        BorderBrush="#15FFFFFF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12">
                    <Grid>
                        <!-- Neon glow decorative background effect -->
                        <Border Background="#ffff3d" Opacity="0.03" CornerRadius="12"/>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- SVG Path / Buffet symbol placeholder -->
                            <Path Data="M11 9H9V2H7V9H5V2H3V9C3 11.12 4.66 12.84 6.75 12.97V22H9.25V12.97C11.34 12.84 13 11.12 13 9M16 6V14H18.5V22H21V2C18.24 2 16 4.24 16 6Z"
                                  Fill="#ffff3d"
                                  Width="42" Height="42"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center" />
                            <TextBlock Text="سفارش آنلاین بوفه گیم‌نت"
                                       FontFamily="{StaticResource PeydaBold}"
                                       FontSize="14"
                                       Foreground="White"
                                       Margin="0,10,0,2"
                                       TextAlignment="Center" />
                            <TextBlock Text="انواع نوشیدنی و خوراکی درب سیستم شما"
                                       FontFamily="{StaticResource PeydaLight}"
                                       FontSize="11"
                                       Foreground="#9A9A9A"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- 3. CALL TO ACTION BUTTON -->
            <Button Grid.Row="3"
                    Style="{StaticResource AdButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Margin="0,10,0,0">
                <TextBlock Text="شارژ آنلاین حساب"
                           FontFamily="{StaticResource PeydaBold}"
                           FontSize="15" />
            </Button>
        </Grid>
    </Border>
</UserControl>
