<UserControl x:Class="Sayra.UI.Views.Components.SessionHero"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:vm="clr-namespace:Sayra.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="240" d:DesignWidth="1860">

    <UserControl.DataContext>
        <vm:SessionHeroViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Soft breathing and glow animation for the background SAYRA logo -->
        <Style x:Key="HeroLogoStyle" TargetType="svgc:SvgViewbox">
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                             From="0.1" To="0.35" Duration="0:0:4" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                             From="15" To="35" Duration="0:0:4" />
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.05" To="0.12" Duration="0:0:4" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Dynamic card hover style for information cards -->
        <Style x:Key="HeroInfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1C1D24" />
            <Setter Property="BorderBrush" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Width" Value="210" />
            <Setter Property="Padding" Value="14,10" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#25262E" />
                    <Setter Property="BorderBrush" Value="#30FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Main Banner Container with premium glassmorphic style -->
    <!-- Background: rgba(8,9,13, 0.8) for dark transparent overlay -->
    <!-- Border: rgba(255,255,255, 0.1) for thin transparent border -->
    <!-- CornerRadius: 22 -->
    <!-- Height: approx 220-260px (Design Height 240) -->
    <Border CornerRadius="22"
            Background="#D908090D"
            BorderBrush="#1AFFFFFF"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <!-- Gentle yellow neon glow atmospheric shadow -->
            <DropShadowEffect Color="#F5FF00" BlurRadius="25" ShadowDepth="0" Opacity="0.12" />
        </Border.Effect>

        <Grid>
            <!-- 1. BACKGROUND LAYER: Large Faded SAYRA Logo -->
            <svgc:SvgViewbox Source="/Assets/sayra.svg"
                             Width="380" Height="380"
                             Style="{StaticResource HeroLogoStyle}"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,-40,-40"
                             IsHitTestVisible="False">
                <svgc:SvgViewbox.Effect>
                    <DropShadowEffect Color="#F5FF00" BlurRadius="25" ShadowDepth="0" Opacity="0.2" />
                </svgc:SvgViewbox.Effect>
            </svgc:SvgViewbox>

            <!-- 2. FOREGROUND CONTENT LAYER -->
            <Grid Margin="32,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Align Left Side content vertically -->
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <!-- Session Timer -->
                    <TextBlock Text="{Binding SessionTime}"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="64"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,14">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFFFFF" BlurRadius="15" ShadowDepth="0" Opacity="0.35" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Financial Cards Stack -->
                    <StackPanel Orientation="Horizontal">
                        <!-- Cost Card (هزینه تاکنون) -->
                        <Border Style="{StaticResource HeroInfoCardStyle}" Margin="0,0,16,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.4" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Coin/Cash icon with neon glow -->
                                <Path Grid.Column="0"
                                      Data="M21,18V19A2,2 0 0,1 19,21H5C3.89,21 3,20.1 3,19V5C3,3.89 3.89,3 5,3H19A2,2 0 0,1 21,5V6H12C10.89,6 10,6.89 10,8V16C10,17.11 10.89,18 12,18H21M12,16H22V8H12V16M16,13.5A1.5,1.5 0 0,1 14.5,12A1.5,1.5 0 0,1 16,10.5A1.5,1.5 0 0,1 17.5,12A1.5,1.5 0 0,1 16,13.5Z"
                                      Fill="#F5FF00"
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#F5FF00" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                    </Path.Effect>
                                </Path>

                                <!-- Labels in RTL for correct Persian rendering -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" FlowDirection="RightToLeft">
                                    <TextBlock Text="هزینه تاکنون"
                                               FontFamily="{StaticResource PeydaMedium}"
                                               FontSize="11"
                                               Foreground="#A1A1AA" />
                                    <TextBlock Text="{Binding CurrentCost}"
                                               FontFamily="{StaticResource PeydaBold}"
                                               FontSize="15"
                                               Foreground="White"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Hourly Rate Card (نرخ ساعتی) -->
                        <Border Style="{StaticResource HeroInfoCardStyle}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.4" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Clock icon with neon glow -->
                                <Path Grid.Column="0"
                                      Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"
                                      Fill="#F5FF00"
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#F5FF00" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                    </Path.Effect>
                                </Path>

                                <!-- Labels in RTL for correct Persian rendering -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" FlowDirection="RightToLeft">
                                    <TextBlock Text="نرخ ساعتی"
                                               FontFamily="{StaticResource PeydaMedium}"
                                               FontSize="11"
                                               Foreground="#A1A1AA" />
                                    <TextBlock Text="{Binding HourlyRate}"
                                               FontFamily="{StaticResource PeydaBold}"
                                               FontSize="15"
                                               Foreground="White"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
