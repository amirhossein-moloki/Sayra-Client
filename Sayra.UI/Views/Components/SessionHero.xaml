<UserControl x:Class="Sayra.UI.Views.Components.SessionHero"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:vm="clr-namespace:Sayra.UI.ViewModels"
             xmlns:c="clr-namespace:Sayra.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="240" d:DesignWidth="1860">

    <UserControl.DataContext>
        <vm:SessionHeroViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Soft breathing and glow animation for the background SAYRA logo -->
        <Style x:Key="HeroLogoStyle" TargetType="svgc:SvgViewbox">
            <Setter Property="Opacity" Value="0.15" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect x:Name="HeroLogoGlow" Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="20" ShadowDepth="0" Opacity="0.3" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                             From="0.3" To="0.85" Duration="0:0:4" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                             From="20" To="60" Duration="0:0:4" />
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.15" To="0.45" Duration="0:0:4" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Premium style for the single merged pricing container - Glass Effect -->
        <Style x:Key="MergedPricingContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="#CC1F1F23" /> <!-- #1F1F23 with transparency -->
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Main Banner Container with premium glassmorphic style -->
    <Border CornerRadius="0"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            ClipToBounds="True">

        <Grid>
            <!-- Video background for the session hero banner -->
            <c:VideoBackground VideoName="LoginBg.mp4" OverlayBackground="#B308090D" />

            <!-- Dark linear gradient overlay with maximum contrast based on #101014 -->
            <Border Grid.Row="0" Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#F2101014" Offset="0" />
                        <GradientStop Color="#CC101014" Offset="0.5" />
                        <GradientStop Color="#F2101014" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- 1. BACKGROUND LAYER: Large Faded SAYRA Logo -->
            <svgc:SvgViewbox Source="/Assets/sayra.svg"
                             Width="456" Height="456"
                             Style="{StaticResource HeroLogoStyle}"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,110,0"
                             IsHitTestVisible="False" />

            <!-- 2. FOREGROUND CONTENT LAYER -->
            <Grid Margin="60,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Align Left Side content vertically -->
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <!-- Session Timer - Numbers: BlackOpsOne -->
                    <TextBlock Text="{Binding SessionTime}"
                               FontFamily="{StaticResource BlackOpsOne}"
                               FontSize="64"
                               Foreground="{DynamicResource WhiteBrush}"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,14">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{DynamicResource Theme.Colors.Text.Primary}" BlurRadius="15" ShadowDepth="0" Opacity="0.35" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Merged Pricing Container -->
                    <Border Style="{StaticResource MergedPricingContainerStyle}">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="12" ShadowDepth="0" Opacity="0.12" />
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Cost Section (هزینه تاکنون) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Reusable Current Cost Icon with stroke style, 1.5 thickness, and transparent fill -->
                                <Path Data="{StaticResource CurrentCostIconGeometry}"
                                      Stroke="{DynamicResource PrimaryBrush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0">
                                    <Path.Effect>
                                        <DropShadowEffect Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                    </Path.Effect>
                                </Path>

                                <!-- Labels in RTL for correct Persian rendering -->
                                <StackPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
                                    <!-- Label: Peyda-Medium, Muted -->
                                    <TextBlock Text="هزینه تاکنون"
                                               FontFamily="{StaticResource PeydaMedium}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryWhiteBrush}" />
                                    <!-- Value: Peyda-Black, White -->
                                    <TextBlock Text="{Binding CurrentCost}"
                                               FontFamily="{StaticResource PeydaBlack}"
                                               FontSize="15"
                                               Foreground="{DynamicResource WhiteBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Vertical Divider -->
                            <Rectangle Width="1" Height="30" Fill="{DynamicResource Theme.Brushes.White.Opacity20}" Margin="24,0" VerticalAlignment="Center" />

                            <!-- Hourly Rate Section (نرخ ساعتی) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Reusable Hourly Rate Icon with stroke style, 1.5 thickness, and transparent fill -->
                                <Path Data="{StaticResource HourlyRateIconGeometry}"
                                      Stroke="{DynamicResource PrimaryBrush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0">
                                    <Path.Effect>
                                        <DropShadowEffect Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                    </Path.Effect>
                                </Path>

                                <!-- Labels in RTL for correct Persian rendering -->
                                <StackPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
                                    <!-- Label: Peyda-Medium, Muted -->
                                    <TextBlock Text="نرخ ساعتی"
                                               FontFamily="{StaticResource PeydaMedium}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryWhiteBrush}" />
                                    <!-- Value: Peyda-Black, White -->
                                    <TextBlock Text="{Binding HourlyRate}"
                                               FontFamily="{StaticResource PeydaBlack}"
                                               FontSize="15"
                                               Foreground="{DynamicResource WhiteBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
