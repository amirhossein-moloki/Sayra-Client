<UserControl x:Class="Sayra.UI.Views.Components.SessionHero"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:vm="clr-namespace:Sayra.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="240" d:DesignWidth="1860">

    <UserControl.DataContext>
        <vm:SessionHeroViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Soft breathing and glow animation for the background SAYRA logo -->
        <Style x:Key="HeroLogoStyle" TargetType="svgc:SvgViewbox">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect x:Name="HeroLogoGlow" Color="#F5FF00" BlurRadius="25" ShadowDepth="0" Opacity="0.1" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                             From="0.1" To="0.35" Duration="0:0:4" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                             From="15" To="35" Duration="0:0:4" />
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.05" To="0.12" Duration="0:0:4" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Premium style for the single merged pricing container -->
        <Style x:Key="MergedPricingContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="#E615161E" />
            <Setter Property="BorderBrush" Value="#40F5FF00" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E61C1E26" />
                    <Setter Property="BorderBrush" Value="#80F5FF00" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Main Banner Container with premium glassmorphic style -->
    <!-- Background: subtle linear gradient starting dark transparent to slightly lighter dark transparent -->
    <!-- Border: rgba(255,255,255, 0.1) for thin transparent bottom border -->
    <!-- CornerRadius: 0 (clean rectangle) -->
    <Border CornerRadius="0"
            BorderBrush="#1AFFFFFF"
            BorderThickness="0,0,0,1"
            ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#D908090D" Offset="0" />
                <GradientStop Color="#D912131A" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <!-- 1. BACKGROUND LAYER: Large Faded SAYRA Logo -->
            <!-- Positioned at the very right of the entire control, not constrained by padding -->
            <svgc:SvgViewbox Source="/Assets/sayra.svg"
                             Width="380" Height="380"
                             Style="{StaticResource HeroLogoStyle}"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,40,0"
                             IsHitTestVisible="False" />

            <!-- 2. FOREGROUND CONTENT LAYER -->
            <!-- Using internal left and right padding: 60px (within the 50-70px target) for breathing space -->
            <Grid Margin="60,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Align Left Side content vertically -->
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <!-- Session Timer -->
                    <TextBlock Text="{Binding SessionTime}"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="64"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,14">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFFFFF" BlurRadius="15" ShadowDepth="0" Opacity="0.35" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Merged Pricing Container -->
                    <Border Style="{StaticResource MergedPricingContainerStyle}">
                        <Border.Effect>
                            <DropShadowEffect Color="#F5FF00" BlurRadius="12" ShadowDepth="0" Opacity="0.12" />
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Cost Section (هزینه تاکنون) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Coin/Cash icon with neon glow -->
                                <Path Data="M21,18V19A2,2 0 0,1 19,21H5C3.89,21 3,20.1 3,19V5C3,3.89 3.89,3 5,3H19A2,2 0 0,1 21,5V6H12C10.89,6 10,6.89 10,8V16C10,17.11 10.89,18 12,18H21M12,16H22V8H12V16M16,13.5A1.5,1.5 0 0,1 14.5,12A1.5,1.5 0 0,1 16,10.5A1.5,1.5 0 0,1 17.5,12A1.5,1.5 0 0,1 16,13.5Z"
                                      Fill="#F5FF00"
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#F5FF00" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                    </Path.Effect>
                                </Path>

                                <!-- Labels in RTL for correct Persian rendering -->
                                <StackPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
                                    <TextBlock Text="هزینه تاکنون"
                                               FontFamily="{StaticResource PeydaMedium}"
                                               FontSize="11"
                                               Foreground="#A1A1AA" />
                                    <TextBlock Text="{Binding CurrentCost}"
                                               FontFamily="{StaticResource PeydaBold}"
                                               FontSize="15"
                                               Foreground="White"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Vertical Divider -->
                            <Rectangle Width="1" Height="30" Fill="#33FFFFFF" Margin="24,0" VerticalAlignment="Center" />

                            <!-- Hourly Rate Section (نرخ ساعتی) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Clock icon with neon glow -->
                                <Path Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"
                                      Fill="#F5FF00"
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#F5FF00" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                    </Path.Effect>
                                </Path>

                                <!-- Labels in RTL for correct Persian rendering -->
                                <StackPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
                                    <TextBlock Text="نرخ ساعتی"
                                               FontFamily="{StaticResource PeydaMedium}"
                                               FontSize="11"
                                               Foreground="#A1A1AA" />
                                    <TextBlock Text="{Binding HourlyRate}"
                                               FontFamily="{StaticResource PeydaBold}"
                                               FontSize="15"
                                               Foreground="White"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>