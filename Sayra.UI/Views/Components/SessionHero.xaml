<UserControl x:Class="Sayra.UI.Views.Components.SessionHero"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:vm="clr-namespace:Sayra.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="240" d:DesignWidth="1860">

    <UserControl.DataContext>
        <vm:SessionHeroViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Soft breathing and glow animation for the background SAYRA logo -->
        <Style x:Key="HeroLogoStyle" TargetType="svgc:SvgViewbox">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect x:Name="HeroLogoGlow" Color="#ffff3d" BlurRadius="25" ShadowDepth="0" Opacity="0.1" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                             From="0.1" To="0.35" Duration="0:0:4" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                             From="15" To="35" Duration="0:0:4" />
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.05" To="0.12" Duration="0:0:4" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Premium style for the single merged pricing container -->
        <Style x:Key="MergedPricingContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryYellowBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Main Banner Container with premium glassmorphic style -->
    <Border CornerRadius="0"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            ClipToBounds="True">
        <Border.Background>
            <ImageBrush ImageSource="/Assets/SessionHeroSectionBG.jpg" Stretch="UniformToFill" />
        </Border.Background>

        <Grid>
            <!-- Dark linear gradient overlay to preserve text readability and maintain aesthetic compatibility -->
            <Border Grid.Row="0" Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E6101014" Offset="0" />
                        <GradientStop Color="#B3101014" Offset="0.5" />
                        <GradientStop Color="#E6101014" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- 1. BACKGROUND LAYER: Large Faded SAYRA Logo -->
            <svgc:SvgViewbox Source="/Assets/sayra.svg"
                             Width="456" Height="456"
                             Style="{StaticResource HeroLogoStyle}"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,110,0"
                             IsHitTestVisible="False" />

            <!-- 2. FOREGROUND CONTENT LAYER -->
            <Grid Margin="60,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Align Left Side content vertically -->
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <!-- Session Timer -->
                    <TextBlock Text="{Binding SessionTime}"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="64"
                               Foreground="{DynamicResource WhiteBrush}"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,14">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFFFFF" BlurRadius="15" ShadowDepth="0" Opacity="0.35" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Merged Pricing Container -->
                    <Border Style="{StaticResource MergedPricingContainerStyle}">
                        <Border.Effect>
                            <DropShadowEffect Color="#ffff3d" BlurRadius="12" ShadowDepth="0" Opacity="0.12" />
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Cost Section (هزینه تاکنون) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Specified Current Cost Icon with stroke style, 1.5 thickness, and transparent fill -->
                                <Path Data="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9m18 0V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v3"
                                      Stroke="{DynamicResource PrimaryYellowBrush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#ffff3d" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                    </Path.Effect>
                                </Path>

                                <!-- Labels in RTL for correct Persian rendering -->
                                <StackPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
                                    <TextBlock Text="هزینه تاکنون"
                                               FontFamily="{StaticResource PeydaMedium}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryWhiteBrush}" />
                                    <TextBlock Text="{Binding CurrentCost}"
                                               FontFamily="{StaticResource PeydaBold}"
                                               FontSize="15"
                                               Foreground="{DynamicResource WhiteBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Vertical Divider -->
                            <Rectangle Width="1" Height="30" Fill="#33FFFFFF" Margin="24,0" VerticalAlignment="Center" />

                            <!-- Hourly Rate Section (نرخ ساعتی) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Specified Hourly Rate Icon with stroke style, 1.5 thickness, and transparent fill -->
                                <Path Data="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"
                                      Stroke="{DynamicResource PrimaryYellowBrush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#ffff3d" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                    </Path.Effect>
                                </Path>

                                <!-- Labels in RTL for correct Persian rendering -->
                                <StackPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
                                    <TextBlock Text="نرخ ساعتی"
                                               FontFamily="{StaticResource PeydaMedium}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryWhiteBrush}" />
                                    <TextBlock Text="{Binding HourlyRate}"
                                               FontFamily="{StaticResource PeydaBold}"
                                               FontSize="15"
                                               Foreground="{DynamicResource WhiteBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
