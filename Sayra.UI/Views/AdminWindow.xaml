        <!-- Base Toolbar Button Style -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="{StaticResource SecondarySurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon Area (if Tag has geometry) -->
                                <Path x:Name="btnIcon"
                                      Grid.Column="0"
                                      Data="{TemplateBinding Tag}"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="20" Height="20"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0">
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="iconRotate" Angle="0" CenterX="10" CenterY="10" />
                                    </Path.RenderTransform>
                                </Path>

                                <!-- Text content -->
                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Hover state -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource DividerBrush}" />
                            </Trigger>
                            <!-- Pressed state -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SelectedBrush}" />
                            </Trigger>
                            <!-- Focused state -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryAccentBrush}" />
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#F7E733" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <!-- Disabled state -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#0AFFFFFF" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#05FFFFFF" />
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="btnIcon" Property="Stroke" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Accent Button Style -->
        <Style x:Key="PrimaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccentBrush}" />
            <Setter Property="Foreground" Value="#0E1015" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon Area -->
                                <Path x:Name="btnIcon"
                                      Grid.Column="0"
                                      Data="{TemplateBinding Tag}"
                                      Stroke="#0E1015"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="20" Height="20"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />

                                <!-- Text content -->
                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding Content}"
                                           Foreground="#0E1015"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#F7E733" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFE01B" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFE01B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#22F7E733" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#11F7E733" />
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="btnIcon" Property="Stroke" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Red Button Style -->
        <Style x:Key="DangerToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#1AE65C5C" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon Area -->
                                <Path x:Name="btnIcon"
                                      Grid.Column="0"
                                      Data="{TemplateBinding Tag}"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="20" Height="20"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />

                                <!-- Text content -->
                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33E65C5C" />
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#E65C5C" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4CE65C5C" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#0AE65C5C" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#11E65C5C" />
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="btnIcon" Property="Stroke" Value="{StaticResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Statically Demoed States Button Styles -->
        <!-- Hover State Static Demo Style -->
        <Style x:Key="HoverStaticDemoButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="{StaticResource HoverBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        </Style>

        <!-- Pressed State Static Demo Style -->
        <Style x:Key="PressedStaticDemoButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SelectedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        </Style>

        <!-- Focused State Static Demo Style -->
        <Style x:Key="FocusedStaticDemoButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1.5"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect Color="#F7E733" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                            </Border.Effect>
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon Area -->
                                <Path x:Name="btnIcon"
                                      Grid.Column="0"
                                      Data="{TemplateBinding Tag}"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="20" Height="20"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />

                                <!-- Text content -->
                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Loading State Spinner Rotating Style -->
        <Style x:Key="LoadingToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Loading rotating spinner (standard circular layout) -->
                                <Path x:Name="spinner"
                                      Grid.Column="0"
                                      Data="M12 4V2m0 20v-2m8-8h2M2 12h2m13.657-5.657l1.414-1.414M5.657 16.343l1.414-1.414m11.314 11.314l-1.414-1.414M5.657 5.657L7.07 7.07"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="20" Height="20"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="noFreezeRotate" Angle="0" />
                                    </Path.RenderTransform>
                                </Path>

                                <!-- Text content -->
                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded" SourceName="spinner">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="noFreezeRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1.2"
                                                         RepeatBehavior="Forever" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource DividerBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Large Search Box Style -->
        <Style x:Key="LargeSearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SecondarySurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryAccentBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="SearchBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="14,0"
                                Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Search Icon -->
                                <Path x:Name="SearchIcon"
                                      Grid.Column="0"
                                      Data="{StaticResource SearchIconGeometry}"
                                      Stroke="{StaticResource MutedTextBrush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="18" Height="18"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0" />

                                <!-- Text/Placeholder -->
                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                                    <TextBlock x:Name="Placeholder"
                                               Text="Search by game name, executable, publisher, launcher or category..."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               FontSize="14"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed" />
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="{StaticResource DividerBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="{StaticResource PrimaryAccentBrush}" />
                                <Setter TargetName="SearchBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#F7E733" BlurRadius="8" ShadowDepth="0" Opacity="0.3" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <!-- Header Bar -->
            <RowDefinition Height="80" />
            <!-- Workspace Content Area -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Header Bar (Flat surface, subtle border divider on bottom) -->
        <Border Grid.Row="0" Background="{StaticResource PrimarySurfaceBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1" Panel.ZIndex="10">
            <Grid Margin="32,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Branding & Module Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <svgc:SvgViewbox Source="/Assets/sayra.svg" Width="100" Height="25" VerticalAlignment="Center"/>
                    <Border Width="1" Height="20" Background="{StaticResource DividerBrush}" Margin="16,0"/>
                    <TextBlock Text="Local Administration" FontFamily="Segoe UI Variable, Segoe UI" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                    <Border Width="1" Height="20" Background="{StaticResource DividerBrush}" Margin="16,0"/>
                    <TextBlock Text="Game &amp; Application Manager" FontFamily="Segoe UI Variable, Segoe UI" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource PrimaryAccentBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Action Button (Return to Login) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Exit Panel" Click="LogoutButton_Click" Height="36" Padding="20,0" Cursor="Hand" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" FontFamily="Segoe UI Variable, Segoe UI" FontWeight="Medium">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{StaticResource PrimarySurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource HoverBrush}"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Workspace Container -->
        <Grid Grid.Row="1" Margin="32">
            <Grid.RowDefinitions>
                <!-- Section 1: Search Area -->
                <RowDefinition Height="Auto" />
                <!-- Section 2: Toolbar -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- SECTION 1: SEARCH AREA (Height: 64px, Padding: 20px, Rounded Corners: 12px) -->
            <Border Grid.Row="0" Height="64" Background="{StaticResource PrimarySurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <!-- Large Search Box occupies approximately 70% width -->
                        <ColumnDefinition Width="70*" />
                        <!-- Right Side Buttons aligned right -->
                        <ColumnDefinition Width="30*" />
                    </Grid.ColumnDefinitions>

                    <!-- Large Search Box with Placeholder and Search left icon -->
                    <TextBox Grid.Column="0"
                             Style="{StaticResource LargeSearchBoxStyle}"
                             VerticalAlignment="Center" />

                    <!-- Actions Aligned Right -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Clear Search Button -->
                        <Button Content="Clear"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Tag="{StaticResource ClearSearchIconGeometry}"
                                Margin="0,0,12,0" />

                        <!-- Refresh Button -->
                        <Button Content="Refresh"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Tag="{StaticResource RefreshIconGeometry}"
                                Margin="0,0,12,0" />

                        <!-- Quick Filter Button -->
                        <Button Content="Quick Filter"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Tag="{StaticResource QuickFilterIconGeometry}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- SECTION 2: TOOLBAR (Height: 88px, Margin Top: 24px, Rounded: 12px, Padding: 20px) -->
            <Border Grid.Row="1" Height="88" Margin="0,24,0,0" Background="{StaticResource PrimarySurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" VerticalAlignment="Top">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" SnapsToDevicePixels="True" VerticalAlignment="Center" Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- GROUP 1: DISCOVERY -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Group heading left of buttons or just structured layout -->
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0" Width="80">
                                <TextBlock Text="DISCOVERY" FontFamily="Segoe UI Variable, Segoe UI" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Left" />
                                <TextBlock Text="Platform scan" FontFamily="Segoe UI Variable, Segoe UI" FontSize="9" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" HorizontalAlignment="Left" />
                            </StackPanel>

                            <!-- Scan All (Primary Accent Yellow) -->
                            <Button Content="Scan All"
                                    Style="{StaticResource PrimaryToolbarButtonStyle}"
                                    Tag="{StaticResource ScanAllIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Steam (Brand Color) -->
                            <Button Content="Steam"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource SteamIconGeometry}"
                                    Foreground="#66C0F4"
                                    Margin="0,0,12,0" />

                            <!-- Epic Games (Brand Color) -->
                            <Button Content="Epic Games"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource EpicGamesIconGeometry}"
                                    Foreground="#FFFFFF"
                                    Margin="0,0,12,0" />

                            <!-- Riot Games (Brand Color) -->
                            <Button Content="Riot Games"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource RiotGamesIconGeometry}"
                                    Foreground="#EB0028"
                                    Margin="0,0,12,0" />

                            <!-- Battle.net (Brand Color) -->
                            <Button Content="Battle.net"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource BattleNetIconGeometry}"
                                    Foreground="#00AEFF"
                                    Margin="0,0,12,0" />

                            <!-- Ubisoft Connect (Brand Color) -->
                            <Button Content="Ubisoft Connect"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource UbisoftIconGeometry}"
                                    Foreground="#00C2FF"
                                    Margin="0,0,12,0" />

                            <!-- Xbox (Brand Color) -->
                            <Button Content="Xbox"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource XboxIconGeometry}"
                                    Foreground="#107C10"
                                    Margin="0,0,12,0" />

                            <!-- EA App (Brand Color) -->
                            <Button Content="EA App"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource EaAppIconGeometry}"
                                    Foreground="#F51E38"
                                    Margin="0,0,12,0" />

                            <!-- Custom Folder (Brand Color) -->
                            <Button Content="Custom Folder"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource CustomFolderIconGeometry}"
                                    Foreground="{StaticResource PrimaryAccentBrush}" />
                        </StackPanel>

                        <!-- Group Separator 1 -->
                        <Border Width="1" Height="40" Background="{StaticResource DividerBrush}" Margin="20,0" />

                        <!-- GROUP 2: MANAGEMENT -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0" Width="85">
                                <TextBlock Text="MANAGEMENT" FontFamily="Segoe UI Variable, Segoe UI" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Left" />
                                <TextBlock Text="Local registry" FontFamily="Segoe UI Variable, Segoe UI" FontSize="9" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" HorizontalAlignment="Left" />
                            </StackPanel>

                            <!-- Add Game (Primary accent style -> Normal State Demo) -->
                            <Button Content="Add Game"
                                    Style="{StaticResource PrimaryToolbarButtonStyle}"
                                    Tag="{StaticResource AddGameIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Add Application (Focused State Demo) -->
                            <Button Content="Add Application"
                                    Style="{StaticResource FocusedStaticDemoButtonStyle}"
                                    Tag="{StaticResource AddAppIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Duplicate (Pressed State Demo) -->
                            <Button Content="Duplicate"
                                    Style="{StaticResource PressedStaticDemoButtonStyle}"
                                    Tag="{StaticResource DuplicateIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Edit (Hover State Demo) -->
                            <Button Content="Edit"
                                    Style="{StaticResource HoverStaticDemoButtonStyle}"
                                    Tag="{StaticResource EditIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Remove (Danger style -> Red State Demo) -->
                            <Button Content="Remove"
                                    Style="{StaticResource DangerToolbarButtonStyle}"
                                    Tag="{StaticResource RemoveIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Enable (Normal Style -> Normal State Demo) -->
                            <Button Content="Enable"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource EnableIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Disable (Disabled State Demo) -->
                            <Button Content="Disable"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource DisableIconGeometry}"
                                    IsEnabled="False" />
                        </StackPanel>

                        <!-- Group Separator 2 -->
                        <Border Width="1" Height="40" Background="{StaticResource DividerBrush}" Margin="20,0" />

                        <!-- GROUP 3: IMPORT / EXPORT -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0" Width="95">
                                <TextBlock Text="IMPORT/EXPORT" FontFamily="Segoe UI Variable, Segoe UI" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Left" />
                                <TextBlock Text="JSON manifests" FontFamily="Segoe UI Variable, Segoe UI" FontSize="9" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" HorizontalAlignment="Left" />
                            </StackPanel>

                            <!-- Import -->
                            <Button Content="Import"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource ImportIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Export -->
                            <Button Content="Export"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource ExportIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Backup -->
                            <Button Content="Backup"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource BackupIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Restore (Disabled State Demo) -->
                            <Button Content="Restore"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource RestoreIconGeometry}"
                                    IsEnabled="False"
                                    Margin="0,0,12,0" />

                            <!-- Import Metadata -->
                            <Button Content="Import Metadata"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource ImportIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Export Configuration -->
                            <Button Content="Export Configuration"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource ExportIconGeometry}" />
                        </StackPanel>

                        <!-- Group Separator 3 -->
                        <Border Width="1" Height="40" Background="{StaticResource DividerBrush}" Margin="20,0" />

                        <!-- GROUP 4: SYNCHRONIZATION -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0" Width="105">
                                <TextBlock Text="SYNCHRONIZATION" FontFamily="Segoe UI Variable, Segoe UI" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Left" />
                                <TextBlock Text="Server alignment" FontFamily="Segoe UI Variable, Segoe UI" FontSize="9" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" HorizontalAlignment="Left" />
                            </StackPanel>

                            <!-- Sync From Server -->
                            <Button Content="Sync From Server"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource ImportIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Sync To Server (Active Loading State Demo) -->
                            <Button Content="Sync To Server"
                                    Style="{StaticResource LoadingToolbarButtonStyle}"
                                    Margin="0,0,12,0" />

                            <!-- Compare -->
                            <Button Content="Compare"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource CompareIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Validate -->
                            <Button Content="Validate"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource ValidateIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Rescan -->
                            <Button Content="Rescan"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource RescanIconGeometry}"
                                    Margin="0,0,12,0" />

                            <!-- Repair Metadata -->
                            <Button Content="Repair Metadata"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Tag="{StaticResource RepairIconGeometry}" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Floating Notification Overlay for Services -->
        <Grid Grid.RowSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40" Panel.ZIndex="1000" IsHitTestVisible="True"
              DataContext="{Binding Source={x:Static suis:NotificationService.Instance}}"
              Visibility="{Binding IsNotificationVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <c:NotificationCard DataContext="{Binding CurrentNotification}" />
        </Grid>
    </Grid>
</Window>
