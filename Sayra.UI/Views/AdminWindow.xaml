        <Style x:Key="PlaceholderBorder" TargetType="Border">
            <Setter Property="Background" Value="#1C1F26"/>
            <Setter Property="BorderBrush" Value="#4DFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style x:Key="PlaceholderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- Modal Storyboards -->
        <Storyboard x:Key="OpenModalStoryboard">
            <DoubleAnimation Storyboard.TargetName="ModalOverlay" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ModalScaleTransform" Storyboard.TargetProperty="ScaleX" From="0.95" To="1.0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ModalScaleTransform" Storyboard.TargetProperty="ScaleY" From="0.95" To="1.0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BgBlurEffect" Storyboard.TargetProperty="Radius" From="0" To="18" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="CloseModalStoryboard">
            <DoubleAnimation Storyboard.TargetName="ModalOverlay" Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ModalScaleTransform" Storyboard.TargetProperty="ScaleX" From="1.0" To="0.95" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ModalScaleTransform" Storyboard.TargetProperty="ScaleY" From="1.0" To="0.95" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BgBlurEffect" Storyboard.TargetProperty="Radius" From="18" To="0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Premium Dark Custom Styles for Button & TextBox -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E2026"/>
            <Setter Property="Foreground" Value="#E1E1E6"/>
            <Setter Property="BorderBrush" Value="#2A2D36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#262933"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#63E6FF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#101215"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
        </Style>

        <Style x:Key="ToolbarLauncherButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Padding" Value="3,3"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
        </Style>

        <!-- Category Sidebar ListBox Styles -->
        <Style x:Key="CategoryListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="CategoryListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <!-- Left border accent indicator on Selection -->
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" BorderThickness="3,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter Margin="8,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1C1F26"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4463E6FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252A34"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#63E6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Styles -->
        <Style x:Key="PremiumDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E2026"/>
            <Setter Property="Foreground" Value="#9A9A9A"/>
            <Setter Property="BorderBrush" Value="#2A2D36"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaBold}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PremiumDataGridHeaderCenteredStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource PremiumDataGridHeaderStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PremiumDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2663E6FF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PremiumDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#181A20"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252A34"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2D3440"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PremiumDataGridStyle" TargetType="DataGrid">
            <Style.Resources>
                <!-- Custom implicit ScrollViewer Style for DataGrid to ensure Scrollbar doesn't overlap Headers -->
                <Style TargetType="{x:Type ScrollViewer}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollViewer}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Column Headers Presenter strictly in Row 0, Column 0 (with ColumnSpan=1 or 2 as desired) -->
                                    <DataGridColumnHeadersPresenter x:Name="PART_ColumnHeadersPresenter"
                                                                    Grid.Column="0" Grid.Row="0"
                                                                    Visibility="{Binding HeadersVisibility, ConverterParameter={x:Static DataGridHeadersVisibility.Column}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"/>

                                    <!-- Scroll Content Presenter in Row 1, Column 0, spanning columns so it aligns properly -->
                                    <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                            Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                            CanContentScroll="{TemplateBinding CanContentScroll}" />

                                    <!-- Vertical ScrollBar strictly in Row 1 (RowSpan=1) and Column 1 so it starts below the headers and has no overlap -->
                                    <ScrollBar x:Name="PART_VerticalScrollBar"
                                               Style="{StaticResource AdminScrollBarStyle}"
                                               Grid.Column="1" Grid.Row="1" Grid.RowSpan="1"
                                               Orientation="Vertical"
                                               ViewportSize="{TemplateBinding ViewportHeight}"
                                               Maximum="{TemplateBinding ScrollableHeight}"
                                               Minimum="0"
                                               Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>

                                    <!-- Horizontal ScrollBar in Row 2, Column 0 -->
                                    <ScrollBar x:Name="PART_HorizontalScrollBar"
                                               Style="{StaticResource AdminScrollBarStyle}"
                                               Grid.Column="0" Grid.Row="2"
                                               Orientation="Horizontal"
                                               ViewportSize="{TemplateBinding ViewportWidth}"
                                               Maximum="{TemplateBinding ScrollableWidth}"
                                               Minimum="0"
                                               Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                               Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
            <Setter Property="Background" Value="#181A20"/>
            <Setter Property="RowBackground" Value="#181A20"/>
            <Setter Property="AlternatingRowBackground" Value="#1C1F26"/>
            <Setter Property="BorderBrush" Value="#2A2D36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource PremiumDataGridHeaderStyle}"/>
            <Setter Property="CellStyle" Value="{StaticResource PremiumDataGridCellStyle}"/>
            <Setter Property="RowStyle" Value="{StaticResource PremiumDataGridRowStyle}"/>
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>

        <!-- Premium Dark Custom Styles for editable fields in Admin Details Card -->
        <Style x:Key="AdminDetailTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1C1F26"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2D36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
            <Setter Property="CaretBrush" Value="#63E6FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4463E6FF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#63E6FF"/>
                                <Setter Property="Background" Value="#15171C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AdminDetailComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1C1F26"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#63E6FF"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#63E6FF"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AdminDetailComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#1C1F26"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2D36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource AdminDetailComboBoxItemStyle}"/>
        </Style>
    </Window.Resources>

    <Grid Background="#0F1014">
        <!-- ROOT GRID (Wrapped in a container with an effect) -->
        <Grid x:Name="MainContentContainer">
            <Grid.Effect>
                <BlurEffect x:Name="BgBlurEffect" Radius="0" KernelType="Box"/>
            </Grid.Effect>

            <Grid x:Name="RootGrid">
                <Grid.RowDefinitions>
                <RowDefinition Height="56" />  <!-- Row 0: Header (Fixed to 56px, 2/3 of original thickness) -->
                    <RowDefinition Height="*" />   <!-- Row 1: Workspace (Stretch) -->
                    <RowDefinition Height="50" />  <!-- Row 2: Footer (Fixed to 50px) -->
                </Grid.RowDefinitions>

            <!-- 01. HEADER -->
            <!-- Width: Stretch to full window width. Height: 56px. Background panel color #181A20 with border #2A2D36 -->
            <Border Grid.Row="0" Height="56" Background="#181A20" BorderBrush="#2A2D36" BorderThickness="0,0,0,1" Padding="24,8,24,8">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <!-- Branding & Breadcrumb Area on the left. Width: Auto -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Empty center space -->
                        <ColumnDefinition Width="*" />
                        <!-- Status Area on the right -->
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- BRANDING & BREADCRUMB AREA -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Application Logo: 140px width, matching TopBar in Home/Dashboard -->
                        <svgc:SvgViewbox Source="/Assets/sayra.svg"
                                         Width="140"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center" />

                        <!-- Spacing after logo: 16px -->
                        <Border Width="16" />

                        <!-- Title and Breadcrumb -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Game &amp; Application Manager"
                                       FontFamily="{StaticResource PeydaBold}"
                                       FontSize="16"
                                       Foreground="#63E6FF"
                                       FontWeight="Bold"
                                       LineHeight="20" />
                            <TextBlock Text="Local Administration / Game &amp; Application Manager"
                                       FontFamily="{StaticResource PeydaMedium}"
                                       FontSize="11"
                                       Foreground="#9A9A9A"
                                       FontWeight="Normal"
                                       LineHeight="14"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- STATUS AREA (Height: 40px, Width: 150px per card, spacing 12px) -->
                    <!-- Items: PC Name, Server Status, Last Scan, Games Count, Applications Count -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- PC NAME -->
                        <controls:StatusWidget Width="150" Height="40"
                                               Icon="{StaticResource PCNameIcon}"
                                               Label="PC NAME"
                                               Value="PC-05" />

                        <!-- Spacing: 12px -->
                        <Border Width="12" />

                        <!-- SERVER STATUS -->
                        <controls:StatusWidget Width="150" Height="40"
                                               Icon="{StaticResource ServerStatusIcon}"
                                               Label="SERVER STATUS"
                                               Value="Connected" />

                        <!-- Spacing: 12px -->
                        <Border Width="12" />

                        <!-- LAST SCAN -->
                        <controls:StatusWidget Width="150" Height="40"
                                               Icon="{StaticResource LastScanIcon}"
                                               Label="LAST SCAN"
                                               Value="Today 14:25" />

                        <!-- Spacing: 12px -->
                        <Border Width="12" />

                        <!-- GAMES COUNT (Bound dynamically to category 1 count) -->
                        <controls:StatusWidget Width="150" Height="40"
                                               Icon="{StaticResource GameCountIcon}"
                                               Label="GAMES COUNT"
                                               Value="{Binding Categories[1].Count, FallbackValue=86}" />

                        <!-- Spacing: 12px -->
                        <Border Width="12" />

                        <!-- APPLICATIONS COUNT (Bound dynamically to category 2 count) -->
                        <controls:StatusWidget Width="150" Height="40"
                                               Icon="{StaticResource AppCountIcon}"
                                               Label="APPLICATIONS COUNT"
                                               Value="{Binding Categories[2].Count, FallbackValue=14}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- NESTED GRID: Workspace -->
            <!-- Background is omitted ({x:Null}) to allow hit-testing to pass through to underlying elements -->
            <Grid Grid.Row="1" x:Name="WorkspaceGrid" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*" MinWidth="180" MaxWidth="250" /> <!-- Column 0: Category Sidebar -->
                    <ColumnDefinition Width="16" />  <!-- Gap -->
                    <ColumnDefinition Width="10.7*" />   <!-- Column 1: Games Panel (Stretches) -->
                    <ColumnDefinition Width="16" />  <!-- Gap -->
                    <ColumnDefinition Width="3.2*" MinWidth="260" MaxWidth="320" /> <!-- Column 2: Right Sidebar -->
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- Row 0: Search Area -->
                    <RowDefinition Height="Auto" />  <!-- Row 1: Action Area Level / Toolbar -->
                    <RowDefinition Height="*" />     <!-- Row 2: Content Level (Stretch) -->
                </Grid.RowDefinitions>

                <!-- 07. CATEGORY SIDEBAR -->
                <!-- Category Sidebar aligned with Main DataGrid in Row 2 -->
                <Grid Grid.Column="0" Grid.Row="2" Grid.RowSpan="1" Margin="24,12,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#181A20" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="10" Padding="8">
                        <ListBox x:Name="CategoriesList"
                                 ItemsSource="{Binding Categories}"
                                 SelectedItem="{Binding SelectedCategory}"
                                 Style="{StaticResource CategoryListBoxStyle}"
                                 ItemContainerStyle="{StaticResource CategoryListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="32">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Category Icon -->
                                        <Path Grid.Column="0" Data="{Binding IconGeometry}"
                                              Width="16" Height="16" Stretch="Uniform"
                                              VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <!-- Default state: outline icon -->
                                                    <Setter Property="Stroke" Value="#9A9A9A"/>
                                                    <Setter Property="StrokeThickness" Value="1.5"/>
                                                    <Setter Property="Fill" Value="Transparent"/>

                                                    <Style.Triggers>
                                                        <!-- If outline icon is hovered -->
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Stroke" Value="#FFFFFF"/>
                                                        </DataTrigger>
                                                        <!-- If outline icon is selected -->
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Stroke" Value="#63E6FF"/>
                                                        </DataTrigger>

                                                        <!-- If it's a Brand Icon (Solid fill instead of outline stroke) -->
                                                        <DataTrigger Binding="{Binding IsBrandIcon}" Value="True">
                                                            <Setter Property="Fill" Value="#9A9A9A"/>
                                                            <Setter Property="Stroke" Value="Transparent"/>
                                                            <Setter Property="StrokeThickness" Value="0"/>
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsBrandIcon}" Value="True"/>
                                                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Fill" Value="#FFFFFF"/>
                                                            <Setter Property="Stroke" Value="Transparent"/>
                                                            <Setter Property="StrokeThickness" Value="0"/>
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsBrandIcon}" Value="True"/>
                                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Fill" Value="#63E6FF"/>
                                                            <Setter Property="Stroke" Value="Transparent"/>
                                                            <Setter Property="StrokeThickness" Value="0"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <!-- Category Name -->
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   Foreground="White" FontSize="13"
                                                   FontFamily="{StaticResource PeydaMedium}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- Count Badge -->
                                        <Border Grid.Column="2" Background="#252A34" CornerRadius="10" Padding="8,2" Height="18" MinWidth="22" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Count}" Foreground="#63E6FF" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Left Nav Bottom Actions/Settings (Clean & Premium) -->
                    <Border Grid.Row="1" Background="#181A20" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="10" Margin="0,12,0,0" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding ManageCategoriesCommand}" Height="32" Padding="4">
                                <Path Data="M10.5 6a1.5 1.5 0 111.5 1.5 1.5 1.5 0 01-1.5-1.5zm0 6a1.5 1.5 0 111.5 1.5 1.5 1.5 0 01-1.5-1.5zm0 6a1.5 1.5 0 111.5 1.5 1.5 1.5 0 01-1.5-1.5z" Stroke="#9A9A9A" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform"/>
                            </Button>
                            <Button Grid.Column="1" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding SettingsCommand}" Height="32" Padding="4" Margin="4,0">
                                <Path Data="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.323.196.72.222 1.062.067l1.175-.53c.5-.226 1.1-.035 1.373.438l1.296 2.247c.273.472.115 1.077-.354 1.378l-1.076.69c-.312.2-.494.55-.494.924v.266c0 .373.182.724.494.924l1.076.69c.469.301.627.906.354 1.378l-1.296 2.247c-.273.473-.873.664-1.373.438l-1.175-.53a1.125 1.125 0 00-1.062.067c-.073.044-.146.087-.22.128-.332.183-.582.495-.645.869l-.213 1.28c-.09.543-.56.94-1.11.94h-2.593c-.55 0-1.02-.398-1.11-.94l-.213-1.28a1.125 1.125 0 00-.645-.869c-.074-.04-.147-.084-.22-.128a1.125 1.125 0 00-1.062-.067l-1.175.53c-.5.226-1.1.035-1.373-.438l-1.296-2.247c-.273-.472-.115-1.077.354-1.378l1.076-.69c.312-.2.494-.55.494-.924v-.266c0-.374-.182-.724-.494-.924l-1.076-.69c-.469-.301-.627-.906-.354-1.378l1.296-2.247c.273-.473.873-.664 1.373-.438l1.175.53c.343.155.74.129 1.062-.067.073-.044.146-.087.22-.128.332-.184.582-.496.645-.87l.213-1.281z" Stroke="#9A9A9A" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform"/>
                            </Button>
                            <Button Grid.Column="2" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding RefreshCommand}" Height="32" Padding="4">
                                <Path Data="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" Stroke="#9A9A9A" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 02. SEARCH (Full width) -->
                <!-- Shorter Search Box (Height: 38px, Margin: 12px top, 24px left/right) -->
                <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0" Margin="24,12,0,0" Height="38">
                    <Border CornerRadius="8" Background="#181A20" BorderBrush="#2A2D36" BorderThickness="1.5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Search Icon -->
                            <Path Grid.Column="0" Data="{StaticResource SearchIconGeometry}"
                                  Stroke="#9A9A9A" StrokeThickness="1.5" Width="14" Height="14"
                                  Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" />

                            <!-- Search TextBox -->
                            <TextBox Grid.Column="1" x:Name="SearchBox"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#FFFFFF" CaretBrush="#63E6FF"
                                     VerticalContentAlignment="Center" FontSize="12"
                                     FontFamily="{StaticResource PeydaMedium}" Padding="4,0,0,0"/>

                            <!-- Placeholder Text block (Visible only when text is empty) -->
                            <TextBlock Grid.Column="1" Text="Search by name, publisher, executable or category..."
                                       Foreground="#55FFFFFF" IsHitTestVisible="False"
                                       VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0"
                                       FontSize="12" FontFamily="{StaticResource PeydaMedium}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Total items badge on the right -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Border Background="#252A34" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalItemsCount, StringFormat='{}{0} items found'}" Foreground="#63E6FF" FontSize="10" FontFamily="{StaticResource PeydaBold}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 03. TOOLBAR (Full width) -->
                <!-- Thicker Toolbar (Height: 56px -> 64px, Margin: 8px top, 24px left/right, 4 separate border segments separated by 16px) -->
                <ScrollViewer Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled" BorderThickness="0" Background="Transparent" Margin="24,8,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="56">
                        <!-- GROUP: SCAN -->
                        <Border Background="#181A20" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="8" Padding="12,0" Margin="0,0,16,0" VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="SCAN" FontFamily="{StaticResource PeydaBold}" FontSize="9" Foreground="#14BE78" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Scan All">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource ScanAllIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Scan All" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Steam">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource SteamLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Steam" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Epic Games">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource EpicLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Epic" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Riot Games">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource RiotLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Riot" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Battle.net">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource BattlenetLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Battle.net" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Ubisoft">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource UbisoftLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Ubisoft" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Xbox">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource XboxLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Xbox" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Custom Launcher">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource CustomLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Custom" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- GROUP: ADD -->
                        <Border Background="#181A20" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="8" Padding="12,0" Margin="0,0,16,0" VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ADD" FontFamily="{StaticResource PeydaBold}" FontSize="9" Foreground="#ffff3d" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding ManageCategoriesCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource AddGameIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Add Game" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding ManageCategoriesCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource AddAppIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Add App" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- GROUP: DATA -->
                        <Border Background="#181A20" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="8" Padding="12,0" Margin="0,0,16,0" VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="DATA" FontFamily="{StaticResource PeydaBold}" FontSize="9" Foreground="#8A5CFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCategoriesCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource ImportIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Import" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCategoriesCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource ExportIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Export" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCategoriesCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource BackupIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Backup" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCategoriesCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource RestoreIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Restore" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- GROUP: SYNC (Adjacent to DATA) -->
                        <Border Background="#181A20" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="8" Padding="12,0" VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="SYNC" FontFamily="{StaticResource PeydaBold}" FontSize="9" Foreground="#63E6FF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource SyncFromIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Sync From Server" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource SyncToIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Sync To Server" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource CompareIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Compare" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 09. GAMES PANEL -->
                <!-- Main DataGrid Container with integrated sticky pagination footer -->
                <Border Grid.Column="2" Grid.Row="2" Background="#181A20" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="10" Margin="0,12,0,12">
                    <Border.OpacityMask>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Border Background="Black" CornerRadius="10" SnapsToDevicePixels="True"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                        Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.OpacityMask>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" /> <!-- Local sticky pagination footer inside Games Panel -->
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" x:Name="GamesDataGrid"
                                  ItemsSource="{Binding VisibleItems}"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  SelectionChanged="GamesDataGrid_SelectionChanged">
                            <DataGrid.Style>
                                <Style TargetType="DataGrid" BasedOn="{StaticResource PremiumDataGridStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedViewMode}" Value="Grid View">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedViewMode}" Value="Compact View">
                                            <Setter Property="RowHeight" Value="32"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Style>
                            <DataGrid.Columns>
                                <!-- Checkbox Column -->
                                <DataGridTemplateColumn Width="45">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Icon/Cover Column -->
                                <DataGridTemplateColumn Header="Cover" Width="55" HeaderStyle="{StaticResource PremiumDataGridHeaderCenteredStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="32" Height="32" Background="#13FFFFFF" CornerRadius="4" ClipToBounds="True" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="1" BorderBrush="#2A2D36">
                                                <Grid>
                                                    <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                                          Fill="#33FFFFFF" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Name Column -->
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>

                                <!-- Category Column -->
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>

                                <!-- Launcher Column -->
                                <DataGridTextColumn Header="Launcher" Binding="{Binding Launcher}" Width="110" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>

                                <!-- Version Column -->
                                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="90" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>

                                <!-- Enabled Checkbox Column -->
                                <DataGridTemplateColumn Header="Enabled" Width="80" HeaderStyle="{StaticResource PremiumDataGridHeaderCenteredStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Path Column -->
                                <DataGridTemplateColumn Header="Path" Width="250">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource PremiumDataGridTextBlockStyle}" Text="{Binding InstallationPath}" ToolTip="{Binding InstallationPath}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Source Column -->
                                <DataGridTextColumn Header="Source" Binding="{Binding InstallationSource}" Width="110" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>

                                <!-- Enabled/Status Column -->
                                <DataGridTemplateColumn Header="Status" Width="105" HeaderStyle="{StaticResource PremiumDataGridHeaderCenteredStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#2214BE78"/>
                                                        <Setter Property="BorderBrush" Value="#4414BE78"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                                                <Setter Property="Background" Value="#229A9A9A"/>
                                                                <Setter Property="BorderBrush" Value="#449A9A9A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Corrupted">
                                                                <Setter Property="Background" Value="#22F46B6B"/>
                                                                <Setter Property="BorderBrush" Value="#44F46B6B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                                <Setter Property="Background" Value="#22F46B6B"/>
                                                                <Setter Property="BorderBrush" Value="#44F46B6B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Updating">
                                                                <Setter Property="Background" Value="#22ffff3d"/>
                                                                <Setter Property="BorderBrush" Value="#44ffff3d"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Validation Required">
                                                                <Setter Property="Background" Value="#228A5CFF"/>
                                                                <Setter Property="BorderBrush" Value="#448A5CFF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontFamily="{StaticResource PeydaBold}" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="75">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#14BE78"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                                                    <Setter Property="Foreground" Value="#9A9A9A"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Corrupted">
                                                                    <Setter Property="Foreground" Value="#F46B6B"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                                    <Setter Property="Foreground" Value="#F46B6B"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Updating">
                                                                    <Setter Property="Foreground" Value="#ffff3d"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Validation Required">
                                                                    <Setter Property="Foreground" Value="#8A5CFF"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Last Modified Column -->
                                <DataGridTextColumn Header="Last Updated" Binding="{Binding LastUpdated}" Width="130" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Grid View Scrollable Container -->
                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="12">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedViewMode}" Value="Grid View">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>

                            <!-- ItemsControl to render GameCards in a responsive WrapPanel -->
                            <ItemsControl ItemsSource="{Binding VisibleItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:GameCard Title="{Binding Title}"
                                                            Genre="{Binding Genre}"
                                                            ImagePath="{Binding CoverImage}"
                                                            Status="{Binding Status}"
                                                            IsSelected="{Binding IsChecked, Mode=TwoWay}"
                                                            IsAvailable="{Binding IsEnabled}"
                                                            Margin="10"
                                                            PlayCommand="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Local Sticky Footer with Reusable Pagination Control -->
                        <Border Grid.Row="1" Background="#1C1F26" BorderBrush="#2A2D36" BorderThickness="0,1,0,0" Padding="16,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- View Mode & Demo State on the left -->
                                    <ColumnDefinition Width="*"/>    <!-- Reusable Pagination component -->
                                </Grid.ColumnDefinitions>

                                <!-- Demo / View mode selectors -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- View Mode Selector -->
                                    <TextBlock Text="View Mode:" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox ItemsSource="{Binding ViewModes}" SelectedItem="{Binding SelectedViewMode}" Width="100" Height="26" Background="#14161C" Foreground="White" BorderBrush="#2A2D36" FontFamily="{StaticResource PeydaMedium}" FontSize="11" VerticalContentAlignment="Center"/>

                                    <Border Width="16"/>

                                    <!-- Demo State Selector -->
                                    <TextBlock Text="Demo State:" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox ItemsSource="{Binding DemoStates}" SelectedItem="{Binding SelectedDemoState}" Width="100" Height="26" Background="#14161C" Foreground="White" BorderBrush="#2A2D36" FontFamily="{StaticResource PeydaMedium}" FontSize="11" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Reusable Pagination Control -->
                                <controls:Pagination Grid.Column="1" Margin="24,0,0,0"
                                                     CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                                                     TotalItems="{Binding TotalItemsCount}"
                                                     PageSize="{Binding SelectedPageSize, Mode=TwoWay}"
                                                     RefreshCommand="{Binding RefreshCommand}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Old game details pane removed as requested (we now use a centered modal) -->

                <!-- 11. RIGHT SIDEBAR -->
                <!-- Right Sidebar aligned with Main DataGrid in Row 2 -->
                <Border Grid.Column="4" Grid.Row="0" Grid.RowSpan="3" Margin="0,12,24,12" Background="#14161C" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="10" Padding="12,12,0,12">
                    <ScrollViewer Style="{StaticResource ThinScrollViewerStyle}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid x:Name="RightSidebarGrid" Margin="0,0,12,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- 11.1 Add New Game -->
                                <RowDefinition Height="Auto" /> <!-- 11.2 Scanner Result -->
                                <RowDefinition Height="Auto" /> <!-- 11.3 Validation Result -->
                                <RowDefinition Height="Auto" /> <!-- 11.4 Import Games -->
                                <RowDefinition Height="Auto" /> <!-- 11.5 Sync Conflict Resolver -->
                            </Grid.RowDefinitions>

                            <!-- 11.1 ADD NEW GAME -->
                            <Expander Grid.Row="0" Style="{StaticResource SidebarExpanderStyle}" IsExpanded="True">
                                <Expander.Header>
                                    <TextBlock Text="Add New Game" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White"/>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Name * Field -->
                                    <TextBlock Text="Name *" Foreground="#9A9A9A" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                    <Border Background="#1C1F26" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="6" Height="30" Padding="6,2" Margin="0,0,0,10">
                                        <TextBox Background="Transparent" BorderThickness="0" Foreground="White" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalContentAlignment="Center" CaretBrush="#63E6FF"/>
                                    </Border>

                                    <!-- Executable Path * Field -->
                                    <TextBlock Text="Executable Path *" Foreground="#9A9A9A" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#1C1F26" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="6,0,0,6" Height="30" Padding="6,2">
                                            <TextBox Background="Transparent" BorderThickness="0" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaMedium}" VerticalContentAlignment="Center" Text="D:\Games\New Game\game.exe" CaretBrush="#63E6FF"/>
                                        </Border>
                                        <Button Grid.Column="1" Content="Browse" Height="30" Padding="10,0" Style="{StaticResource ToolbarButtonStyle}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="0,6,6,0"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>

                                    <!-- Metadata Section (Launcher & Category Dropdowns) -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Launcher" Foreground="#9A9A9A" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                            <ComboBox Height="30" Background="#1C1F26" Foreground="White" BorderBrush="#2A2D36" FontFamily="{StaticResource PeydaMedium}" FontSize="11" VerticalContentAlignment="Center" SelectedIndex="4">
                                                <ComboBoxItem Content="Steam"/>
                                                <ComboBoxItem Content="Epic Games"/>
                                                <ComboBoxItem Content="GOG"/>
                                                <ComboBoxItem Content="Battle.net"/>
                                                <ComboBoxItem Content="Manual"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Category" Foreground="#9A9A9A" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                            <ComboBox Height="30" Background="#1C1F26" Foreground="White" BorderBrush="#2A2D36" FontFamily="{StaticResource PeydaMedium}" FontSize="11" VerticalContentAlignment="Center" SelectedIndex="0">
                                                <ComboBoxItem Content="Action"/>
                                                <ComboBoxItem Content="Adventure"/>
                                                <ComboBoxItem Content="RPG"/>
                                                <ComboBoxItem Content="Simulation"/>
                                                <ComboBoxItem Content="Strategy"/>
                                                <ComboBoxItem Content="Sport"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Description Section -->
                                    <TextBlock Text="Description" Foreground="#9A9A9A" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                    <Border Background="#1C1F26" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="6" Height="60" Padding="6,4" Margin="0,0,0,10">
                                        <TextBox Background="Transparent" BorderThickness="0" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaMedium}" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" CaretBrush="#63E6FF"/>
                                    </Border>

                                    <!-- Favorite Checkbox -->
                                    <CheckBox Content="Add to Favorites" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="11" Margin="0,0,0,12"/>

                                    <!-- Footer Buttons -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Cancel" Height="30" Style="{StaticResource ToolbarButtonStyle}"/>
                                        <Button Grid.Column="2" Content="Add Game" Height="30">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                    <Setter Property="Background" Value="#2200FFFF"/>
                                                    <Setter Property="BorderBrush" Value="#4400FFFF"/>
                                                    <Setter Property="Foreground" Value="#00FFFF"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3300FFFF"/>
                                                            <Setter Property="BorderBrush" Value="#00FFFF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <!-- 11.2 SCANNER RESULT -->
                            <Expander Grid.Row="1" Style="{StaticResource SidebarExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Scanner Results" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White"/>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Main Body (Two Columns) -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="1.3*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Left Column: Circular Progress Chart -->
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Grid Width="64" Height="64">
                                                <!-- Progress Background Ring -->
                                                <Ellipse Stroke="#2A2D36" StrokeThickness="4"/>
                                                <!-- Progress Active Segment -->
                                                <Ellipse Stroke="#00FFFF" StrokeThickness="4" StrokeDashArray="3.14 0.8" RenderTransformOrigin="0.5,0.5">
                                                    <Ellipse.RenderTransform>
                                                        <RotateTransform Angle="-90"/>
                                                    </Ellipse.RenderTransform>
                                                </Ellipse>
                                                <!-- Text inside -->
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="87%" Foreground="#00FFFF" FontSize="12" FontFamily="{StaticResource PeydaBold}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Scanning" Foreground="#9A9A9A" FontSize="8" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Scanning path info -->
                                            <TextBlock Text="D:\Games\...\GAME.exe" Foreground="#55FFFFFF" FontSize="9" FontFamily="{StaticResource PeydaMedium}" Margin="0,8,0,0" HorizontalAlignment="Center" TextAlignment="Center" TextTrimming="CharacterEllipsis" Width="95" ToolTip="D:\Games\Steam\CS2\game.exe"/>
                                        </StackPanel>

                                        <!-- Right Column: Stats List -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <!-- Found Games -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Found Games" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="23" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <!-- Found Applications -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Found Applications" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="7" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <!-- Updated -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Updated" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="12" Foreground="#63E6FF" FontSize="11" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <!-- New -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="New" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="18" Foreground="#14BE78" FontSize="11" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <!-- Errors -->
                                            <Grid>
                                                <TextBlock Text="Errors" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="2" Foreground="#F46B6B" FontSize="11" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Footer -->
                                    <TextBlock Text="Time Elapsed 00:45" Foreground="#9A9A9A" FontSize="10" FontFamily="{StaticResource PeydaMedium}" Margin="0,0,0,10" HorizontalAlignment="Left"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Stop" Height="30">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                    <Setter Property="Background" Value="#22F46B6B"/>
                                                    <Setter Property="BorderBrush" Value="#44F46B6B"/>
                                                    <Setter Property="Foreground" Value="#F46B6B"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#33F46B6B"/>
                                                            <Setter Property="BorderBrush" Value="#F46B6B"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Grid.Column="2" Content="View Results" Height="30">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                    <Setter Property="Background" Value="#2200FFFF"/>
                                                    <Setter Property="BorderBrush" Value="#4400FFFF"/>
                                                    <Setter Property="Foreground" Value="#00FFFF"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3300FFFF"/>
                                                            <Setter Property="BorderBrush" Value="#00FFFF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <!-- 11.3 VALIDATION RESULT -->
                            <Expander Grid.Row="2" Style="{StaticResource SidebarExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Validation Results" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White"/>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Main Body (Two Columns) -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="1.3*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Left Column: Validation Status Circle -->
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Grid Width="56" Height="56">
                                                <Ellipse Stroke="#14BE78" StrokeThickness="3" Fill="#1114BE78"/>
                                                <!-- Checkmark Icon -->
                                                <Path Data="M 16,28 L 22,34 L 38,18" Stroke="#14BE78" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="Validation Completed" Foreground="#14BE78" FontSize="10" FontFamily="{StaticResource PeydaBold}" Margin="0,8,0,0" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            <TextBlock Text="All checks passed successfully" Foreground="#9A9A9A" FontSize="8" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Width="95"/>
                                        </StackPanel>

                                        <!-- Right Column: Validation Statistics Grid -->
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="1"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Headers -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="عنوان" Foreground="#55FFFFFF" FontSize="9" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left" Margin="0,0,0,2"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="مقدار" Foreground="#55FFFFFF" FontSize="9" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Right" Margin="0,0,0,2"/>
                                            <Border Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="#2A2D36" BorderThickness="0,0,0,1" Margin="0,0,0,4"/>

                                            <!-- Total Files -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Files" Foreground="#9A9A9A" FontSize="10" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="1243" Foreground="White" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right" Margin="0,0,0,3"/>

                                            <!-- Valid Files -->
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Valid Files" Foreground="#9A9A9A" FontSize="10" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="1232" Foreground="#14BE78" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right" Margin="0,0,0,3"/>

                                            <!-- Invalid Files -->
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Invalid Files" Foreground="#9A9A9A" FontSize="10" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="0" Foreground="White" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right" Margin="0,0,0,3"/>

                                            <!-- Missing Files -->
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Missing Files" Foreground="#9A9A9A" FontSize="10" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="11" Foreground="#ffff3d" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right" Margin="0,0,0,3"/>

                                            <!-- Corrupted Files -->
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Corrupted Files" Foreground="#9A9A9A" FontSize="10" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="0" Foreground="#F46B6B" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Footer -->
                                    <Button Content="Close" Height="30" Style="{StaticResource ToolbarButtonStyle}"/>
                                </StackPanel>
                            </Expander>

                            <!-- 11.4 IMPORT GAMES -->
                            <Expander Grid.Row="3" Style="{StaticResource SidebarExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Import Games" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White"/>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Source Section -->
                                    <TextBlock Text="Source" Foreground="#9A9A9A" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" Height="30" Background="#1C1F26" Foreground="White" BorderBrush="#2A2D36" FontFamily="{StaticResource PeydaMedium}" FontSize="11" VerticalContentAlignment="Center" SelectedIndex="0">
                                            <ComboBoxItem Content="Select source..."/>
                                            <ComboBoxItem Content="Steam Library"/>
                                            <ComboBoxItem Content="Epic Library"/>
                                            <ComboBoxItem Content="Folder"/>
                                            <ComboBoxItem Content="Backup"/>
                                            <ComboBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6,0,0,6"/>
                                                </Style>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                        <Button Grid.Column="1" Content="Browse" Height="30" Padding="10,0" Style="{StaticResource ToolbarButtonStyle}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="0,6,6,0"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>

                                    <!-- Import Options -->
                                    <TextBlock Text="Import Options" Foreground="#9A9A9A" FontSize="11" Margin="0,0,0,6" FontFamily="{StaticResource PeydaMedium}"/>
                                    <StackPanel Margin="0,0,0,12">
                                        <CheckBox Content="Import Games" IsChecked="True" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="10" Margin="0,0,0,6"/>
                                        <CheckBox Content="Import Applications" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="10" Margin="0,0,0,6"/>
                                        <CheckBox Content="Import Settings" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="10" Margin="0,0,0,6"/>
                                        <CheckBox Content="Import Metadata (Cover, Description...)" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="10"/>
                                    </StackPanel>

                                    <!-- Footer -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Cancel" Height="30" Style="{StaticResource ToolbarButtonStyle}"/>
                                        <Button Grid.Column="2" Content="Import" Height="30">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                    <Setter Property="Background" Value="#2200FFFF"/>
                                                    <Setter Property="BorderBrush" Value="#4400FFFF"/>
                                                    <Setter Property="Foreground" Value="#00FFFF"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3300FFFF"/>
                                                            <Setter Property="BorderBrush" Value="#00FFFF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <!-- 11.5 SYNC CONFLICT RESOLVER -->
                            <Expander Grid.Row="4" Style="{StaticResource SidebarExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Sync Conflict Resolver" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White"/>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Conflict Summary -->
                                    <TextBlock Text="Conflicts Found: 3" Foreground="#ffff3d" FontSize="11" FontFamily="{StaticResource PeydaBold}" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <TextBlock Text="Choose which version to keep for each item" Foreground="#9A9A9A" FontSize="10" FontFamily="{StaticResource PeydaMedium}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                                    <!-- Conflict Table list -->
                                    <StackPanel Margin="0,0,0,12">
                                        <!-- Conflict Row 1: Valorant -->
                                        <Border BorderBrush="#2A2D36" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0">
                                                    <TextBlock Text="Valorant" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                                    <TextBlock Text="Local is newer" Foreground="#9A9A9A" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </StackPanel>
                                                <!-- Options buttons -->
                                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <RadioButton Grid.Column="0" GroupName="ValConflict" Content="Local" IsChecked="True" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="2" GroupName="ValConflict" Content="Server" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="4" GroupName="ValConflict" Content="Both" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <!-- Conflict Row 2: GTA V -->
                                        <Border BorderBrush="#2A2D36" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0">
                                                    <TextBlock Text="GTA V" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                                    <TextBlock Text="Server is newer" Foreground="#9A9A9A" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </StackPanel>
                                                <!-- Options buttons -->
                                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <RadioButton Grid.Column="0" GroupName="GtaConflict" Content="Local" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="2" GroupName="GtaConflict" Content="Server" IsChecked="True" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="4" GroupName="GtaConflict" Content="Both" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <!-- Conflict Row 3: Red Dead Redemption 2 -->
                                        <Border Padding="0,0,0,4">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0">
                                                    <TextBlock Text="Red Dead Redemption 2" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                                    <TextBlock Text="Different" Foreground="#9A9A9A" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </StackPanel>
                                                <!-- Options buttons -->
                                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <RadioButton Grid.Column="0" GroupName="RdrConflict" Content="Local" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="2" GroupName="RdrConflict" Content="Server" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="4" GroupName="RdrConflict" Content="Both" IsChecked="True" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <!-- Global Option -->
                                    <CheckBox Content="Apply to all conflicts" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="10" Margin="0,0,0,12"/>

                                    <!-- Footer Buttons -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Skip All" Height="30" Style="{StaticResource ToolbarButtonStyle}"/>
                                        <Button Grid.Column="2" Content="Resolve" Height="30">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                    <Setter Property="Background" Value="#2200FFFF"/>
                                                    <Setter Property="BorderBrush" Value="#4400FFFF"/>
                                                    <Setter Property="Foreground" Value="#00FFFF"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3300FFFF"/>
                                                            <Setter Property="BorderBrush" Value="#00FFFF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 12. FOOTER -->
            <Border Grid.Row="2" Background="#181A20" BorderBrush="#2A2D36" BorderThickness="0,1,0,0" Padding="24,10">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <!-- Full-width: Status Stat Cards -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Status Stat Cards -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Stat Card: Games -->
                        <Border Background="#1C1F26" CornerRadius="6" Padding="12,6" Margin="0,0,8,0" BorderBrush="#2A2D36" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="GAMES: " Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                <TextBlock Text="{Binding Categories[1].Count}" Foreground="#63E6FF" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat Card: Applications -->
                        <Border Background="#1C1F26" CornerRadius="6" Padding="12,6" Margin="0,0,8,0" BorderBrush="#2A2D36" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="APPLICATIONS: " Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                <TextBlock Text="{Binding Categories[2].Count}" Foreground="#63E6FF" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat Card: Installed -->
                        <Border Background="#1C1F26" CornerRadius="6" Padding="12,6" Margin="0,0,8,0" BorderBrush="#2A2D36" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="INSTALLED: " Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                <TextBlock Text="{Binding Categories[0].Count}" Foreground="#14BE78" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat Card: Missing -->
                        <Border Background="#1C1F26" CornerRadius="6" Padding="12,6" Margin="0,0,8,0" BorderBrush="#2A2D36" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="MISSING: " Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                <TextBlock Text="{Binding Categories[15].Count}" Foreground="#F46B6B" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat Card: Broken -->
                        <Border Background="#1C1F26" CornerRadius="6" Padding="12,6" Margin="0,0,8,0" BorderBrush="#2A2D36" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="INVALID: " Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                <TextBlock Text="{Binding Categories[15].Count}" Foreground="#F46B6B" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat Card: Need Scan -->
                        <Border Background="#1C1F26" CornerRadius="6" Padding="12,6" Margin="0,0,8,0" BorderBrush="#2A2D36" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="NEED SCAN: " Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                <TextBlock Text="{Binding Categories[16].Count}" Foreground="#ffff3d" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                            </StackPanel>
                        </Border>

                        <!-- Stat Card: Disabled -->
                        <Border Background="#1C1F26" CornerRadius="6" Padding="12,6" Margin="0,0,8,0" BorderBrush="#2A2D36" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="DISABLED: " Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                <TextBlock Text="{Binding Categories[14].Count}" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        </Grid>

        <!-- FULL-SCREEN LOADING OVERLAY -->
        <Grid Background="#88000000" Panel.ZIndex="10000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#1A1F26" BorderBrush="#63E6FF" BorderThickness="1.5" CornerRadius="12" Width="380" Height="180" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Margin="24">
                    <TextBlock Text="Scanning Local Computer..." Foreground="White" FontSize="15" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <!-- Progress Bar -->
                    <ProgressBar Value="{Binding LoadingProgress}" Height="10" Background="#14161C" Foreground="#63E6FF" BorderThickness="0" Maximum="100"/>
                    <!-- Progress Text -->
                    <TextBlock Text="{Binding LoadingProgress, StringFormat='{}{0}% Completed'}" Foreground="#63E6FF" FontSize="12" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- MODAL DIALOG OVERLAY (Semi-transparent black overlay 45% & Blur focus controller) -->
        <Grid x:Name="ModalOverlay" DataContext="{x:Null}" Background="#73000000" Panel.ZIndex="9000" Visibility="Collapsed" IsVisibleChanged="ModalOverlay_IsVisibleChanged" MouseDown="ModalOverlay_MouseDown">
            <!-- Centered Modal dialog container -->
            <Border x:Name="ModalCard"
                    Width="1100" Height="740"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="18" BorderBrush="#252528" BorderThickness="1"
                    RenderTransformOrigin="0.5,0.5"
                    MouseDown="ModalCard_MouseDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#1B1B1F" Offset="0"/>
                        <GradientStop Color="#101014" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Opacity="0.65"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <ScaleTransform x:Name="ModalScaleTransform" ScaleX="1.0" ScaleY="1.0"/>
                </Border.RenderTransform>

                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Header -->
                        <RowDefinition Height="*" />    <!-- Body/Split columns -->
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Game Cover & Metadata -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Game Cover: 96x96 glassmorphic -->
                            <Border Width="96" Height="96" Background="#13FFFFFF" BorderBrush="#252528" BorderThickness="1" CornerRadius="12" Margin="0,0,20,0" ClipToBounds="True">
                                <Grid>
                                    <!-- Fallback Path icon -->
                                    <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                          Fill="#33FFFFFF" Width="48" Height="48" Stretch="Uniform"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <!-- Cover Image -->
                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Grid>
                            </Border>

                            <!-- Game Metadata Stack -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name, FallbackValue='Game Name'}" Foreground="White" FontSize="24" FontFamily="{StaticResource PeydaBold}" FontWeight="Bold"/>

                                <WrapPanel Margin="0,6,0,0" VerticalAlignment="Center">
                                    <!-- Category Badge -->
                                    <Border Background="#252A34" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Category, FallbackValue='Action'}" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}"/>
                                    </Border>

                                    <!-- Platform Launcher -->
                                    <Border Background="#1C1F26" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Launcher, FallbackValue='Steam'}" Foreground="#63E6FF" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                    </Border>

                                    <!-- Installed Status Badge -->
                                    <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2214BE78"/>
                                                <Setter Property="BorderBrush" Value="#4414BE78"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                                        <Setter Property="Background" Value="#229A9A9A"/>
                                                        <Setter Property="BorderBrush" Value="#449A9A9A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Corrupted">
                                                        <Setter Property="Background" Value="#22F46B6B"/>
                                                        <Setter Property="BorderBrush" Value="#44F46B6B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                        <Setter Property="Background" Value="#22F46B6B"/>
                                                        <Setter Property="BorderBrush" Value="#44F46B6B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Updating">
                                                        <Setter Property="Background" Value="#22ffff3d"/>
                                                        <Setter Property="BorderBrush" Value="#44ffff3d"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Validation Required">
                                                        <Setter Property="Background" Value="#228A5CFF"/>
                                                        <Setter Property="BorderBrush" Value="#448A5CFF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status, FallbackValue='Installed'}" FontSize="11" FontFamily="{StaticResource PeydaBold}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#14BE78"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                                            <Setter Property="Foreground" Value="#9A9A9A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Corrupted">
                                                            <Setter Property="Foreground" Value="#F46B6B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                            <Setter Property="Foreground" Value="#F46B6B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Updating">
                                                            <Setter Property="Foreground" Value="#ffff3d"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Validation Required">
                                                            <Setter Property="Foreground" Value="#8A5CFF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Version -->
                                    <TextBlock Text="{Binding Version, FallbackValue='1.0.0'}" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" Margin="0,0,8,0" VerticalAlignment="Center"/>

                                    <!-- Developer -->
                                    <TextBlock Text="{Binding Publisher, FallbackValue='Developer'}" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                </WrapPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Column: X Close Button -->
                        <Button Grid.Column="1" Width="36" Height="36" VerticalAlignment="Top" Click="CloseModal_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CloseBorder" Background="Transparent" CornerRadius="18" BorderThickness="0">
                                        <Path x:Name="CrossPath" Data="M10 10L26 26M26 10L10 26" Stroke="#9A9A9A" StrokeThickness="2" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CloseBorder" Property="Background" Value="#D9383A"/>
                                            <Setter TargetName="CrossPath" Property="Stroke" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- BODY/SPLIT COLUMNS -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6.5*" /> <!-- Left 65% Column -->
                            <ColumnDefinition Width="20" />  <!-- Spacing gap 20px -->
                            <ColumnDefinition Width="3.5*" /> <!-- Right 35% Column -->
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN (65%) -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,0,10,0">

                                <!-- 1. General Info Card -->
                                <Border Background="#121216" BorderBrush="#252528" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="1. GENERAL" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#63E6FF" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- ID -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Application ID" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Id, FallbackValue='N/A'}" Foreground="White" FontSize="12" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center" Margin="8,0,0,0"/>

                                            <!-- Name -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Name / Title" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>

                                            <!-- Publisher -->
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Developer / Publisher" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Publisher, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 2. Executable Card -->
                                <Border Background="#121216" BorderBrush="#252528" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="2. EXECUTABLE" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#ffff3d" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Executable -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Executable" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Executable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>

                                            <!-- Install Directory -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Install Directory" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding InstallationPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 3. Launcher Card -->
                                <Border Background="#121216" BorderBrush="#252528" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="3. LAUNCHER" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#8A5CFF" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Launcher Platform -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Launcher Platform" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Row="0" Grid.Column="1" SelectedValue="{Binding Launcher, Mode=TwoWay}" SelectedValuePath="Content" Style="{StaticResource AdminDetailComboBoxStyle}">
                                                <ComboBoxItem Content="Steam"/>
                                                <ComboBoxItem Content="Epic"/>
                                                <ComboBoxItem Content="Battle.net"/>
                                                <ComboBoxItem Content="Riot"/>
                                                <ComboBoxItem Content="Ubisoft"/>
                                                <ComboBoxItem Content="EA"/>
                                                <ComboBoxItem Content="Xbox"/>
                                                <ComboBoxItem Content="Custom"/>
                                            </ComboBox>

                                            <!-- Installation Source -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Installation Source" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding InstallationSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 4. Launch Settings Card -->
                                <Border Background="#121216" BorderBrush="#252528" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="4. LAUNCH SETTINGS" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#14BE78" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Arguments -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Arguments / Params" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="#63E6FF" FontFamily="Consolas" Style="{StaticResource AdminDetailTextBoxStyle}"/>

                                            <!-- Working Directory -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Working Directory" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding InstallationPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 5. Runtime Card -->
                                <Border Background="#121216" BorderBrush="#252528" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="5. RUNTIME" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#F46B6B" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Status -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Execution Status" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Row="0" Grid.Column="1" SelectedValue="{Binding Status, Mode=TwoWay}" SelectedValuePath="Content" Style="{StaticResource AdminDetailComboBoxStyle}">
                                                <ComboBoxItem Content="Installed"/>
                                                <ComboBoxItem Content="Missing"/>
                                                <ComboBoxItem Content="Disabled"/>
                                                <ComboBoxItem Content="Updating"/>
                                                <ComboBoxItem Content="Corrupted"/>
                                                <ComboBoxItem Content="Validation Required"/>
                                            </ComboBox>

                                            <!-- Enabled -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Is Enabled" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding IsEnabled, Mode=TwoWay}" Foreground="White" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center" Content="Enabled"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 6. Images Card -->
                                <Border Background="#121216" BorderBrush="#252528" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="6. IMAGES" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#63E6FF" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Column Headers -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cover Image" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Logo Image" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Background Image" Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Center"/>

                                            <!-- Cover Image Container -->
                                            <Border Grid.Row="2" Grid.Column="0" Height="140" Background="#1C1F26" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                                <Grid>
                                                    <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                                          Fill="#22FFFFFF" Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                            </Border>

                                            <!-- Logo Image Container -->
                                            <Border Grid.Row="2" Grid.Column="2" Height="140" Background="#1C1F26" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                                <Grid>
                                                    <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                                          Fill="#22FFFFFF" Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Image Source="{Binding LogoImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                            </Border>

                                            <!-- Background Image Container -->
                                            <Border Grid.Row="2" Grid.Column="4" Height="140" Background="#1C1F26" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                                <Grid>
                                                    <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                                          Fill="#22FFFFFF" Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Image Source="{Binding BackgroundImage}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 7. Metadata Card -->
                                <Border Background="#121216" BorderBrush="#252528" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="7. METADATA" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#ffff3d" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Size -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Size on Disk" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Size, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>

                                            <!-- License -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="License Model" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Row="2" Grid.Column="1" SelectedValue="{Binding License, Mode=TwoWay}" SelectedValuePath="Content" Style="{StaticResource AdminDetailComboBoxStyle}">
                                                <ComboBoxItem Content="Commercial"/>
                                                <ComboBoxItem Content="Free"/>
                                                <ComboBoxItem Content="Free-to-Play"/>
                                            </ComboBox>

                                            <!-- Release Year -->
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Release Year" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ReleaseYear, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 8. Tags Card -->
                                <Border Background="#121216" BorderBrush="#252528" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="8. TAGS" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#8A5CFF" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Category -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Category / Genre" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>

                                            <!-- Custom Tags -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Custom Tags" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CustomTags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 9. Security Card -->
                                <Border Background="#121216" BorderBrush="#252528" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="9. SECURITY" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#14BE78" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Verification Status -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Verification Status" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding VerificationStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>

                                            <!-- Sandbox Mode -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Sandbox Mode" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SandboxMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 10. Visibility Card -->
                                <Border Background="#121216" BorderBrush="#252528" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="10. VISIBILITY" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#63E6FF" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Hide on Client -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Hide on Client" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding HideOnClient, Mode=TwoWay}" Foreground="White" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center" Content="Hide"/>

                                            <!-- Last Updated -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Synced / Modified" Foreground="#9A9A9A" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastUpdated, FallbackValue='N/A'}" Foreground="White" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Danger Zone -->
                                <Border BorderBrush="#F46B6B" BorderThickness="1.5" CornerRadius="12" Background="#1A1212" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="DANGER ZONE" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#F46B6B" Margin="0,0,0,8" FontWeight="Bold"/>
                                        <TextBlock Text="These actions can result in permanent loss of local app states, metadata configuration, or image cache. Please execute with high caution."
                                                   Foreground="#9A9A9A" FontSize="11" FontFamily="{StaticResource PeydaMedium}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Reset Config -->
                                            <Button Grid.Column="0" Content="Reset Config" Height="36" Margin="0,0,8,0" Click="ResetConfig_Click" Foreground="#F46B6B">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                        <Setter Property="BorderBrush" Value="#44F46B6B"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Remove Images -->
                                            <Button Grid.Column="1" Content="Remove Images" Height="36" Margin="0,0,8,0" Click="RemoveImages_Click" Foreground="#F46B6B">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                        <Setter Property="BorderBrush" Value="#44F46B6B"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Delete Game -->
                                            <Button Grid.Column="2" Content="Delete Entry" Height="36" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Foreground="White">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                        <Setter Property="Background" Value="#F46B6B"/>
                                                        <Setter Property="BorderBrush" Value="#F46B6B"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#D9383A"/>
                                                                <Setter Property="BorderBrush" Value="#D9383A"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- RIGHT COLUMN (35%) -->
                        <Grid Grid.Column="2" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="QUICK ACTIONS" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="#63E6FF" Margin="0,0,0,16" FontWeight="Bold"/>

                                <!-- Launch Button -->
                                <Button Content="Launch Application" Command="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Height="42" Margin="0,0,0,12">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                            <Setter Property="Background" Value="#2214BE78"/>
                                            <Setter Property="BorderBrush" Value="#4414BE78"/>
                                            <Setter Property="Foreground" Value="#14BE78"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                            <Grid Margin="12,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Play Icon Geometry -->
                                                                <Path Data="M8 5v14l11-7z" Fill="#14BE78" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#3314BE78"/>
                                                                <Setter TargetName="border" Property="BorderBrush" Value="#14BE78"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Stop Button -->
                                <Button Content="Stop Execution" Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Height="42" Margin="0,0,0,12">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                            <Setter Property="Background" Value="#22F46B6B"/>
                                            <Setter Property="BorderBrush" Value="#44F46B6B"/>
                                            <Setter Property="Foreground" Value="#F46B6B"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                            <Grid Margin="12,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Stop Icon Geometry -->
                                                                <Path Data="M6 6h12v12H6z" Fill="#F46B6B" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#33F46B6B"/>
                                                                <Setter TargetName="border" Property="BorderBrush" Value="#F46B6B"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Restart Button -->
                                <Button Content="Restart App" Command="{Binding DataContext.RestartCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Height="42" Margin="0,0,0,12">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                            <Setter Property="Template">
                                                <Setter.Value>
