<Window x:Class="Sayra.UI.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sayra.UI.Views"
        xmlns:c="clr-namespace:Sayra.UI.Controls"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        xmlns:suis="clr-namespace:Sayra.UI.Services"
        mc:Ignorable="d"
        Title="SAYRA Admin Panel"
        Height="1080" Width="1920"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Fade-in animation for Window content -->
        <Storyboard x:Key="WindowFadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1.0" />
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeInStoryboard}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootGrid">
        <!-- Background accents -->
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Color="#150E1A1A" Offset="0"/>
                <GradientStop Color="#08090D" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <!-- Top Header Bar -->
        <Grid Height="80" VerticalAlignment="Top" Background="#A6020305" Panel.ZIndex="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- App Logo / Branding -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,0,0">
                <svgc:SvgViewbox Source="/Assets/sayra.svg" Width="100" Height="25" VerticalAlignment="Center"/>
                <Border Width="1" Height="20" Background="#33FFFFFF" Margin="15,0"/>
                <TextBlock Text="پنل مدیریت سایرا" FontFamily="{StaticResource PeydaBold}" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="[ADMIN CONTROL PANEL]" FontFamily="{StaticResource PeydaLight}" FontSize="11" Foreground="#F5FF00" Margin="10,0,0,0" VerticalAlignment="Center" Opacity="0.8"/>
            </StackPanel>

            <!-- Exit / Logout buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,30,0">
                <Button Content="خروج از پنل" Click="LogoutButton_Click" Height="40" Padding="20,0" Cursor="Hand" Foreground="White" FontSize="13" FontFamily="{StaticResource PeydaMedium}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="#1AF46B6B" BorderBrush="#33F46B6B" BorderThickness="1" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#33F46B6B"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#F46B6B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Content Area -->
        <Grid Margin="50,130,50,50">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page Title -->
            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                <TextBlock Text="داشبورد مدیریت" FontFamily="{StaticResource PeydaBold}" FontSize="28" Foreground="White"/>
                <TextBlock Text="به پنل کاربری مدیریت سیستم سایرا خوش آمدید. این صفحه در حال حاضر خالی است." FontFamily="{StaticResource PeydaLight}" FontSize="14" Foreground="#A1A1AA" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Center Empty State Panel -->
            <Border Grid.Row="1" Background="#A60A0A0A" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="16">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">
                        <!-- Icon Placeholder -->
                        <Border Width="80" Height="80" CornerRadius="40" Background="#0AFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" Margin="0,0,0,25" HorizontalAlignment="Center">
                            <Path Data="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z"
                                  Fill="#F5FF00" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="صفحه ادمین خالی" FontFamily="{StaticResource PeydaBold}" FontSize="20" Foreground="White" HorizontalAlignment="Center"/>

                        <TextBlock Text="تمام دسترسی‌های مدیریتی، پیکربندی سیستم، مدیریت کلاینت‌ها و گزارش‌گیری در این بخش قرار خواهند گرفت."
                                   FontFamily="{StaticResource PeydaLight}" FontSize="14" Foreground="#A1A1AA" TextAlignment="Center" Margin="0,15,0,30" LineHeight="22"/>

                        <!-- Interactive Back Button to return to Login Window -->
                        <Button Content="بازگشت به صفحه ورود" Click="LogoutButton_Click" Height="48" Cursor="Hand" Foreground="#08090D" FontSize="14" FontFamily="{StaticResource PeydaBold}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#F5FF00" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#DDE500"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#BCC200"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Floating Horizontal Notification Card -->
        <Grid VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40" Panel.ZIndex="1000" IsHitTestVisible="True"
              DataContext="{Binding Source={x:Static suis:NotificationService.Instance}}"
              Visibility="{Binding IsNotificationVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <c:NotificationCard DataContext="{Binding CurrentNotification}" />
        </Grid>
    </Grid>
</Window>
