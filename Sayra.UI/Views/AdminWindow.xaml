<Window x:Class="Sayra.UI.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sayra.UI.Views"
        xmlns:controls="clr-namespace:Sayra.UI.Controls"
        xmlns:services="clr-namespace:Sayra.UI.Services"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        mc:Ignorable="d"
        Title="SAYRA Admin Workspace"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="LeftToRight">

    <!-- Define premium dark style resources for layout placeholders -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/AdminTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PremiumDataGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource PremiumDataGridRowStyle}">
                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridRow_PreviewMouseLeftButtonDown"/>
                <EventSetter Event="MouseEnter" Handler="DataGridRow_MouseEnter"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{DynamicResource Admin.BackgroundBrush}">
        <!-- ROOT GRID (Wrapped in a container with an effect) -->
        <Grid x:Name="MainContentContainer">
            <Grid.Effect>
                <BlurEffect x:Name="BgBlurEffect" Radius="0" KernelType="Box"/>
            </Grid.Effect>

            <Grid x:Name="RootGrid">
                <Grid.RowDefinitions>
                <RowDefinition Height="56" />  <!-- Row 0: Header (Fixed to 56px, 2/3 of original thickness) -->
                    <RowDefinition Height="*" />   <!-- Row 1: Workspace (Stretch) -->
                    <RowDefinition Height="50" />  <!-- Row 2: Footer (Fixed to 50px) -->
                </Grid.RowDefinitions>

            <!-- 01. HEADER -->
            <!-- Width: Stretch to full window width. Height: 56px. Background panel color #181A20 with border #2A2D36 -->
            <Border Grid.Row="0" Height="56" Background="{DynamicResource Admin.SurfaceBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="0,0,0,1" Padding="24,8,24,8">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <!-- Branding & Breadcrumb Area on the left. Width: Auto -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Empty center space -->
                        <ColumnDefinition Width="*" />
                        <!-- Status Area on the right -->
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- BRANDING & BREADCRUMB AREA -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Application Logo: 140px width, matching TopBar in Home/Dashboard -->
                        <svgc:SvgViewbox Source="/Assets/sayra.svg"
                                         Width="140"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center" />

                        <!-- Spacing after logo: 16px -->
                        <Border Width="16" />

                        <!-- Title and Breadcrumb -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Game &amp; Application Manager"
                                       FontFamily="{StaticResource PeydaBold}"
                                       FontSize="16"
                                       Foreground="{DynamicResource Admin.AccentBrush}"
                                       FontWeight="Bold"
                                       LineHeight="20" />
                            <TextBlock Text="Local Administration / Game &amp; Application Manager"
                                       FontFamily="{StaticResource PeydaMedium}"
                                       FontSize="11"
                                       Foreground="{DynamicResource Admin.Text.Secondary}"
                                       FontWeight="Normal"
                                       LineHeight="14"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- NAVIGATION & SESSION CONTROLS (Go to Home & Logout) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0">
                        <!-- Go to Home Button -->
                        <Button Content="صفحه اصلی" Click="GoToHome_Click" Height="34" Margin="0,0,12,0" Padding="14,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource Admin.Cyan.Translucent.22}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource Admin.Cyan.Translucent.44}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Cyan}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Admin.Cyan.Translucent.33}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Admin.Cyan}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Logout Button -->
                        <Button Content="خروج از حساب" Click="Logout_Click" Height="34" Padding="14,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource Admin.Danger.Translucent.22}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger.Translucent.44}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Danger}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Admin.Danger.Translucent.33}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- STATUS AREA (Height: 40px, Width: 150px per card, spacing 12px) -->
                    <!-- Items: PC Name, Server Status, Last Scan, Games Count, Applications Count -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- PC NAME -->
                        <controls:StatusWidget Width="150" Height="40"
                                               Icon="{StaticResource PCNameIcon}"
                                               Label="PC NAME"
                                               Value="PC-05" />

                        <!-- Spacing: 12px -->
                        <Border Width="12" />

                        <!-- SERVER STATUS -->
                        <controls:StatusWidget Width="150" Height="40"
                                               Icon="{StaticResource ServerStatusIcon}"
                                               Label="SERVER STATUS"
                                               Value="Connected" />

                        <!-- Spacing: 12px -->
                        <Border Width="12" />

                        <!-- LAST SCAN -->
                        <controls:StatusWidget Width="150" Height="40"
                                               Icon="{StaticResource LastScanIcon}"
                                               Label="LAST SCAN"
                                               Value="Today 14:25" />

                        <!-- Spacing: 12px -->
                        <Border Width="12" />

                        <!-- GAMES COUNT (Bound dynamically to category 1 count) -->
                        <controls:StatusWidget Width="150" Height="40"
                                               Icon="{StaticResource GameCountIcon}"
                                               Label="GAMES COUNT"
                                               Value="{Binding Categories[1].Count, FallbackValue=86}" />

                        <!-- Spacing: 12px -->
                        <Border Width="12" />

                        <!-- APPLICATIONS COUNT (Bound dynamically to category 2 count) -->
                        <controls:StatusWidget Width="150" Height="40"
                                               Icon="{StaticResource AppCountIcon}"
                                               Label="APPLICATIONS COUNT"
                                               Value="{Binding Categories[2].Count, FallbackValue=14}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- NESTED GRID: Workspace -->
            <!-- Background is omitted ({x:Null}) to allow hit-testing to pass through to underlying elements -->
            <Grid Grid.Row="1" x:Name="WorkspaceGrid" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*" MinWidth="180" MaxWidth="250" /> <!-- Column 0: Category Sidebar -->
                    <ColumnDefinition Width="16" />  <!-- Gap -->
                    <ColumnDefinition Width="10.7*" />   <!-- Column 1: Games Panel (Stretches) -->
                    <ColumnDefinition Width="16" />  <!-- Gap -->
                    <ColumnDefinition Width="3.2*" MinWidth="260" MaxWidth="320" /> <!-- Column 2: Right Sidebar -->
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- Row 0: Search Area -->
                    <RowDefinition Height="Auto" />  <!-- Row 1: Action Area Level / Toolbar -->
                    <RowDefinition Height="*" />     <!-- Row 2: Content Level (Stretch) -->
                </Grid.RowDefinitions>

                <!-- 07. CATEGORY SIDEBAR -->
                <!-- Category Sidebar aligned with Main DataGrid in Row 2 -->
                <Grid Grid.Column="0" Grid.Row="2" Grid.RowSpan="1" Margin="24,12,0,12">
                    <Border Background="{DynamicResource Admin.SurfaceBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="8">
                        <ListBox x:Name="CategoriesList"
                                 ItemsSource="{Binding Categories}"
                                 SelectedItem="{Binding SelectedCategory}"
                                 Style="{StaticResource CategoryListBoxStyle}"
                                 ItemContainerStyle="{StaticResource CategoryListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="32">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Category Icon -->
                                        <Path Grid.Column="0" Data="{Binding IconGeometry}"
                                              Width="16" Height="16" Stretch="Uniform"
                                              VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <!-- Default state: outline icon -->
                                                    <Setter Property="Stroke" Value="{DynamicResource Admin.Text.Secondary}"/>
                                                    <Setter Property="StrokeThickness" Value="1.5"/>
                                                    <Setter Property="Fill" Value="Transparent"/>

                                                    <Style.Triggers>
                                                        <!-- If outline icon is hovered -->
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Stroke" Value="{DynamicResource Admin.WhiteBrush}"/>
                                                        </DataTrigger>
                                                        <!-- If outline icon is selected -->
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Stroke" Value="{DynamicResource Admin.AccentBrush}"/>
                                                        </DataTrigger>

                                                        <!-- If it's a Brand Icon (Solid fill instead of outline stroke) -->
                                                        <DataTrigger Binding="{Binding IsBrandIcon}" Value="True">
                                                            <Setter Property="Fill" Value="{DynamicResource Admin.Text.Secondary}"/>
                                                            <Setter Property="Stroke" Value="Transparent"/>
                                                            <Setter Property="StrokeThickness" Value="0"/>
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsBrandIcon}" Value="True"/>
                                                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Fill" Value="{DynamicResource Admin.WhiteBrush}"/>
                                                            <Setter Property="Stroke" Value="Transparent"/>
                                                            <Setter Property="StrokeThickness" Value="0"/>
                                                        </MultiDataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsBrandIcon}" Value="True"/>
                                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Fill" Value="{DynamicResource Admin.AccentBrush}"/>
                                                            <Setter Property="Stroke" Value="Transparent"/>
                                                            <Setter Property="StrokeThickness" Value="0"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <!-- Category Name -->
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   Foreground="White" FontSize="13"
                                                   FontFamily="{StaticResource PeydaMedium}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- Count Badge -->
                                        <Border Grid.Column="2" Background="{DynamicResource Admin.Selection.BgBrush}" CornerRadius="10" Padding="8,2" Height="18" MinWidth="22" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Count}" Foreground="{DynamicResource Admin.AccentBrush}" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>

                <!-- 02. SEARCH (Full width) -->
                <!-- Shorter Search Box (Height: 38px, Margin: 12px top, 24px left/right) -->
                <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0" Margin="24,12,0,0" Height="38">
                    <Border CornerRadius="8" Background="{DynamicResource Admin.SurfaceBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1.5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Search Icon -->
                            <Path Grid.Column="0" Data="{StaticResource SearchIconGeometry}"
                                  Stroke="{DynamicResource Admin.Text.Secondary}" StrokeThickness="1.5" Width="14" Height="14"
                                  Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" />

                            <!-- Search TextBox -->
                            <TextBox Grid.Column="1" x:Name="SearchBox"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="White" CaretBrush="{DynamicResource Admin.AccentBrush}"
                                     VerticalContentAlignment="Center" FontSize="12"
                                     FontFamily="{StaticResource PeydaMedium}" Padding="4,0,0,0"/>

                            <!-- Placeholder Text block (Visible only when text is empty) -->
                            <TextBlock Grid.Column="1" Text="Search by name, publisher, executable or category..."
                                       Foreground="{DynamicResource Admin.Translucent.55}" IsHitTestVisible="False"
                                       VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0"
                                       FontSize="12" FontFamily="{StaticResource PeydaMedium}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Total items badge on the right -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Border Background="{DynamicResource Admin.Selection.BgBrush}" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalItemsCount, StringFormat='{}{0} items found'}" Foreground="{DynamicResource Admin.AccentBrush}" FontSize="10" FontFamily="{StaticResource PeydaBold}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 03. TOOLBAR (Full width) -->
                <!-- Thicker Toolbar (Height: 56px -> 64px, Margin: 8px top, 24px left/right, 4 separate border segments separated by 16px) -->
                <ScrollViewer Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled" BorderThickness="0" Background="Transparent" Margin="24,8,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="56">
                        <!-- GROUP: SCAN -->
                        <Border Background="{DynamicResource Admin.SurfaceBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,0" Margin="0,0,16,0" VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="SCAN" FontFamily="{StaticResource PeydaBold}" FontSize="9" Foreground="{DynamicResource Admin.Success}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Scan All">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource ScanAllIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Scan All" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Steam">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource SteamLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Steam" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Epic Games">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource EpicLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Epic" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Riot Games">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource RiotLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Riot" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Battle.net">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource BattlenetLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Battle.net" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Ubisoft">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource UbisoftLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Ubisoft" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Xbox">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource XboxLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Xbox" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource ToolbarLauncherButtonStyle}" Command="{Binding ScanComputerCommand}" ToolTip="Custom Launcher">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Data="{StaticResource CustomLogoGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Custom" FontSize="8.5" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- GROUP: ADD -->
                        <Border Background="{DynamicResource Admin.SurfaceBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,0" Margin="0,0,16,0" VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ADD" FontFamily="{StaticResource PeydaBold}" FontSize="9" Foreground="{DynamicResource Admin.Yellow}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding ManageCategoriesCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource AddGameIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Add Game" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding ManageCategoriesCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource AddAppIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Add App" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- GROUP: DATA -->
                        <Border Background="{DynamicResource Admin.SurfaceBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,0" Margin="0,0,16,0" VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="DATA" FontFamily="{StaticResource PeydaBold}" FontSize="9" Foreground="{DynamicResource Admin.Purple}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCategoriesCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource ImportIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Import" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCategoriesCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource ExportIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Export" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding BackupCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource BackupIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Backup" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RestoreCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource RestoreIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Restore" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- GROUP: SYNC (Adjacent to DATA) -->
                        <Border Background="{DynamicResource Admin.SurfaceBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,0" VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="SYNC" FontFamily="{StaticResource PeydaBold}" FontSize="9" Foreground="{DynamicResource Admin.AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource SyncFromIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Sync From Server" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource SyncToIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Sync To Server" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="6"/>
                                <Button Style="{StaticResource MainToolbarButtonStyle}" Command="{Binding RefreshCommand}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource CompareIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="Compare" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 09. GAMES PANEL -->
                <!-- Main DataGrid Container with integrated sticky pagination footer -->
                <Border Grid.Column="2" Grid.Row="2" Background="{DynamicResource Admin.SurfaceBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="10" Margin="0,12,0,12">
                    <Border.OpacityMask>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Border Background="Black" CornerRadius="10" SnapsToDevicePixels="True"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                        Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.OpacityMask>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" /> <!-- Local sticky pagination footer inside Games Panel -->
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" x:Name="GamesDataGrid"
                                  ItemsSource="{Binding VisibleItems}"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  MouseDoubleClick="GamesDataGrid_MouseDoubleClick"
                                  PreviewMouseLeftButtonUp="GamesDataGrid_PreviewMouseLeftButtonUp">
                            <DataGrid.Style>
                                <Style TargetType="DataGrid" BasedOn="{StaticResource PremiumDataGridStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedViewMode}" Value="Grid View">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedViewMode}" Value="Compact View">
                                            <Setter Property="RowHeight" Value="32"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Style>
                            <DataGrid.Columns>
                                <!-- Checkbox Column -->
                                <DataGridTemplateColumn Width="45">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid ContextMenu="{x:Null}" Background="Transparent">
                                                <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" ContextMenu="{x:Null}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Icon/Cover Column -->
                                <DataGridTemplateColumn Header="Cover" Width="55" HeaderStyle="{StaticResource PremiumDataGridHeaderCenteredStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="32" Height="32" Background="{DynamicResource Admin.Translucent.13}" CornerRadius="4" ClipToBounds="True" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="1" BorderBrush="{DynamicResource Admin.BorderBrush}">
                                                <Grid>
                                                    <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                                          Fill="{DynamicResource Admin.Translucent.33}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Name Column -->
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>

                                <!-- Category Column -->
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>

                                <!-- Launcher Column -->
                                <DataGridTextColumn Header="Launcher" Binding="{Binding Launcher}" Width="110" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>

                                <!-- Version Column -->
                                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="90" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>

                                <!-- Enabled Checkbox Column -->
                                <DataGridTemplateColumn Header="Enabled" Width="80" HeaderStyle="{StaticResource PremiumDataGridHeaderCenteredStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid ContextMenu="{x:Null}" Background="Transparent">
                                                <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" ContextMenu="{x:Null}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Path Column -->
                                <DataGridTemplateColumn Header="Path" Width="250">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource PremiumDataGridTextBlockStyle}" Text="{Binding InstallationPath}" ToolTip="{Binding InstallationPath}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Source Column -->
                                <DataGridTextColumn Header="Source" Binding="{Binding InstallationSource}" Width="110" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>

                                <!-- Enabled/Status Column -->
                                <DataGridTemplateColumn Header="Status" Width="105" HeaderStyle="{StaticResource PremiumDataGridHeaderCenteredStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource Admin.Success.Translucent.22}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Admin.Success.Translucent.44}"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                                                <Setter Property="Background" Value="{DynamicResource Admin.Translucent.22}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Admin.Translucent.44}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Corrupted">
                                                                <Setter Property="Background" Value="{DynamicResource Admin.Danger.Translucent.22}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger.Translucent.44}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                                <Setter Property="Background" Value="{DynamicResource Admin.Danger.Translucent.22}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger.Translucent.44}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Updating">
                                                                <Setter Property="Background" Value="{DynamicResource Admin.Yellow.Translucent.22}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Admin.Yellow.Translucent.44}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Validation Required">
                                                                <Setter Property="Background" Value="{DynamicResource Admin.Purple.Translucent.22}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Admin.Purple.Translucent.44}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontFamily="{StaticResource PeydaBold}" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="75">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource Admin.Success}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Text.Secondary}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Corrupted">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Danger}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Danger}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Updating">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Yellow}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Validation Required">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Purple}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Last Modified Column -->
                                <DataGridTextColumn Header="Last Updated" Binding="{Binding LastUpdated}" Width="130" ElementStyle="{StaticResource PremiumDataGridTextBlockStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Grid View Scrollable Container -->
                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="12">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedViewMode}" Value="Grid View">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>

                            <!-- ItemsControl to render GameCards in a responsive WrapPanel -->
                            <ItemsControl ItemsSource="{Binding VisibleItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:GameCard Title="{Binding Title}"
                                                            Genre="{Binding Genre}"
                                                            ImagePath="{Binding CoverImage}"
                                                            Status="{Binding Status}"
                                                            IsSelected="{Binding IsChecked, Mode=TwoWay}"
                                                            IsAvailable="{Binding IsEnabled}"
                                                            Margin="10"
                                                            PlayCommand="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            ContextMenu="{StaticResource GameItemContextMenu}"
                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Local Sticky Footer with Reusable Pagination Control -->
                        <Border Grid.Row="1" Background="{DynamicResource Admin.Field.BgBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="0,1,0,0" Padding="16,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- View Mode & Demo State on the left -->
                                    <ColumnDefinition Width="*"/>    <!-- Reusable Pagination component -->
                                </Grid.ColumnDefinitions>

                                <!-- Demo / View mode selectors -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- View Mode Selector -->
                                    <TextBlock Text="View Mode:" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox ItemsSource="{Binding ViewModes}" SelectedItem="{Binding SelectedViewMode}" Width="100" Height="26" Background="{DynamicResource Admin.RightSidebar.BgBrush}" Foreground="White" BorderBrush="{DynamicResource Admin.BorderBrush}" FontFamily="{StaticResource PeydaMedium}" FontSize="11" VerticalContentAlignment="Center"/>

                                    <Border Width="16"/>

                                    <!-- Demo State Selector -->
                                    <TextBlock Text="Demo State:" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox ItemsSource="{Binding DemoStates}" SelectedItem="{Binding SelectedDemoState}" Width="100" Height="26" Background="{DynamicResource Admin.RightSidebar.BgBrush}" Foreground="White" BorderBrush="{DynamicResource Admin.BorderBrush}" FontFamily="{StaticResource PeydaMedium}" FontSize="11" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Reusable Pagination Control -->
                                <controls:Pagination Grid.Column="1" Margin="24,0,0,0"
                                                     CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                                                     TotalItems="{Binding TotalItemsCount}"
                                                     PageSize="{Binding SelectedPageSize, Mode=TwoWay}"
                                                     RefreshCommand="{Binding RefreshCommand}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Old game details pane removed as requested (we now use a centered modal) -->

                <!-- 11. RIGHT SIDEBAR -->
                <!-- Right Sidebar aligned with Main DataGrid in Row 2 -->
                <Border Grid.Column="4" Grid.Row="0" Grid.RowSpan="3" Margin="0,12,24,12" Background="{DynamicResource Admin.RightSidebar.BgBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12,12,0,12">
                    <ScrollViewer Style="{StaticResource ThinScrollViewerStyle}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid x:Name="RightSidebarGrid" Margin="0,0,12,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- 11.1 Add New Game -->
                                <RowDefinition Height="Auto" /> <!-- 11.2 Scanner Result -->
                                <RowDefinition Height="Auto" /> <!-- 11.3 Validation Result -->
                                <RowDefinition Height="Auto" /> <!-- 11.4 Import Games -->
                                <RowDefinition Height="Auto" /> <!-- 11.5 Sync Conflict Resolver -->
                            </Grid.RowDefinitions>

                            <!-- 11.1 ADD NEW GAME -->
                            <Expander Grid.Row="0" Style="{StaticResource SidebarExpanderStyle}" IsExpanded="True">
                                <Expander.Header>
                                    <TextBlock Text="Add New Game" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White"/>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Name * Field -->
                                    <TextBlock Text="Name *" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                    <Border Background="{DynamicResource Admin.Field.BgBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="6" Height="30" Padding="6,2" Margin="0,0,0,10">
                                        <TextBox Background="Transparent" BorderThickness="0" Foreground="White" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalContentAlignment="Center" CaretBrush="{DynamicResource Admin.AccentBrush}"/>
                                    </Border>

                                    <!-- Executable Path * Field -->
                                    <TextBlock Text="Executable Path *" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{DynamicResource Admin.Field.BgBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="6,0,0,6" Height="30" Padding="6,2">
                                            <TextBox Background="Transparent" BorderThickness="0" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaMedium}" VerticalContentAlignment="Center" Text="D:\Games\New Game\game.exe" CaretBrush="{DynamicResource Admin.AccentBrush}"/>
                                        </Border>
                                        <Button Grid.Column="1" Content="Browse" Height="30" Padding="10,0" Style="{StaticResource ToolbarButtonStyle}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="0,6,6,0"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>

                                    <!-- Metadata Section (Launcher & Category Dropdowns) -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Launcher" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                            <ComboBox Height="30" Background="{DynamicResource Admin.Field.BgBrush}" Foreground="White" BorderBrush="{DynamicResource Admin.BorderBrush}" FontFamily="{StaticResource PeydaMedium}" FontSize="11" VerticalContentAlignment="Center" SelectedIndex="4">
                                                <ComboBoxItem Content="Steam"/>
                                                <ComboBoxItem Content="Epic Games"/>
                                                <ComboBoxItem Content="GOG"/>
                                                <ComboBoxItem Content="Battle.net"/>
                                                <ComboBoxItem Content="Manual"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Category" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                            <ComboBox Height="30" Background="{DynamicResource Admin.Field.BgBrush}" Foreground="White" BorderBrush="{DynamicResource Admin.BorderBrush}" FontFamily="{StaticResource PeydaMedium}" FontSize="11" VerticalContentAlignment="Center" SelectedIndex="0">
                                                <ComboBoxItem Content="Action"/>
                                                <ComboBoxItem Content="Adventure"/>
                                                <ComboBoxItem Content="RPG"/>
                                                <ComboBoxItem Content="Simulation"/>
                                                <ComboBoxItem Content="Strategy"/>
                                                <ComboBoxItem Content="Sport"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Description Section -->
                                    <TextBlock Text="Description" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                    <Border Background="{DynamicResource Admin.Field.BgBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="6" Height="60" Padding="6,4" Margin="0,0,0,10">
                                        <TextBox Background="Transparent" BorderThickness="0" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaMedium}" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" CaretBrush="{DynamicResource Admin.AccentBrush}"/>
                                    </Border>

                                    <!-- Favorite Checkbox -->
                                    <CheckBox Content="Add to Favorites" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="11" Margin="0,0,0,12"/>

                                    <!-- Footer Buttons -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Cancel" Height="30" Style="{StaticResource ToolbarButtonStyle}"/>
                                        <Button Grid.Column="2" Content="Add Game" Height="30">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                    <Setter Property="Background" Value="{DynamicResource Admin.Cyan.Translucent.22}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Admin.Cyan.Translucent.44}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Cyan}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Admin.Cyan.Translucent.33}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Admin.Cyan}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <!-- 11.2 SCANNER RESULT -->
                            <Expander Grid.Row="1" Style="{StaticResource SidebarExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Scanner Results" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White"/>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Main Body (Two Columns) -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="1.3*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Left Column: Circular Progress Chart -->
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Grid Width="64" Height="64">
                                                <!-- Progress Background Ring -->
                                                <Ellipse Stroke="{DynamicResource Admin.BorderBrush}" StrokeThickness="4"/>
                                                <!-- Progress Active Segment -->
                                                <Ellipse Stroke="{DynamicResource Admin.Cyan}" StrokeThickness="4" StrokeDashArray="3.14 0.8" RenderTransformOrigin="0.5,0.5">
                                                    <Ellipse.RenderTransform>
                                                        <RotateTransform Angle="-90"/>
                                                    </Ellipse.RenderTransform>
                                                </Ellipse>
                                                <!-- Text inside -->
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="87%" Foreground="{DynamicResource Admin.Cyan}" FontSize="12" FontFamily="{StaticResource PeydaBold}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Scanning" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="8" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Scanning path info -->
                                            <TextBlock Text="D:\Games\...\GAME.exe" Foreground="{DynamicResource Admin.Translucent.55}" FontSize="9" FontFamily="{StaticResource PeydaMedium}" Margin="0,8,0,0" HorizontalAlignment="Center" TextAlignment="Center" TextTrimming="CharacterEllipsis" Width="95" ToolTip="D:\Games\Steam\CS2\game.exe"/>
                                        </StackPanel>

                                        <!-- Right Column: Stats List -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <!-- Found Games -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Found Games" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="23" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <!-- Found Applications -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Found Applications" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="7" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <!-- Updated -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Updated" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="12" Foreground="{DynamicResource Admin.AccentBrush}" FontSize="11" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <!-- New -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="New" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="18" Foreground="{DynamicResource Admin.Success}" FontSize="11" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <!-- Errors -->
                                            <Grid>
                                                <TextBlock Text="Errors" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                                <TextBlock Text="2" Foreground="{DynamicResource Admin.Danger}" FontSize="11" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Footer -->
                                    <TextBlock Text="Time Elapsed 00:45" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="10" FontFamily="{StaticResource PeydaMedium}" Margin="0,0,0,10" HorizontalAlignment="Left"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Stop" Height="30">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                    <Setter Property="Background" Value="{DynamicResource Admin.Danger.Translucent.22}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger.Translucent.44}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Danger}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Admin.Danger.Translucent.33}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Grid.Column="2" Content="View Results" Height="30">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                    <Setter Property="Background" Value="{DynamicResource Admin.Cyan.Translucent.22}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Admin.Cyan.Translucent.44}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Cyan}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Admin.Cyan.Translucent.33}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Admin.Cyan}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <!-- 11.3 VALIDATION RESULT -->
                            <Expander Grid.Row="2" Style="{StaticResource SidebarExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Validation Results" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White"/>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Main Body (Two Columns) -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="1.3*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Left Column: Validation Status Circle -->
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Grid Width="56" Height="56">
                                                <Ellipse Stroke="{DynamicResource Admin.Success}" StrokeThickness="3" Fill="{DynamicResource Admin.Success.Translucent.11}"/>
                                                <!-- Checkmark Icon -->
                                                <Path Data="M 16,28 L 22,34 L 38,18" Stroke="{DynamicResource Admin.Success}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="Validation Completed" Foreground="{DynamicResource Admin.Success}" FontSize="10" FontFamily="{StaticResource PeydaBold}" Margin="0,8,0,0" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            <TextBlock Text="All checks passed successfully" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="8" FontFamily="{StaticResource PeydaMedium}" Margin="0,2,0,0" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Width="95"/>
                                        </StackPanel>

                                        <!-- Right Column: Validation Statistics Grid -->
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="1"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Headers -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="عنوان" Foreground="{DynamicResource Admin.Translucent.55}" FontSize="9" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left" Margin="0,0,0,2"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="مقدار" Foreground="{DynamicResource Admin.Translucent.55}" FontSize="9" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Right" Margin="0,0,0,2"/>
                                            <Border Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4"/>

                                            <!-- Total Files -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Files" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="10" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="1243" Foreground="White" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right" Margin="0,0,0,3"/>

                                            <!-- Valid Files -->
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Valid Files" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="10" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="1232" Foreground="{DynamicResource Admin.Success}" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right" Margin="0,0,0,3"/>

                                            <!-- Invalid Files -->
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Invalid Files" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="10" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="0" Foreground="White" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right" Margin="0,0,0,3"/>

                                            <!-- Missing Files -->
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Missing Files" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="10" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="11" Foreground="{DynamicResource Admin.Yellow}" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right" Margin="0,0,0,3"/>

                                            <!-- Corrupted Files -->
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Corrupted Files" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="10" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="0" Foreground="{DynamicResource Admin.Danger}" FontSize="10" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Grid>

                                    <!-- Footer -->
                                    <Button Content="Close" Height="30" Style="{StaticResource ToolbarButtonStyle}"/>
                                </StackPanel>
                            </Expander>

                            <!-- 11.4 IMPORT GAMES -->
                            <Expander Grid.Row="3" Style="{StaticResource SidebarExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Import Games" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White"/>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Source Section -->
                                    <TextBlock Text="Source" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" Margin="0,0,0,4" FontFamily="{StaticResource PeydaMedium}"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" Height="30" Background="{DynamicResource Admin.Field.BgBrush}" Foreground="White" BorderBrush="{DynamicResource Admin.BorderBrush}" FontFamily="{StaticResource PeydaMedium}" FontSize="11" VerticalContentAlignment="Center" SelectedIndex="0">
                                            <ComboBoxItem Content="Select source..."/>
                                            <ComboBoxItem Content="Steam Library"/>
                                            <ComboBoxItem Content="Epic Library"/>
                                            <ComboBoxItem Content="Folder"/>
                                            <ComboBoxItem Content="Backup"/>
                                            <ComboBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6,0,0,6"/>
                                                </Style>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                        <Button Grid.Column="1" Content="Browse" Height="30" Padding="10,0" Style="{StaticResource ToolbarButtonStyle}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="0,6,6,0"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>

                                    <!-- Import Options -->
                                    <TextBlock Text="Import Options" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" Margin="0,0,0,6" FontFamily="{StaticResource PeydaMedium}"/>
                                    <StackPanel Margin="0,0,0,12">
                                        <CheckBox Content="Import Games" IsChecked="True" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="10" Margin="0,0,0,6"/>
                                        <CheckBox Content="Import Applications" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="10" Margin="0,0,0,6"/>
                                        <CheckBox Content="Import Settings" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="10" Margin="0,0,0,6"/>
                                        <CheckBox Content="Import Metadata (Cover, Description...)" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="10"/>
                                    </StackPanel>

                                    <!-- Footer -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Cancel" Height="30" Style="{StaticResource ToolbarButtonStyle}"/>
                                        <Button Grid.Column="2" Content="Import" Height="30">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                    <Setter Property="Background" Value="{DynamicResource Admin.Cyan.Translucent.22}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Admin.Cyan.Translucent.44}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Cyan}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Admin.Cyan.Translucent.33}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Admin.Cyan}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <!-- 11.5 SYNC CONFLICT RESOLVER -->
                            <Expander Grid.Row="4" Style="{StaticResource SidebarExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Sync Conflict Resolver" FontFamily="{StaticResource PeydaBold}" FontSize="13" Foreground="White"/>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Conflict Summary -->
                                    <TextBlock Text="Conflicts Found: 3" Foreground="{DynamicResource Admin.Yellow}" FontSize="11" FontFamily="{StaticResource PeydaBold}" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <TextBlock Text="Choose which version to keep for each item" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="10" FontFamily="{StaticResource PeydaMedium}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                                    <!-- Conflict Table list -->
                                    <StackPanel Margin="0,0,0,12">
                                        <!-- Conflict Row 1: Valorant -->
                                        <Border BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0">
                                                    <TextBlock Text="Valorant" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                                    <TextBlock Text="Local is newer" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </StackPanel>
                                                <!-- Options buttons -->
                                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <RadioButton Grid.Column="0" GroupName="ValConflict" Content="Local" IsChecked="True" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="2" GroupName="ValConflict" Content="Server" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="4" GroupName="ValConflict" Content="Both" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <!-- Conflict Row 2: GTA V -->
                                        <Border BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0">
                                                    <TextBlock Text="GTA V" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                                    <TextBlock Text="Server is newer" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </StackPanel>
                                                <!-- Options buttons -->
                                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <RadioButton Grid.Column="0" GroupName="GtaConflict" Content="Local" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="2" GroupName="GtaConflict" Content="Server" IsChecked="True" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="4" GroupName="GtaConflict" Content="Both" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <!-- Conflict Row 3: Red Dead Redemption 2 -->
                                        <Border Padding="0,0,0,4">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0">
                                                    <TextBlock Text="Red Dead Redemption 2" Foreground="White" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                                    <TextBlock Text="Different" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </StackPanel>
                                                <!-- Options buttons -->
                                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <RadioButton Grid.Column="0" GroupName="RdrConflict" Content="Local" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="2" GroupName="RdrConflict" Content="Server" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                    <RadioButton Grid.Column="4" GroupName="RdrConflict" Content="Both" IsChecked="True" Style="{StaticResource {x:Type ToggleButton}}" Height="22" FontSize="9" FontFamily="{StaticResource PeydaMedium}"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <!-- Global Option -->
                                    <CheckBox Content="Apply to all conflicts" Foreground="White" FontFamily="{StaticResource PeydaMedium}" FontSize="10" Margin="0,0,0,12"/>

                                    <!-- Footer Buttons -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Skip All" Height="30" Style="{StaticResource ToolbarButtonStyle}"/>
                                        <Button Grid.Column="2" Content="Resolve" Height="30">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                    <Setter Property="Background" Value="{DynamicResource Admin.Cyan.Translucent.22}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Admin.Cyan.Translucent.44}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Cyan}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Admin.Cyan.Translucent.33}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Admin.Cyan}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 12. FOOTER -->
            <Border Grid.Row="2" Background="{DynamicResource Admin.SurfaceBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="0,1,0,0" Padding="24,10">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <!-- Full-width: Status Stat Cards -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Status Stat Cards -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Stat: Games -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="GAMES: " Foreground="{DynamicResource Admin.AccentBrush}" FontSize="14" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Categories[1].Count}" Foreground="{DynamicResource Admin.AccentBrush}" FontSize="18" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Stat: Applications -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="APPLICATIONS: " Foreground="{DynamicResource Admin.AccentBrush}" FontSize="14" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Categories[2].Count}" Foreground="{DynamicResource Admin.AccentBrush}" FontSize="18" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Stat: Installed -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="INSTALLED: " Foreground="{DynamicResource Admin.Success}" FontSize="14" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Categories[0].Count}" Foreground="{DynamicResource Admin.Success}" FontSize="18" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Stat: Missing -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="MISSING: " Foreground="{DynamicResource Admin.Danger}" FontSize="14" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Categories[15].Count}" Foreground="{DynamicResource Admin.Danger}" FontSize="18" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Stat: Broken / Invalid -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="INVALID: " Foreground="{DynamicResource Admin.Danger}" FontSize="14" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Categories[15].Count}" Foreground="{DynamicResource Admin.Danger}" FontSize="18" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Stat: Need Scan -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="NEED SCAN: " Foreground="{DynamicResource Admin.Yellow}" FontSize="14" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Categories[16].Count}" Foreground="{DynamicResource Admin.Yellow}" FontSize="18" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Stat: Disabled -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="DISABLED: " Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="14" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Categories[14].Count}" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="18" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        </Grid>

        <!-- FULL-SCREEN LOADING OVERLAY -->
        <Grid Background="{DynamicResource Admin.Loading.OverlayBrush}" Panel.ZIndex="10000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="{DynamicResource Admin.Loading.PanelBgBrush}" BorderBrush="{DynamicResource Admin.AccentBrush}" BorderThickness="1.5" CornerRadius="12" Width="380" Height="180" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Margin="24">
                    <TextBlock Text="Scanning Local Computer..." Foreground="White" FontSize="15" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <!-- Progress Bar -->
                    <ProgressBar Value="{Binding LoadingProgress}" Height="10" Background="{DynamicResource Admin.RightSidebar.BgBrush}" Foreground="{DynamicResource Admin.AccentBrush}" BorderThickness="0" Maximum="100"/>
                    <!-- Progress Text -->
                    <TextBlock Text="{Binding LoadingProgress, StringFormat='{}{0}% Completed'}" Foreground="{DynamicResource Admin.AccentBrush}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- MODAL DIALOG OVERLAY (Semi-transparent black overlay 45% & Blur focus controller) -->
        <Grid x:Name="ModalOverlay" DataContext="{x:Null}" Background="{DynamicResource Admin.Modal.OverlayBrush}" Panel.ZIndex="9000" Visibility="Collapsed" IsVisibleChanged="ModalOverlay_IsVisibleChanged" MouseDown="ModalOverlay_MouseDown">
            <!-- Centered Modal dialog container -->
            <Border x:Name="ModalCard"
                    Width="1100" Height="740"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="18" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1"
                    RenderTransformOrigin="0.5,0.5"
                    MouseDown="ModalCard_MouseDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="{DynamicResource Admin.Modal.Bg.Start.Color}" Offset="0"/>
                        <GradientStop Color="{DynamicResource Admin.Modal.Bg.End.Color}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource Admin.BlackBrush}" BlurRadius="40" ShadowDepth="8" Opacity="0.65"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <ScaleTransform x:Name="ModalScaleTransform" ScaleX="1.0" ScaleY="1.0"/>
                </Border.RenderTransform>

                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Header -->
                        <RowDefinition Height="*" />    <!-- Body/Split columns -->
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Game Cover & Metadata -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Game Cover: 96x96 glassmorphic -->
                            <Border Width="96" Height="96" Background="{DynamicResource Admin.Translucent.13}" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1" CornerRadius="12" Margin="0,0,20,0" ClipToBounds="True">
                                <Grid>
                                    <!-- Fallback Path icon -->
                                    <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                          Fill="{DynamicResource Admin.Translucent.33}" Width="48" Height="48" Stretch="Uniform"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <!-- Cover Image -->
                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Grid>
                            </Border>

                            <!-- Game Metadata Stack -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name, FallbackValue='Game Name'}" Foreground="White" FontSize="24" FontFamily="{StaticResource PeydaBold}" FontWeight="Bold"/>

                                <WrapPanel Margin="0,6,0,0" VerticalAlignment="Center">
                                    <!-- Category Badge -->
                                    <Border Background="{DynamicResource Admin.Selection.BgBrush}" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Category, FallbackValue='Games'}" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}"/>
                                    </Border>

                                    <!-- Game Type Badge -->
                                    <Border Background="{DynamicResource Admin.Purple.Translucent.22}" BorderBrush="{DynamicResource Admin.Purple.Translucent.44}" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding GameType, FallbackValue='Action'}" Foreground="{DynamicResource Admin.Purple}" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                    </Border>

                                    <!-- Platform Launcher -->
                                    <Border Background="{DynamicResource Admin.Field.BgBrush}" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Launcher, FallbackValue='Steam'}" Foreground="{DynamicResource Admin.AccentBrush}" FontSize="11" FontFamily="{StaticResource PeydaBold}"/>
                                    </Border>

                                    <!-- Installed Status Badge -->
                                    <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource Admin.Success.Translucent.22}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource Admin.Success.Translucent.44}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                                        <Setter Property="Background" Value="{DynamicResource Admin.Translucent.22}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Admin.Translucent.44}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Corrupted">
                                                        <Setter Property="Background" Value="{DynamicResource Admin.Danger.Translucent.22}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger.Translucent.44}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                        <Setter Property="Background" Value="{DynamicResource Admin.Danger.Translucent.22}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger.Translucent.44}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Updating">
                                                        <Setter Property="Background" Value="{DynamicResource Admin.Yellow.Translucent.22}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Admin.Yellow.Translucent.44}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Validation Required">
                                                        <Setter Property="Background" Value="{DynamicResource Admin.Purple.Translucent.22}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Admin.Purple.Translucent.44}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status, FallbackValue='Installed'}" FontSize="11" FontFamily="{StaticResource PeydaBold}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource Admin.Success}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                                            <Setter Property="Foreground" Value="{DynamicResource Admin.Text.Secondary}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Corrupted">
                                                            <Setter Property="Foreground" Value="{DynamicResource Admin.Danger}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                            <Setter Property="Foreground" Value="{DynamicResource Admin.Danger}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Updating">
                                                            <Setter Property="Foreground" Value="{DynamicResource Admin.Yellow}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Validation Required">
                                                            <Setter Property="Foreground" Value="{DynamicResource Admin.Purple}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Version -->
                                    <TextBlock Text="{Binding Version, FallbackValue='1.0.0'}" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" Margin="0,0,8,0" VerticalAlignment="Center"/>

                                    <!-- Developer -->
                                    <TextBlock Text="{Binding Publisher, FallbackValue='Developer'}" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                </WrapPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Column: X Close Button -->
                        <Button Grid.Column="1" Width="36" Height="36" VerticalAlignment="Top" Click="CloseModal_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CloseBorder" Background="Transparent" CornerRadius="18" BorderThickness="0">
                                        <Path x:Name="CrossPath" Data="M10 10L26 26M26 10L10 26" Stroke="{DynamicResource Admin.Text.Secondary}" StrokeThickness="2" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CloseBorder" Property="Background" Value="{DynamicResource Admin.CloseButton.HoverBgBrush}"/>
                                            <Setter TargetName="CrossPath" Property="Stroke" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- BODY/SPLIT COLUMNS -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6.5*" /> <!-- Left 65% Column -->
                            <ColumnDefinition Width="20" />  <!-- Spacing gap 20px -->
                            <ColumnDefinition Width="3.5*" /> <!-- Right 35% Column -->
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN (65%) -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,0,10,0">

                                <!-- 1. General Info Card -->
                                <Border Background="{DynamicResource Admin.Details.CardBgBrush}" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="1. GENERAL" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.AccentBrush}" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- ID -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Application ID" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Id, FallbackValue='N/A'}" Foreground="White" FontSize="12" FontFamily="{StaticResource PeydaBold}" VerticalAlignment="Center" Margin="8,0,0,0"/>

                                            <!-- Name -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Name / Title" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>

                                            <!-- Publisher -->
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Developer / Publisher" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Publisher, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 2. Executable Card -->
                                <Border Background="{DynamicResource Admin.Details.CardBgBrush}" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="2. EXECUTABLE" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.Yellow}" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Executable -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Executable" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Executable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>

                                            <!-- Install Directory -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Install Directory" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding InstallationPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 3. Launcher Card -->
                                <Border Background="{DynamicResource Admin.Details.CardBgBrush}" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="3. LAUNCHER" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.Purple}" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Launcher Platform -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Launcher Platform" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Row="0" Grid.Column="1" SelectedValue="{Binding Launcher, Mode=TwoWay}" SelectedValuePath="Content" Style="{StaticResource AdminDetailComboBoxStyle}">
                                                <ComboBoxItem Content="Steam"/>
                                                <ComboBoxItem Content="Epic"/>
                                                <ComboBoxItem Content="Battle.net"/>
                                                <ComboBoxItem Content="Riot"/>
                                                <ComboBoxItem Content="Ubisoft"/>
                                                <ComboBoxItem Content="EA"/>
                                                <ComboBoxItem Content="Xbox"/>
                                                <ComboBoxItem Content="Custom"/>
                                            </ComboBox>

                                            <!-- Installation Source -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Installation Source" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding InstallationSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 4. Launch Settings Card -->
                                <Border Background="{DynamicResource Admin.Details.CardBgBrush}" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="4. LAUNCH SETTINGS" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.Success}" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Arguments -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Arguments / Params" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{DynamicResource Admin.AccentBrush}" FontFamily="Consolas" Style="{StaticResource AdminDetailTextBoxStyle}"/>

                                            <!-- Working Directory -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Working Directory" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding InstallationPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 5. Runtime Card -->
                                <Border Background="{DynamicResource Admin.Details.CardBgBrush}" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="5. RUNTIME" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.Danger}" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Status -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Execution Status" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Row="0" Grid.Column="1" SelectedValue="{Binding Status, Mode=TwoWay}" SelectedValuePath="Content" Style="{StaticResource AdminDetailComboBoxStyle}">
                                                <ComboBoxItem Content="Installed"/>
                                                <ComboBoxItem Content="Missing"/>
                                                <ComboBoxItem Content="Disabled"/>
                                                <ComboBoxItem Content="Updating"/>
                                                <ComboBoxItem Content="Corrupted"/>
                                                <ComboBoxItem Content="Validation Required"/>
                                            </ComboBox>

                                            <!-- Enabled -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Is Enabled" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding IsEnabled, Mode=TwoWay}" Foreground="White" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center" Content="Enabled"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 6. Images Card -->
                                <Border Background="{DynamicResource Admin.Details.CardBgBrush}" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="6. IMAGES" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.AccentBrush}" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Column Headers -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cover Image" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Logo Image" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Background Image" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" HorizontalAlignment="Center"/>

                                            <!-- Cover Image Container -->
                                            <Border Grid.Row="2" Grid.Column="0" Height="140" Background="{DynamicResource Admin.Field.BgBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                                <Grid>
                                                    <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                                          Fill="{DynamicResource Admin.Translucent.22}" Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                            </Border>

                                            <!-- Logo Image Container -->
                                            <Border Grid.Row="2" Grid.Column="2" Height="140" Background="{DynamicResource Admin.Field.BgBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                                <Grid>
                                                    <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                                          Fill="{DynamicResource Admin.Translucent.22}" Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Image Source="{Binding LogoImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                            </Border>

                                            <!-- Background Image Container -->
                                            <Border Grid.Row="2" Grid.Column="4" Height="140" Background="{DynamicResource Admin.Field.BgBrush}" BorderBrush="{DynamicResource Admin.BorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                                <Grid>
                                                    <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                                          Fill="{DynamicResource Admin.Translucent.22}" Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Image Source="{Binding BackgroundImage}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                            </Border>

                                            <!-- Cover Input -->
                                            <Grid Grid.Row="4" Grid.Column="0" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding CoverImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                                <Button Grid.Column="1" Content="Browse" Height="28" Padding="8,0" Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" Click="BrowseCover_Click"/>
                                            </Grid>

                                            <!-- Logo Input -->
                                            <Grid Grid.Row="4" Grid.Column="2" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding LogoImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                                <Button Grid.Column="1" Content="Browse" Height="28" Padding="8,0" Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" Click="BrowseLogo_Click"/>
                                            </Grid>

                                            <!-- Background Input -->
                                            <Grid Grid.Row="4" Grid.Column="4" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding BackgroundImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                                <Button Grid.Column="1" Content="Browse" Height="28" Padding="8,0" Style="{StaticResource ToolbarButtonStyle}" Margin="4,0,0,0" Click="BrowseBackground_Click"/>
                                            </Grid>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 7. Metadata Card -->
                                <Border Background="{DynamicResource Admin.Details.CardBgBrush}" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="7. METADATA" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.Yellow}" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Size -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Size on Disk" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Size, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>

                                            <!-- License -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="License Model" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Row="2" Grid.Column="1" SelectedValue="{Binding License, Mode=TwoWay}" SelectedValuePath="Content" Style="{StaticResource AdminDetailComboBoxStyle}">
                                                <ComboBoxItem Content="Commercial"/>
                                                <ComboBoxItem Content="Free"/>
                                                <ComboBoxItem Content="Free-to-Play"/>
                                            </ComboBox>

                                            <!-- Release Year -->
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Release Year" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ReleaseYear, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 8. Tags Card -->
                                <Border Background="{DynamicResource Admin.Details.CardBgBrush}" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="8. TAGS" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.Purple}" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Category -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Category" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Row="0" Grid.Column="1"
                                                      SelectedItem="{Binding Category, Mode=TwoWay}"
                                                      ItemsSource="{Binding DataContext.ExtensiveCategories, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Style="{StaticResource AdminDetailComboBoxStyle}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <!-- Game Type / Genre -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Game Type / Genre" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Row="2" Grid.Column="1"
                                                      SelectedItem="{Binding GameType, Mode=TwoWay}"
                                                      ItemsSource="{Binding DataContext.ExtensiveGameTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Style="{StaticResource AdminDetailComboBoxStyle}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <!-- Custom Tags -->
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Custom Tags" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CustomTags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 9. Security Card -->
                                <Border Background="{DynamicResource Admin.Details.CardBgBrush}" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="9. SECURITY" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.Success}" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Verification Status -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Verification Status" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding VerificationStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>

                                            <!-- Sandbox Mode -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Sandbox Mode" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SandboxMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AdminDetailTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 10. Visibility Card -->
                                <Border Background="{DynamicResource Admin.Details.CardBgBrush}" BorderBrush="{DynamicResource Admin.Modal.BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="10. VISIBILITY" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.AccentBrush}" Margin="0,0,0,12" FontWeight="Bold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Hide on Client -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Hide on Client" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding HideOnClient, Mode=TwoWay}" Foreground="White" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center" Content="Hide"/>

                                            <!-- Last Updated -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Synced / Modified" Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastUpdated, FallbackValue='N/A'}" Foreground="White" FontSize="12" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Danger Zone -->
                                <Border BorderBrush="{DynamicResource Admin.Danger}" BorderThickness="1.5" CornerRadius="12" Background="{DynamicResource Admin.DangerZone.BgBrush}" Padding="16" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="DANGER ZONE" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.Danger}" Margin="0,0,0,8" FontWeight="Bold"/>
                                        <TextBlock Text="These actions can result in permanent loss of local app states, metadata configuration, or image cache. Please execute with high caution."
                                                   Foreground="{DynamicResource Admin.Text.Secondary}" FontSize="11" FontFamily="{StaticResource PeydaMedium}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Reset Config -->
                                            <Button Grid.Column="0" Content="Reset Config" Height="36" Margin="0,0,8,0" Click="ResetConfig_Click" Foreground="{DynamicResource Admin.Danger}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger.Translucent.44}"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Remove Images -->
                                            <Button Grid.Column="1" Content="Remove Images" Height="36" Margin="0,0,8,0" Click="RemoveImages_Click" Foreground="{DynamicResource Admin.Danger}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger.Translucent.44}"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Delete Game -->
                                            <Button Grid.Column="2" Content="Delete Entry" Height="36" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Foreground="White">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                        <Setter Property="Background" Value="{DynamicResource Admin.Danger}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger}"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource Admin.CloseButton.HoverBgBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Admin.CloseButton.HoverBgBrush}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- RIGHT COLUMN (35%) -->
                        <Grid Grid.Column="2" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="QUICK ACTIONS" FontFamily="{StaticResource PeydaBold}" FontSize="12" Foreground="{DynamicResource Admin.AccentBrush}" Margin="0,0,0,16" FontWeight="Bold"/>

                                <!-- Launch Button -->
                                <Button Content="Launch Application" Command="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Height="42" Margin="0,0,0,12">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                            <Setter Property="Background" Value="{DynamicResource Admin.Success.Translucent.22}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Admin.Success.Translucent.44}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Admin.Success}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                            <Grid Margin="12,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Play Icon Geometry -->
                                                                <Path Data="M8 5v14l11-7z" Fill="{DynamicResource Admin.Success}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Admin.Success.Translucent.33}"/>
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Admin.Success}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Stop Button -->
                                <Button Content="Stop Execution" Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Height="42" Margin="0,0,0,12">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                            <Setter Property="Background" Value="{DynamicResource Admin.Danger.Translucent.22}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Admin.Danger.Translucent.44}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Admin.Danger}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                            <Grid Margin="12,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Stop Icon Geometry -->
                                                                <Path Data="M6 6h12v12H6z" Fill="{DynamicResource Admin.Danger}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Admin.Danger.Translucent.33}"/>
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Admin.Danger}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Restart Button -->
                                <Button Content="Restart App" Command="{Binding DataContext.RestartCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Height="42" Margin="0,0,0,12">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                            <Grid Margin="12,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Restart Sync Icon -->
                                                                <Path Data="M19 8l-4 4h3c0 3.31-2.69 6-6 6a5.87 5.87 0 01-2.8-.7l-1.01 1.01A7.9 7.9 0 0012 20c4.42 0 8-3.58 8-8h3l-4-4zM6 12c0-3.31 2.69-6 6-6 1.01 0 1.97.25 2.8.7l1.01-1.01A7.9 7.9 0 0012 4c-4.42 0-8 3.58-8 8H1l4 4 4-4H6z" Fill="{DynamicResource Admin.Text.Secondary}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Admin.Selection.BgBrush}"/>
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Admin.AccentBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Verify Button -->
                                <Button Content="Verify Files" Command="{Binding DataContext.ValidateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Height="42" Margin="0,0,0,12">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                            <Grid Margin="12,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Shield/Check Icon -->
                                                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" Fill="{DynamicResource Admin.Text.Secondary}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Admin.Selection.BgBrush}"/>
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Admin.AccentBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Open Folder Button -->
                                <Button Content="Open Install Folder" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Height="42" Margin="0,0,0,12">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                            <Grid Margin="12,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Folder Icon -->
                                                                <Path Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" Fill="{DynamicResource Admin.Text.Secondary}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Admin.Selection.BgBrush}"/>
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Admin.AccentBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Browse Files Button -->
                                <Button Content="Browse Files" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Height="42" Margin="0,0,0,12">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                            <Grid Margin="12,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Search Eye/Magnifier Icon -->
                                                                <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" Fill="{DynamicResource Admin.Text.Secondary}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Admin.Selection.BgBrush}"/>
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Admin.AccentBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Export Button -->
                                <Button Content="Export Config" Command="{Binding DataContext.ExportCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Height="42" Margin="0,0,0,12">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                            <Grid Margin="12,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Share/Upload Icon -->
                                                                <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" Fill="{DynamicResource Admin.Text.Secondary}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Admin.Selection.BgBrush}"/>
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Admin.AccentBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Delete Button -->
                                <Button Content="Remove App" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Height="42" Margin="0,0,0,12">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                            <Grid Margin="12,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Delete Icon -->
                                                                <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" Fill="{DynamicResource Admin.Text.Secondary}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Admin.Selection.BgBrush}"/>
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Admin.Danger}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- GLOBAL NOTIFICATION SYSTEM -->
        <Grid IsHitTestVisible="False" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,24,24,0" Panel.ZIndex="9999"
              DataContext="{Binding Source={x:Static services:NotificationService.Instance}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsNotificationVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <controls:NotificationCard DataContext="{Binding CurrentNotification}" IsHitTestVisible="True"/>
        </Grid>
    </Grid>
</Window>
