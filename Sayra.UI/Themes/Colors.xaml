<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Sayra Phase 1 Design Tokens: Centralized Color Definitions -->
    <Color x:Key="App.Background">#101014</Color>
    <Color x:Key="App.Surface">#1F1F23</Color>
    <Color x:Key="App.Primary">#AA0072</Color>
    <Color x:Key="App.Accent">#87F4F6</Color>
    <Color x:Key="App.Border">#252528</Color>
    <Color x:Key="App.Text.Primary">#FFFFFF</Color>
    <Color x:Key="App.Text.Secondary">#9A9A9A</Color>
    <Color x:Key="App.Success">#14BE78</Color>
    <Color x:Key="App.Error">#EF4444</Color>
    <Color x:Key="App.Warning">#E5A000</Color>
    <Color x:Key="App.Danger">#F46B6B</Color>

    <!-- Home Page Centralized Colors -->
    <Color x:Key="Home.Background.Color">#08090D</Color>
    <Color x:Key="Home.AccentYellow.Color">#F5FF00</Color>
    <Color x:Key="Home.EndSession.HoverBg.Color">#1AF46B6B</Color>
    <Color x:Key="Home.EndSession.PressedBg.Color">#33F46B6B</Color>

    <!-- Specific Login Screen Brand Colors (Yellow accent/glow used in current UI) -->
    <Color x:Key="App.Login.YellowAccent">#F5FF00</Color>
    <Color x:Key="App.Login.YellowBorder">#29F5FF00</Color>
    <Color x:Key="App.Login.GlassInputBg">#1A0A0A0A</Color>
    <Color x:Key="App.Login.GlassInputBorder">#22F5FF00</Color>
    <Color x:Key="App.Login.GlassPanelBg">#A60A0A0A</Color>
    <Color x:Key="App.Login.DarkBg">#050507</Color>
    <Color x:Key="App.Login.DarkBgTransparent">#00050507</Color>
    <Color x:Key="App.Login.WhiteBorder">#1AFFFFFF</Color>
    <Color x:Key="App.Login.WhiteHoverBg">#1AFFFFFF</Color>
    <Color x:Key="App.Login.WhiteHoverBorder">#4DFFFFFF</Color>
    <Color x:Key="App.Login.WhitePressedBg">#33FFFFFF</Color>
    <Color x:Key="App.Login.PlaceholderText">#66FFFFFF</Color>
    <Color x:Key="App.Login.SecondaryText">#A1A1AA</Color>
</ResourceDictionary>
