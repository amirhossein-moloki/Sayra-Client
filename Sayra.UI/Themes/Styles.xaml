<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">
    <!-- Import Brushes resource dictionary -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Brushes.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Style for SVG Logo (Yellow Glow Effect Removed) -->
    <Style x:Key="BreathingLogoStyle" TargetType="svgc:SvgViewbox">
        <!-- No yellow DropShadowEffect glow on Sayra Logo in login screen -->
    </Style>

    <!-- Circular Action Minimize / Close Button Styles -->
    <Style x:Key="WindowActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="18" BorderThickness="1" BorderBrush="{DynamicResource LoginWhiteBorderBrush}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource LoginWhiteHoverBgBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource LoginWhiteHoverBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource LoginWhitePressedBgBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Reusable Glass Card Panel Style for Login Container -->
    <Style x:Key="LoginCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource LoginGlassPanelBgBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LoginYellowBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="24"/>
        <Setter Property="Padding" Value="35,40"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="10" Opacity="0.65" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- System Terminal Access Subtitle Styles -->
    <Style x:Key="TerminalAccessHeaderLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PeydaBold}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{DynamicResource LoginYellowAccentBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Opacity" Value="0.8"/>
    </Style>

    <Style x:Key="TerminalAccessSubtitleLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PeydaLight}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource LoginSecondaryTextBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
        <Setter Property="Opacity" Value="0.6"/>
    </Style>

    <!-- Username/Password Header Labels -->
    <Style x:Key="InputHeaderLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PeydaBold}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource LoginSecondaryTextBrush}"/>
        <Setter Property="Margin" Value="5,0,0,2"/>
        <Setter Property="Opacity" Value="0.8"/>
    </Style>

    <!-- Error message text block style -->
    <Style x:Key="LoginErrorTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
        <Setter Property="Margin" Value="5,0,0,15"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- Progress loading description text style -->
    <Style x:Key="LoginLoadingTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource LoginYellowAccentBrush}"/>
        <Setter Property="Margin" Value="10,0,0,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
</ResourceDictionary>
