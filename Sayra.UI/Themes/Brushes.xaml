<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Import Colors resource dictionary for resolving references -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Base SolidColorBrush resources matching design tokens -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource App.Background}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource App.Surface}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource App.Primary}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource App.Accent}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource App.Border}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource App.Text.Primary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource App.Text.Secondary}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource App.Success}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource App.Error}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource App.Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource App.Danger}"/>

    <!-- Home Page Centralized Brushes -->
    <SolidColorBrush x:Key="Home.Background" Color="{DynamicResource Home.Background.Color}"/>
    <SolidColorBrush x:Key="Home.AccentYellow" Color="{DynamicResource Home.AccentYellow.Color}"/>
    <SolidColorBrush x:Key="Home.EndSession.HoverBg" Color="{DynamicResource Home.EndSession.HoverBg.Color}"/>
    <SolidColorBrush x:Key="Home.EndSession.PressedBg" Color="{DynamicResource Home.EndSession.PressedBg.Color}"/>

    <!-- Specific Login Screen Brushes -->
    <SolidColorBrush x:Key="LoginYellowAccentBrush" Color="{DynamicResource App.Login.YellowAccent}"/>
    <SolidColorBrush x:Key="LoginYellowBorderBrush" Color="{DynamicResource App.Login.YellowBorder}"/>
    <SolidColorBrush x:Key="LoginGlassInputBgBrush" Color="{DynamicResource App.Login.GlassInputBg}"/>
    <SolidColorBrush x:Key="LoginGlassInputBorderBrush" Color="{DynamicResource App.Login.GlassInputBorder}"/>
    <SolidColorBrush x:Key="LoginGlassPanelBgBrush" Color="{DynamicResource App.Login.GlassPanelBg}"/>
    <SolidColorBrush x:Key="LoginDarkBgBrush" Color="{DynamicResource App.Login.DarkBg}"/>
    <SolidColorBrush x:Key="LoginDarkBgTransparentBrush" Color="{DynamicResource App.Login.DarkBgTransparent}"/>
    <SolidColorBrush x:Key="LoginWhiteBorderBrush" Color="{DynamicResource App.Login.WhiteBorder}"/>
    <SolidColorBrush x:Key="LoginWhiteHoverBgBrush" Color="{DynamicResource App.Login.WhiteHoverBg}"/>
    <SolidColorBrush x:Key="LoginWhiteHoverBorderBrush" Color="{DynamicResource App.Login.WhiteHoverBorder}"/>
    <SolidColorBrush x:Key="LoginWhitePressedBgBrush" Color="{DynamicResource App.Login.WhitePressedBg}"/>
    <SolidColorBrush x:Key="LoginPlaceholderTextBrush" Color="{DynamicResource App.Login.PlaceholderText}"/>
    <SolidColorBrush x:Key="LoginSecondaryTextBrush" Color="{DynamicResource App.Login.SecondaryText}"/>

    <!-- Admin Page Centralized Brushes -->
    <SolidColorBrush x:Key="Admin.BackgroundBrush" Color="{DynamicResource Admin.Background.Color}"/>
    <SolidColorBrush x:Key="Admin.SurfaceBrush" Color="{DynamicResource Admin.Surface.Color}"/>
    <SolidColorBrush x:Key="Admin.BorderBrush" Color="{DynamicResource Admin.Border.Color}"/>
    <SolidColorBrush x:Key="Admin.AccentBrush" Color="{DynamicResource Admin.Accent.Color}"/>
    <SolidColorBrush x:Key="Admin.Text.Secondary" Color="{DynamicResource Admin.Text.Secondary.Color}"/>
    <SolidColorBrush x:Key="Admin.Button.BgBrush" Color="{DynamicResource Admin.Button.Bg.Color}"/>
    <SolidColorBrush x:Key="Admin.Button.FgBrush" Color="{DynamicResource Admin.Button.Fg.Color}"/>
    <SolidColorBrush x:Key="Admin.Button.HoverBgBrush" Color="{DynamicResource Admin.Button.HoverBg.Color}"/>
    <SolidColorBrush x:Key="Admin.Button.PressedBgBrush" Color="{DynamicResource Admin.Button.PressedBg.Color}"/>
    <SolidColorBrush x:Key="Admin.Field.BgBrush" Color="{DynamicResource Admin.Field.Bg.Color}"/>
    <SolidColorBrush x:Key="Admin.Field.FocusedBgBrush" Color="{DynamicResource Admin.Field.FocusedBg.Color}"/>
    <SolidColorBrush x:Key="Admin.Selection.BgBrush" Color="{DynamicResource Admin.Selection.Bg.Color}"/>
    <SolidColorBrush x:Key="Admin.CellSelection.BgBrush" Color="{DynamicResource Admin.CellSelection.Bg.Color}"/>
    <SolidColorBrush x:Key="Admin.RowSelection.BgBrush" Color="{DynamicResource Admin.RowSelection.Bg.Color}"/>
    <SolidColorBrush x:Key="Admin.Field.HoverBorderBrush" Color="{DynamicResource Admin.Field.HoverBorder.Color}"/>
    <SolidColorBrush x:Key="Admin.RightSidebar.BgBrush" Color="{DynamicResource Admin.RightSidebar.Bg.Color}"/>
    <SolidColorBrush x:Key="Admin.Modal.OverlayBrush" Color="{DynamicResource Admin.Modal.Overlay.Color}"/>
    <SolidColorBrush x:Key="Admin.Loading.OverlayBrush" Color="{DynamicResource Admin.Loading.Overlay.Color}"/>
    <SolidColorBrush x:Key="Admin.Modal.Bg.StartBrush" Color="{DynamicResource Admin.Modal.Bg.Start.Color}"/>
    <SolidColorBrush x:Key="Admin.Modal.Bg.EndBrush" Color="{DynamicResource Admin.Modal.Bg.End.Color}"/>
    <SolidColorBrush x:Key="Admin.Modal.BorderBrush" Color="{DynamicResource Admin.Modal.Border.Color}"/>
    <SolidColorBrush x:Key="Admin.Details.CardBgBrush" Color="{DynamicResource Admin.Details.CardBg.Color}"/>
    <SolidColorBrush x:Key="Admin.Loading.PanelBgBrush" Color="{DynamicResource Admin.Loading.PanelBg.Color}"/>
    <SolidColorBrush x:Key="Admin.DangerZone.BgBrush" Color="{DynamicResource Admin.DangerZone.Bg.Color}"/>
    <SolidColorBrush x:Key="Admin.CloseButton.HoverBgBrush" Color="{DynamicResource Admin.CloseButton.HoverBg.Color}"/>

    <!-- Translucent Brushes -->
    <SolidColorBrush x:Key="Admin.Translucent.06" Color="{DynamicResource Admin.Translucent.06.Color}"/>
    <SolidColorBrush x:Key="Admin.Translucent.12" Color="{DynamicResource Admin.Translucent.12.Color}"/>
    <SolidColorBrush x:Key="Admin.Translucent.13" Color="{DynamicResource Admin.Translucent.13.Color}"/>
    <SolidColorBrush x:Key="Admin.Translucent.22" Color="{DynamicResource Admin.Translucent.22.Color}"/>
    <SolidColorBrush x:Key="Admin.Translucent.33" Color="{DynamicResource Admin.Translucent.33.Color}"/>
    <SolidColorBrush x:Key="Admin.Translucent.4D" Color="{DynamicResource Admin.Translucent.4D.Color}"/>
    <SolidColorBrush x:Key="Admin.Translucent.55" Color="{DynamicResource Admin.Translucent.55.Color}"/>

    <!-- Success Brushes -->
    <SolidColorBrush x:Key="Admin.Success" Color="{DynamicResource Admin.Success.Color}"/>
    <SolidColorBrush x:Key="Admin.Success.Translucent.11" Color="{DynamicResource Admin.Success.Translucent.11.Color}"/>
    <SolidColorBrush x:Key="Admin.Success.Translucent.22" Color="{DynamicResource Admin.Success.Translucent.22.Color}"/>
    <SolidColorBrush x:Key="Admin.Success.Translucent.33" Color="{DynamicResource Admin.Success.Translucent.33.Color}"/>
    <SolidColorBrush x:Key="Admin.Success.Translucent.44" Color="{DynamicResource Admin.Success.Translucent.44.Color}"/>

    <!-- Danger Brushes -->
    <SolidColorBrush x:Key="Admin.Danger" Color="{DynamicResource Admin.Danger.Color}"/>
    <SolidColorBrush x:Key="Admin.Danger.Translucent.22" Color="{DynamicResource Admin.Danger.Translucent.22.Color}"/>
    <SolidColorBrush x:Key="Admin.Danger.Translucent.33" Color="{DynamicResource Admin.Danger.Translucent.33.Color}"/>
    <SolidColorBrush x:Key="Admin.Danger.Translucent.44" Color="{DynamicResource Admin.Danger.Translucent.44.Color}"/>

    <!-- Yellow Brushes -->
    <SolidColorBrush x:Key="Admin.Yellow" Color="{DynamicResource Admin.Yellow.Color}"/>
    <SolidColorBrush x:Key="Admin.Yellow.Translucent.22" Color="{DynamicResource Admin.Yellow.Translucent.22.Color}"/>
    <SolidColorBrush x:Key="Admin.Yellow.Translucent.44" Color="{DynamicResource Admin.Yellow.Translucent.44.Color}"/>

    <!-- Purple Brushes -->
    <SolidColorBrush x:Key="Admin.Purple" Color="{DynamicResource Admin.Purple.Color}"/>
    <SolidColorBrush x:Key="Admin.Purple.Translucent.22" Color="{DynamicResource Admin.Purple.Translucent.22.Color}"/>
    <SolidColorBrush x:Key="Admin.Purple.Translucent.44" Color="{DynamicResource Admin.Purple.Translucent.44.Color}"/>

    <!-- Cyan Brushes -->
    <SolidColorBrush x:Key="Admin.Cyan" Color="{DynamicResource Admin.Cyan.Color}"/>
    <SolidColorBrush x:Key="Admin.Cyan.Translucent.22" Color="{DynamicResource Admin.Cyan.Translucent.22.Color}"/>
    <SolidColorBrush x:Key="Admin.Cyan.Translucent.33" Color="{DynamicResource Admin.Cyan.Translucent.33.Color}"/>
    <SolidColorBrush x:Key="Admin.Cyan.Translucent.44" Color="{DynamicResource Admin.Cyan.Translucent.44.Color}"/>
    <SolidColorBrush x:Key="Admin.WhiteBrush" Color="{DynamicResource Admin.White}"/>
    <SolidColorBrush x:Key="Admin.BlackBrush" Color="{DynamicResource Admin.Black}"/>
</ResourceDictionary>
