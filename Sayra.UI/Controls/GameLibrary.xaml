<UserControl x:Class="Sayra.UI.Controls.GameLibrary"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Sayra.UI.Controls"
             xmlns:vm="clr-namespace:Sayra.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <UserControl.DataContext>
        <vm:GameLibraryViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Modern Gaming Search TextBox Style -->
        <Style x:Key="ModernSearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryWhiteBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryYellowBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource PeydaLight}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="SearchBorder"
                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1.2"
                                CornerRadius="18"
                                Padding="14,0"
                                Height="36">
                            <Border.Effect>
                                <DropShadowEffect x:Name="ShadowEffect" Color="#ffff3d" BlurRadius="10" ShadowDepth="0" Opacity="0" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Specified SVG Search Icon with outline stroke 1.5 -->
                                <Path x:Name="SearchIcon"
                                      Grid.Column="0"
                                      Data="{DynamicResource SearchIconGeometry}"
                                      Stroke="{DynamicResource SecondaryWhiteBrush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="15" Height="15"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />

                                <!-- Text content / Placeholder container -->
                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                                    <TextBlock x:Name="Placeholder"
                                               Text="جستجوی بازی..."
                                               Foreground="#B39A9A9A"
                                               FontFamily="{StaticResource PeydaLight}"
                                               FontSize="13"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed" />
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="{DynamicResource PrimaryYellowBrush}" />
                                <Setter TargetName="SearchIcon" Property="Stroke" Value="{DynamicResource PrimaryYellowBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="{DynamicResource PrimaryYellowBrush}" />
                                <Setter TargetName="SearchIcon" Property="Stroke" Value="{DynamicResource PrimaryYellowBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ShadowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.4" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ShadowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.0" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Reusable Horizontal Category Filter Item Style -->
        <Style x:Key="HorizontalFilterListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect x:Name="ItemGlow" Color="#F5FF00" BlurRadius="12" ShadowDepth="0" Opacity="0" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <Path x:Name="ItemIcon"
                                      Grid.Column="0"
                                      Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                      Fill="#A1A1AA"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />

                                <!-- Text content -->
                                <ContentPresenter Grid.Column="1"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover state: subtle background & brighter text/icon -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#15FFFFFF" />
                                <Setter TargetName="ItemIcon" Property="Fill" Value="White" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>

                            <!-- Selected state: yellow accent background/glow, yellow text -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#25F5FF00" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#40F5FF00" />
                                <Setter TargetName="ItemIcon" Property="Fill" Value="#F5FF00" />
                                <Setter Property="Foreground" Value="#F5FF00" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ItemGlow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.3" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ItemGlow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <!-- Target standard TextBlock within ListBoxItem -->
                <Style TargetType="TextBlock">
                    <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="Foreground" Value="#E1E1E6" />
                </Style>
            </Style.Resources>
        </Style>

        <!-- Clean styling for horizontal ListBox to remove borders/scrollbars -->
        <Style x:Key="HorizontalFilterListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header & Search Area -->
            <RowDefinition Height="*" />    <!-- Games Grid Area -->
        </Grid.RowDefinitions>

        <!-- 1. HEADER & SEARCH AREA -->
        <Grid Grid.Row="0" Margin="11,24,11,20" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- Horizontal Filter Bar next to search (RTL -> Right side) -->
                <ColumnDefinition Width="*" />    <!-- Flexible spacer in the middle -->
                <ColumnDefinition Width="Auto" /> <!-- Search Box on the left (RTL -> Left side) -->
            </Grid.ColumnDefinitions>

            <!-- Custom Horizontal Category Bar on the Right side (RTL) -->
            <ListBox Grid.Column="0"
                     Style="{StaticResource HorizontalFilterListBoxStyle}"
                     SelectedValue="{Binding SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     SelectedValuePath="DataContext"
                     VerticalAlignment="Center">
                <!-- All Games -->
                <ListBoxItem Style="{StaticResource HorizontalFilterListBoxItemStyle}" IsSelected="True" DataContext="All"
                             Tag="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z">
                    <TextBlock Text="همه بازی‌ها" />
                </ListBoxItem>
                <!-- RPG -->
                <ListBoxItem Style="{StaticResource HorizontalFilterListBoxItemStyle}" DataContext="RPG"
                             Tag="M12,2C11.5,2 10,2.1 7,3C3,4.3 3,12 3,12C3,12 3,18.2 12,22C21,18.2 21,12 21,12C21,12 21,4.3 17,3C14,2.1 12.5,2 12,2M12,4C12.3,4 13.5,4.1 15.8,4.8C18.6,5.7 19,10.8 19,12C19,13.5 18,17 12,19.8C6,17 5,13.5 5,12C5,10.8 5.4,5.7 8.2,4.8C10.5,4.1 11.7,4 12,4M12,7V12H7V13H12V17H13V13H18V12H13V7H12Z">
                    <TextBlock Text="نقش آفرینی (RPG)" />
                </ListBoxItem>
                <!-- Action -->
                <ListBoxItem Style="{StaticResource HorizontalFilterListBoxItemStyle}" DataContext="Action"
                             Tag="M11.5,2H17L13.5,9H19L11,22V13H7L11.5,2Z">
                    <TextBlock Text="اکشن (Action)" />
                </ListBoxItem>
                <!-- Shooter -->
                <ListBoxItem Style="{StaticResource HorizontalFilterListBoxItemStyle}" DataContext="Shooter"
                             Tag="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z">
                    <TextBlock Text="شوتر (Shooter)" />
                </ListBoxItem>
                <!-- Racing -->
                <ListBoxItem Style="{StaticResource HorizontalFilterListBoxItemStyle}" DataContext="Racing"
                             Tag="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 19.3,9.5H15.9C15.4,7.8 13.9,6.5 12,6.1C10.1,6.5 8.6,7.8 8.1,9.5H4.7A8,8 0 0,1 12,4M4.1,11H8.5C9,12.5 10.3,13.6 12,13.9C13.7,13.6 15,12.5 15.5,11H19.9A8,8 0 0,1 12,20A8,8 0 0,1 4.1,11Z">
                    <TextBlock Text="مسابقه‌ای (Racing)" />
                </ListBoxItem>
                <!-- Installed -->
                <ListBoxItem Style="{StaticResource HorizontalFilterListBoxItemStyle}" DataContext="Installed"
                             Tag="M12 2C6.5 2 2 6.5 2 12S6.5 22 12 22 22 17.5 22 12 17.5 2 12 2M10 17L5 12L6.41 10.59L10 14.17L17.59 6.58L19 8L10 17Z">
                    <TextBlock Text="نصب شده" />
                </ListBoxItem>
            </ListBox>

            <!-- Search Box (Physically to the left of Filter Bar) -->
            <TextBox Grid.Column="2"
                     Style="{StaticResource ModernSearchTextBoxStyle}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="294"
                     Margin="0"
                     VerticalAlignment="Center" />
        </Grid>

        <!-- 2. GAMES GRID AREA -->
        <ScrollViewer x:Name="LibraryScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
            <ItemsControl ItemsSource="{Binding Games}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- Responsive grid layout adapting to available width -->
                        <UniformGrid Columns="{Binding GridColumns, RelativeSource={RelativeSource AncestorType=UserControl}}" VerticalAlignment="Top" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Cards margins adjusted to achieve horizontal gap of 22px and vertical gap of 28px -->
                        <local:GameCard Title="{Binding Title}"
                                        Genre="{Binding Genre}"
                                        ImagePath="{Binding ImagePath}"
                                        Status="{Binding Status}"
                                        IsSelected="{Binding IsSelected, Mode=TwoWay}"
                                        IsAvailable="{Binding IsAvailable}"
                                        PlayCommand="{Binding DataContext.PlayGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Margin="11,14" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
