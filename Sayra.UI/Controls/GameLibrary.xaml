<UserControl x:Class="Sayra.UI.Controls.GameLibrary"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Sayra.UI.Controls"
             xmlns:vm="clr-namespace:Sayra.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <UserControl.DataContext>
        <vm:GameLibraryViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Modern Gaming Search TextBox Style -->
        <Style x:Key="ModernSearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="CaretBrush" Value="#F5FF00" />
            <Setter Property="FontFamily" Value="{StaticResource PeydaLight}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="SearchBorder"
                                Background="#0DFFFFFF"
                                BorderBrush="#1EFFFFFF"
                                BorderThickness="1.2"
                                CornerRadius="20"
                                Padding="16,10"
                                Height="48">
                            <Border.Effect>
                                <DropShadowEffect x:Name="ShadowEffect" Color="#F5FF00" BlurRadius="10" ShadowDepth="0" Opacity="0" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Gray / Yellow Search Icon -->
                                <Path x:Name="SearchIcon"
                                      Grid.Column="0"
                                      Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                                      Fill="#A1A1AA"
                                      Width="18" Height="18"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0" />

                                <!-- Text content / Placeholder container -->
                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                                    <TextBlock x:Name="Placeholder"
                                               Text="جستجوی بازی..."
                                               Foreground="#B3FFFFFF"
                                               FontFamily="{StaticResource PeydaLight}"
                                               FontSize="15"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed" />
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="#40FFFFFF" />
                                <Setter TargetName="SearchIcon" Property="Fill" Value="#D1D1D6" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SearchBorder" Property="BorderBrush" Value="#F5FF00" />
                                <Setter TargetName="SearchIcon" Property="Fill" Value="#F5FF00" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ShadowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.4" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ShadowEffect"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.0" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header & Search Area -->
            <RowDefinition Height="*" />    <!-- Games Grid Area -->
        </Grid.RowDefinitions>

        <!-- 1. HEADER & SEARCH AREA -->
        <Grid Grid.Row="0" Margin="0,24,0,20" HorizontalAlignment="Stretch">
            <!-- Search Box (End of RTL -> Physical Left) -->
            <TextBox Style="{StaticResource ModernSearchTextBoxStyle}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="420"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Center" />
        </Grid>

        <!-- 2. GAMES GRID AREA -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Games}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- Responsive grid layout adapting to available width -->
                        <UniformGrid Columns="{Binding GridColumns, RelativeSource={RelativeSource AncestorType=UserControl}}" VerticalAlignment="Top" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Cards margins adjusted to achieve horizontal gap of 22px and vertical gap of 28px -->
                        <local:GameCard Title="{Binding Title}"
                                        Genre="{Binding Genre}"
                                        ImagePath="{Binding ImagePath}"
                                        Status="{Binding Status}"
                                        IsSelected="{Binding IsSelected, Mode=TwoWay}"
                                        IsAvailable="{Binding IsAvailable}"
                                        PlayCommand="{Binding DataContext.PlayGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Margin="11,14" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
