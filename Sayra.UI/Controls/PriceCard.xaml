<UserControl x:Class="Sayra.UI.Controls.PriceCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Border Style="{StaticResource GlassCard}" Padding="20,15" MinWidth="180">
        <StackPanel>
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource SecondaryText}" FontSize="14" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Style="{StaticResource HeadingText}" FontSize="20" Foreground="{StaticResource PrimaryTextBrush}"/>
                <Path Data="M12 2L2 7L12 12L22 7L12 2Z" Fill="{StaticResource AccentYellowBrush}"
                      Width="16" Height="16" Stretch="Uniform" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
