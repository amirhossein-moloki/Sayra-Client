<UserControl x:Class="Sayra.UI.Controls.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d"
             d:DesignHeight="85" d:DesignWidth="1920">

    <UserControl.Resources>
        <!-- Header Svg Logo Style -->
        <Style x:Key="HeaderLogoStyle" TargetType="svgc:SvgViewbox">
            <!-- No yellow DropShadowEffect glow on Sayra Logo header -->
        </Style>

        <!-- Circular Red Power Button Style -->
        <Style x:Key="CircularPowerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Width="40"
                                Height="40">
                            <Border.Effect>
                                <DropShadowEffect x:Name="glow" Color="#F46B6B" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <!-- Power icon path (End Session Button Icon) -->
                            <Path x:Name="icon"
                                  Data="M5.636 5.636a9 9 0 1 0 12.728 0M12 3v9"
                                  Stroke="{DynamicResource RedBrush}"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1AF46B6B"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                             To="15" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                             To="0.8" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                             To="0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                             To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="0.9" Duration="0:0:0.05"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="0.9" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Header Regular Button Style -->
        <Style x:Key="HeaderRegularButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#66FFFFFF"/>
                                <Setter Property="Foreground" Value="#F5FF00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4DFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Header Admin Panel Button Style -->
        <Style x:Key="HeaderAdminPanelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1AF5FF00"/>
            <Setter Property="Foreground" Value="#F5FF00"/>
            <Setter Property="BorderBrush" Value="#44F5FF00"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaBold}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33F5FF00"/>
                                <Setter Property="BorderBrush" Value="#F5FF00"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4DF5FF00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Glassmorphic panel with thin border, dark transparent color -->
    <Border Background="{DynamicResource GlassPanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            CornerRadius="0"
            Height="85">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.45"/>
        </Border.Effect>

        <Grid Margin="30,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" /> <!-- Left SAYRA Logo Area -->
                <ColumnDefinition Width="2*" /> <!-- Center PC identity & status badge -->
                <ColumnDefinition Width="1*" /> <!-- Right Time & Date / Power control -->
            </Grid.ColumnDefinitions>

            <!-- LEFT AREA: SAYRA Logo -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <svgc:SvgViewbox Source="/Assets/sayra.svg"
                                 Width="140"
                                 Style="{StaticResource HeaderLogoStyle}"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center" />
            </StackPanel>

            <!-- CENTER AREA: PC identity section + status badge -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="PC-08"
                           FontFamily="{StaticResource PeydaBold}"
                           FontSize="22"
                           Foreground="White"
                           VerticalAlignment="Center" />
                <Border BorderBrush="{DynamicResource SuccessBrush}"
                        BorderThickness="1.2"
                        CornerRadius="14"
                        Padding="14,5"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Background="#0814BE78">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Connected"
                                   FontFamily="{StaticResource PeydaMedium}"
                                   FontSize="14"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT AREA: Time and power controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <!-- Admin Panel Button (ONLY visible when App.IsAdminLoggedIn is true) -->
                <Button x:Name="AdminPanelButton"
                        Content="پنل مدیریت"
                        Click="AdminPanelButton_Click"
                        Style="{StaticResource HeaderAdminPanelButtonStyle}"
                        Height="36" Padding="14,0" Margin="0,0,12,0"
                        Visibility="Collapsed"/>

                <!-- Logout Button -->
                <Button x:Name="LogoutButton"
                        Content="خروج از حساب"
                        Click="LogoutButton_Click"
                        Style="{StaticResource HeaderRegularButtonStyle}"
                        Height="36" Padding="14,0" Margin="0,0,20,0"/>

                <!-- Time & Date Stack -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <TextBlock x:Name="TimeText"
                               Text="14:26"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="20"
                               Foreground="White"
                               HorizontalAlignment="Right" />
                    <TextBlock x:Name="DateText"
                               Text="1405/04/15"
                               FontFamily="{StaticResource PeydaLight}"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryWhiteBrush}"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,0" />
                </StackPanel>

                <!-- Power Button -->
                <Button Style="{StaticResource CircularPowerButtonStyle}" Click="PowerButton_Click" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
