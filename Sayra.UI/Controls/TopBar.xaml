<UserControl x:Class="Sayra.UI.Controls.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d"
             d:DesignHeight="85" d:DesignWidth="1920">

    <UserControl.Resources>
        <!-- Breathing effect for SAYRA Logo glow in header -->
        <Style x:Key="HeaderLogoStyle" TargetType="svgc:SvgViewbox">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect x:Name="HeaderLogoGlow" Color="#F5FF00" BlurRadius="12" ShadowDepth="0" Opacity="0.45"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                             From="0.3" To="0.75" Duration="0:0:3" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                             From="10" To="25" Duration="0:0:3" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Circular Red Power Button Style -->
        <Style x:Key="CircularPowerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1AEF4444"/>
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Width="40"
                                Height="40">
                            <Border.Effect>
                                <DropShadowEffect x:Name="glow" Color="#EF4444" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <!-- Power icon path -->
                            <Path x:Name="icon"
                                  Data="M12,2V12 M16.24,7.76A6,6 0 1,1 7.76,7.76"
                                  Stroke="#EF4444"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33EF4444"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                             To="15" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                             To="0.8" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                             To="0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                             To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="0.9" Duration="0:0:0.05"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="0.9" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Glassmorphic panel with slight bottom corners rounded, thin border, dark transparent color -->
    <Border Background="{DynamicResource GlassPanelBrush}"
            BorderBrush="#1AFFFFFF"
            BorderThickness="0,0,0,1"
            CornerRadius="0,0,24,24"
            Height="85">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.45"/>
        </Border.Effect>

        <Grid Margin="30,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" /> <!-- Left SAYRA Logo Area -->
                <ColumnDefinition Width="2*" /> <!-- Center PC identity & status badge -->
                <ColumnDefinition Width="1*" /> <!-- Right Time & Date / Power control -->
            </Grid.ColumnDefinitions>

            <!-- LEFT AREA: SAYRA Logo with subtle yellow glow -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <svgc:SvgViewbox Source="/Assets/sayra.svg"
                                 Width="140"
                                 Style="{StaticResource HeaderLogoStyle}"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center" />
            </StackPanel>

            <!-- CENTER AREA: PC identity section + status badge -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="PC-08"
                           FontFamily="{StaticResource PeydaMedium}"
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center" />
                <Border BorderBrush="#22C55E"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,2"
                        Margin="0,5,0,0"
                        HorizontalAlignment="Center"
                        Background="#0822C55E">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Connected"
                                   FontFamily="{StaticResource PeydaMedium}"
                                   FontSize="11"
                                   Foreground="#22C55E"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT AREA: Time and power controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <!-- Time & Date Stack -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <TextBlock x:Name="TimeText"
                               Text="14:26"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="20"
                               Foreground="White"
                               HorizontalAlignment="Right" />
                    <TextBlock x:Name="DateText"
                               Text="1405/04/15"
                               FontFamily="{StaticResource PeydaLight}"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,0" />
                </StackPanel>

                <!-- Power Button -->
                <Button Style="{StaticResource CircularPowerButtonStyle}" Click="PowerButton_Click" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
