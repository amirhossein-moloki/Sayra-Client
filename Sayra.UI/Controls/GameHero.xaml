<UserControl x:Class="Sayra.UI.Controls.GameHero"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Sayra.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="406" d:DesignWidth="1296">

    <!-- Large Box (Game Details - Width: 1296, Height: 406, CornerRadius: 20, Border: 1) -->
    <Border Style="{DynamicResource GameInfoCardStyle}" Height="406">
        <Grid FlowDirection="RightToLeft">
            <Grid.ColumnDefinitions>
                <!-- Right Column of the box (RTL Column 0): Name, Genre, Description, Play Button -->
                <ColumnDefinition Width="*" />
                <!-- Spacer -->
                <ColumnDefinition Width="30" />
                <!-- Left Column of the box (RTL Column 2): Cover Image, Title, Genre -->
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left Column Content: Cover Image ONLY -->
            <Border Grid.Column="2" CornerRadius="16" Width="248" VerticalAlignment="Stretch" BorderThickness="1.5" BorderBrush="{DynamicResource GameDetail.Border}" Background="{DynamicResource GameDetail.CardBackground}" ClipToBounds="True" HorizontalAlignment="Left" Margin="0,10,0,10">
                <Grid Background="{DynamicResource GameDetail.CoverPlaceholderBackground}">
                    <!-- Gamepad Fallback Vector Graphic -->
                    <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                          Fill="{DynamicResource GameDetail.GamepadIconFill}"
                          Width="50" Height="50"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
                    <Image x:Name="DetailCoverImage" Stretch="UniformToFill" ImageFailed="DetailCoverImage_ImageFailed"/>
                </Grid>
            </Border>

            <!-- Right Column Content -->
            <Grid Grid.Column="0" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Title / Genre & Logo Segment -->
                    <RowDefinition Height="*" />    <!-- Description Segment -->
                    <RowDefinition Height="Auto" /> <!-- Rich Metadata Segment (Developer, Year, Launcher) -->
                    <RowDefinition Height="Auto" /> <!-- Play / Status Button -->
                </Grid.RowDefinitions>

                <!-- Title / Genre Stack on the right, and high resolution logo on the left (RTL) -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Title and Genre Stack -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock x:Name="DetailTitle"
                                   Style="{DynamicResource GameHeroTitleStyle}" />
                        <TextBlock x:Name="DetailGenre"
                                   Style="{DynamicResource GameHeroGenreStyle}" />
                    </StackPanel>

                    <!-- High-resolution Game Logo -->
                    <Image x:Name="DetailLogoImage"
                           Grid.Column="0"
                           Height="60"
                           MaxWidth="240"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="1" Opacity="0.5"/>
                        </Image.Effect>
                    </Image>
                </Grid>

                <!-- Description Segment -->
                <TextBlock x:Name="DetailDescription"
                           Grid.Row="1"
                           Style="{DynamicResource GameHeroDescriptionStyle}"/>

                <!-- Rich Metadata Segment (Developer, Release Year, Launcher Badge) -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" FlowDirection="RightToLeft" Margin="0,0,0,20">
                    <!-- Developer Pill -->
                    <local:GameBadge x:Name="DeveloperBadge" Style="{DynamicResource CategoryBadgeStyle}" HasLabel="True" Label="سازنده: " Margin="0,0,10,0"/>

                    <!-- Year Pill -->
                    <local:GameBadge x:Name="ReleaseYearBadge" Style="{DynamicResource CategoryBadgeStyle}" HasLabel="True" Label="سال انتشار: " Margin="0,0,10,0"/>

                    <!-- Launcher Platform Pill -->
                    <local:GameBadge x:Name="LauncherBadge" Style="{DynamicResource GenreBadgeStyle}" HasLabel="True" Label="لانچر: " TextForeground="{DynamicResource GameDetail.Highlight}"/>
                </StackPanel>

                <!-- Game Status Badge / Button -->
                <Button Grid.Row="3"
                        x:Name="PlayButton"
                        Style="{DynamicResource PrimaryActionButtonStyle}"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Right"
                        Padding="0"
                        Cursor="Hand"
                        Margin="0,0,0,10">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Button.Template>
                    <!-- Content of Button is the Status Badge border -->
                    <Border x:Name="StatusBadgeBorder"
                            Width="288"
                            Height="50"
                            Style="{DynamicResource StatusBadgeStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusBadgeDot" Width="8" Height="8" Fill="{DynamicResource GameDetail.Status.SuccessBorder}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="DetailStatus"
                                       Text="وضعیت"
                                       FontFamily="{StaticResource PeydaMedium}"
                                       FontSize="15"
                                       Foreground="{DynamicResource GameDetail.Status.SuccessBorder}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
