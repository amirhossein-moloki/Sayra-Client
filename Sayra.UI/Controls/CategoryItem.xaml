<UserControl x:Class="Sayra.UI.Controls.CategoryItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="228"
             d:DesignHeight="42"
             Width="228"
             Height="42"
             Background="Transparent">

    <Border CornerRadius="8"
            Background="Transparent"
            BorderThickness="0"
            Padding="12,10,12,10">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <!-- Area 1: Icon Container (Width: 20px) -->
                <ColumnDefinition Width="20" />
                <!-- Gap: 12px -->
                <ColumnDefinition Width="12" />
                <!-- Area 2: Text Container (Flexible Width) -->
                <ColumnDefinition Width="*" />
                <!-- Area 3: Badge Placeholder (Width: 28px) -->
                <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>

            <!-- Area 1: Icon Placeholder -->
            <Rectangle Grid.Column="0"
                       Width="20"
                       Height="20"
                       Stroke="#303641"
                       StrokeThickness="1"
                       StrokeDashArray="3,3"
                       Fill="Transparent"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <!-- Area 2: Text Container & Placeholder -->
            <Grid Grid.Column="2"
                  Height="20"
                  VerticalAlignment="Center">
                <Rectangle Width="110"
                           Height="14"
                           RadiusX="3"
                           RadiusY="3"
                           Stroke="#303641"
                           StrokeThickness="1"
                           StrokeDashArray="3,3"
                           Fill="Transparent"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Area 3: Badge Placeholder -->
            <Rectangle Grid.Column="3"
                       Width="28"
                       Height="22"
                       RadiusX="11"
                       RadiusY="11"
                       Stroke="#303641"
                       StrokeThickness="1"
                       StrokeDashArray="3,3"
                       Fill="Transparent"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center" />
        </Grid>
    </Border>
</UserControl>
