<UserControl x:Class="Sayra.UI.Controls.GameBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="self"
             d:DesignHeight="50" d:DesignWidth="150">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Border x:Name="BadgeBorder" Style="{Binding BadgeStyle, ElementName=self}"
            Background="{Binding BadgeBackground, ElementName=self}"
            BorderBrush="{Binding BadgeBorderBrush, ElementName=self}"
            BorderThickness="{Binding BadgeBorderThickness, ElementName=self}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Optional Status Dot -->
            <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center"
                     Fill="{Binding DotBrush, ElementName=self}"
                     Visibility="{Binding HasDot, ElementName=self, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>

            <!-- Label (e.g. "سازنده: ") -->
            <TextBlock x:Name="LabelText" Text="{Binding Label, ElementName=self}"
                       FontFamily="{StaticResource PeydaMedium}" FontSize="13"
                       Foreground="{DynamicResource GameDetail.TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"
                       Visibility="{Binding HasLabel, ElementName=self, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>

            <!-- Value Text -->
            <TextBlock x:Name="ValueText" Text="{Binding Text, ElementName=self}"
                       FontFamily="{StaticResource PeydaBold}" FontSize="13"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{Binding TextForeground, ElementName=self}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TextForeground, ElementName=self}" Value="{x:Null}">
                                <Setter Property="Foreground" Value="{DynamicResource GameDetail.TextPrimary}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Border>
</UserControl>
