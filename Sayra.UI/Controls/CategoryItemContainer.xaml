<UserControl x:Class="Sayra.UI.Controls.CategoryItemContainer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="228"
             d:DesignHeight="42"
             Width="228"
             Height="42"
             Background="Transparent">

    <Border CornerRadius="8"
            Background="Transparent"
            BorderThickness="0"
            Padding="12,10,12,10">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <!-- Zone 1: Icon Area (Width: 20px) -->
                <ColumnDefinition Width="20" />
                <!-- Gap: 12px -->
                <ColumnDefinition Width="12" />
                <!-- Zone 2: Flexible Text Area (Flexible Width) -->
                <ColumnDefinition Width="*" />
                <!-- Zone 3: Badge Area (Width: 28px) -->
                <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>

            <!-- Zone 1: Icon Content -->
            <ContentPresenter Grid.Column="0"
                              Content="{Binding IconContent, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              Width="20"
                              Height="20"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />

            <!-- Zone 2: Flexible Text Content -->
            <ContentPresenter Grid.Column="2"
                              Content="{Binding TextContent, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center" />

            <!-- Zone 3: Badge Content -->
            <ContentPresenter Grid.Column="3"
                              Content="{Binding BadgeContent, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              Width="28"
                              Height="22"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center" />
        </Grid>
    </Border>
</UserControl>
