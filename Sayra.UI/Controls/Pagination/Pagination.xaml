<UserControl x:Class="Sayra.UI.Controls.Pagination"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="self"
             d:DesignHeight="50" d:DesignWidth="1000"
             SizeChanged="Pagination_SizeChanged">

    <UserControl.Resources>
        <!-- Pagination Button Style -->
        <Style x:Key="PaginationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#14161C"/>
            <Setter Property="Foreground" Value="#9A9A9A"/>
            <Setter Property="BorderBrush" Value="#2A2D36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252A34"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#ffff3d"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#101215"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#10FFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#10FFFFFF"/>
                                <Setter Property="Foreground" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active Pagination Button Style -->
        <Style x:Key="ActivePaginationButtonStyle" TargetType="Button" BasedOn="{StaticResource PaginationButtonStyle}">
            <Setter Property="Background" Value="#252A34"/>
            <Setter Property="Foreground" Value="#ffff3d"/>
            <Setter Property="BorderBrush" Value="#ffff3d"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaBold}"/>
        </Style>

        <!-- Arrow Button Style -->
        <Style x:Key="ArrowButtonStyle" TargetType="Button" BasedOn="{StaticResource PaginationButtonStyle}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Dropdown Box Style -->
        <Style x:Key="PaginationComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="#14161C"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Textbox Style -->
        <Style x:Key="PaginationTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#14161C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2D36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#ffff3d"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#ffff3d"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#ffff3d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <!-- Left: Info Text -->
            <ColumnDefinition Width="*" />
            <!-- Right: Controls -->
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Left info section -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Showing description -->
            <TextBlock x:Name="InfoTextBlock"
                       Text="Showing 1-25 of 128 records"
                       Foreground="#9A9A9A"
                       FontSize="11"
                       FontFamily="{StaticResource PeydaMedium}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Right pagination & navigation controls -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">

            <!-- 1. Rows per page selector -->
            <StackPanel x:Name="RowsPerPagePanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="Rows per page:"
                           Foreground="#9A9A9A"
                           FontSize="11"
                           FontFamily="{StaticResource PeydaMedium}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox x:Name="PageSizeComboBox"
                          Style="{StaticResource PaginationComboBoxStyle}"
                          Width="60"
                          SelectionChanged="PageSizeComboBox_SelectionChanged">
                    <ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="20" IsSelected="True"/>
                    <ComboBoxItem Content="50"/>
                    <ComboBoxItem Content="100"/>
                </ComboBox>
            </StackPanel>

            <!-- 2. Navigation & Page Buttons -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Prev Button -->
                <Button x:Name="PrevButton"
                        Style="{StaticResource ArrowButtonStyle}"
                        Click="PrevButton_Click"
                        ToolTip="Previous Page">
                    <Path Data="M15 18l-6-6 6-6" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="8" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Page Number Buttons ItemsControl -->
                <ItemsControl x:Name="PageButtonsItemsControl" Margin="4,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,0">
                                <!-- Ellipsis or Clickable Button -->
                                <TextBlock Text="{Binding Text}"
                                           Foreground="#55FFFFFF"
                                           FontSize="11"
                                           FontFamily="{StaticResource PeydaMedium}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Margin="4,0"
                                           Visibility="{Binding IsEllipsisVisibility}"/>

                                <Button Content="{Binding Text}"
                                        Click="PageButton_Click"
                                        Visibility="{Binding IsButtonVisibility}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PaginationButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#252A34"/>
                                                    <Setter Property="Foreground" Value="#ffff3d"/>
                                                    <Setter Property="BorderBrush" Value="#ffff3d"/>
                                                    <Setter Property="FontFamily" Value="{StaticResource PeydaBold}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Next Button -->
                <Button x:Name="NextButton"
                        Style="{StaticResource ArrowButtonStyle}"
                        Click="NextButton_Click"
                        ToolTip="Next Page"
                        Margin="0,0,16,0">
                    <Path Data="M9 18l6-6-6-6" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="8" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>

            <!-- 3. Go to page inputs -->
            <StackPanel x:Name="JumpToPagePanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="Go to page:"
                           Foreground="#9A9A9A"
                           FontSize="11"
                           FontFamily="{StaticResource PeydaMedium}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox x:Name="JumpPageTextBox"
                         Style="{StaticResource PaginationTextBoxStyle}"
                         Width="40"
                         HorizontalContentAlignment="Center"
                         KeyDown="JumpPageTextBox_KeyDown"/>
                <Button x:Name="GoButton"
                        Content="Go"
                        Style="{StaticResource PaginationButtonStyle}"
                        Height="28"
                        Width="36"
                        Margin="4,0,0,0"
                        Click="GoButton_Click"/>
            </StackPanel>

            <!-- 4. Refresh Button -->
            <Button x:Name="RefreshButton"
                    Style="{StaticResource PaginationButtonStyle}"
                    Width="32"
                    Height="28"
                    Padding="0"
                    Click="RefreshButton_Click"
                    ToolTip="Refresh">
                <Path Data="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.5"
                      Fill="Transparent"
                      Width="12" Height="12"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>
