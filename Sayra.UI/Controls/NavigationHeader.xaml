<UserControl x:Class="Sayra.UI.Controls.NavigationHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="228"
             Height="65"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Top"
             Margin="0"
             Padding="4,0,4,0"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Collapse Navigation Button Style -->
        <Style x:Key="CollapseNavigationButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="Transparent" />
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <!-- Chevron Left Icon -->
                            <Path x:Name="icon"
                                  Data="M15 19l-7-7 7-7"
                                  Stroke="#BFC5D0"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#252932" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="Transparent" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#303641" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: Content Area (Height: 44px) -->
            <RowDefinition Height="44" />
            <!-- Row 1: Divider Margin Top (Height: 20px) -->
            <RowDefinition Height="20" />
            <!-- Row 2: Bottom Divider (Thickness: 1px) -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Content Area -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <!-- Title & Subtitle left-aligned -->
                <ColumnDefinition Width="*" />
                <!-- Compact Collapse Button right-aligned -->
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left Side: Title and Subtitle -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Categories"
                           FontFamily="Segoe UI Variable"
                           FontWeight="SemiBold"
                           FontSize="18"
                           Foreground="#FFFFFF"
                           MaxHeight="24"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Browse installed games and applications"
                           FontFamily="Segoe UI Variable"
                           FontWeight="Regular"
                           FontSize="12"
                           Foreground="#8E95A1"
                           MaxHeight="16"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,2,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Right Side: Collapse Navigation Button -->
            <Button Grid.Column="1"
                    Style="{StaticResource CollapseNavigationButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,-4,0"
                    Click="CollapseButton_Click" />
        </Grid>

        <!-- Bottom Divider -->
        <Border Grid.Row="2"
                Height="1"
                Background="#2B3039"
                HorizontalAlignment="Stretch"
                Margin="-4,0,-4,0" />
    </Grid>
</UserControl>
