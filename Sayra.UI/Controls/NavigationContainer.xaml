<UserControl x:Class="Sayra.UI.Controls.NavigationContainer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="260">
    <Grid>
        <!-- Main container Border -->
        <Border Width="260"
                Background="#171A20"
                BorderBrush="#2B3039"
                BorderThickness="0,0,1,0"
                CornerRadius="12"
                Padding="16,20,16,20">
            <Border.Effect>
                <DropShadowEffect Color="Black"
                                  Direction="270"
                                  ShadowDepth="2"
                                  BlurRadius="12"
                                  Opacity="0.12"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Block 1: Navigation Header Placeholder (Height: 44px, Gap Below: 20px) -->
                    <RowDefinition Height="44" />
                    <!-- Gap between Block 1 and Block 2: 20px -->
                    <RowDefinition Height="20" />
                    <!-- Block 2: Category List Placeholder (Flexible Height) -->
                    <RowDefinition Height="*" />
                    <!-- Block 3: Footer Placeholder (Height: 120px, Margin Top: 20px) -->
                    <RowDefinition Height="20" />
                    <RowDefinition Height="120" />
                </Grid.RowDefinitions>

                <!-- Block 1: Navigation Header Placeholder -->
                <Grid Grid.Row="0">
                    <!-- Empty placeholder for Navigation Header (Height: 44px) -->
                </Grid>

                <!-- Block 2: Category List Placeholder -->
                <Grid Grid.Row="2">
                    <!-- Dashed border representing the empty placeholder -->
                    <Rectangle Stroke="#303641"
                               StrokeThickness="1"
                               StrokeDashArray="4,4"
                               RadiusX="8"
                               RadiusY="8" />
                </Grid>

                <!-- Block 3: Footer Placeholder -->
                <Border Grid.Row="4"
                        BorderThickness="0,1,0,0"
                        BorderBrush="#2B3039">
                    <!-- Empty placeholder for Footer actions (Height: 120px) -->
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
