<UserControl x:Class="Sayra.UI.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Border Background="#1A22C55E" CornerRadius="12" Padding="12,4" BorderBrush="#3322C55E" BorderThickness="1">
        <StackPanel Orientation="Horizontal">
            <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessGreenBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="متصل" Foreground="{StaticResource SuccessGreenBrush}" FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
