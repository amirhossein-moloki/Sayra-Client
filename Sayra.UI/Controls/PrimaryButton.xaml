<UserControl x:Class="Sayra.UI.Controls.PrimaryButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="self"
             d:DesignHeight="60" d:DesignWidth="300">
    <UserControl.Resources>
        <!-- Futuristic Premium Button Style -->
        <Style x:Key="FuturisticButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brushes.Primary}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="FontFamily" Value="{StaticResource PeydaMedium}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <!-- Ensure the Border has a RenderTransform of ScaleTransform -->
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="BtnScaleTransform" ScaleX="1.0" ScaleY="1.0"/>
                            </Border.RenderTransform>
                            <!-- Use locally defined non-frozen Brush to allow Background color animation -->
                            <Border.Background>
                                <SolidColorBrush x:Name="BtnBackgroundBrush" Color="{DynamicResource Transparent}" />
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect x:Name="BtnGlow" Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="15" ShadowDepth="0" Opacity="0" />
                            </Border.Effect>

                            <Grid x:Name="ContentGrid" Margin="25,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- ContentPresenter Center Aligned -->
                                <ContentPresenter Grid.Column="0"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>

                                <!-- Futuristic sliding arrow on right -->
                                <Grid x:Name="ArrowGrid" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5,0,0,0">
                                    <Grid.RenderTransform>
                                        <TranslateTransform x:Name="ArrowTranslate" X="0"/>
                                    </Grid.RenderTransform>
                                    <Path x:Name="ArrowPath" Data="M1 1l4 4-4 4"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Width="8" Height="10"
                                          Stretch="Uniform">
                                        <Path.Stroke>
                                            <SolidColorBrush x:Name="ArrowStrokeBrush" Color="{DynamicResource Theme.Colors.Primary}" />
                                        </Path.Stroke>
                                    </Path>
                                </Grid>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Hover Trigger: Animate non-frozen background and stroke colors targeting named instances directly to prevent crashes -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="BtnBackgroundBrush" Storyboard.TargetProperty="Color"
                                                            To="{DynamicResource Theme.Brushes.Primary}" Duration="0:0:0.25"/>
                                            <ColorAnimation Storyboard.TargetName="ArrowStrokeBrush" Storyboard.TargetProperty="Color"
                                                            To="{DynamicResource Theme.Brushes.Surface.Card}" Duration="0:0:0.25"/>
                                            <ColorAnimation Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                            To="{DynamicResource Theme.Brushes.Surface.Card}" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnGlow" Storyboard.TargetProperty="Opacity"
                                                             To="0.8" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="ArrowTranslate" Storyboard.TargetProperty="X"
                                                             To="5" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="BtnBackgroundBrush" Storyboard.TargetProperty="Color"
                                                            To="{DynamicResource Transparent}" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="ArrowStrokeBrush" Storyboard.TargetProperty="Color"
                                                            To="{DynamicResource Theme.Brushes.Primary}" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                            To="{DynamicResource Theme.Brushes.Primary}" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnGlow" Storyboard.TargetProperty="Opacity"
                                                             To="0.0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="ArrowTranslate" Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- Pressed/Click: Smooth Scale Animation using the explicitly declared ScaleTransform -->
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnScaleTransform" Storyboard.TargetProperty="ScaleX"
                                                             To="0.96" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnScaleTransform" Storyboard.TargetProperty="ScaleY"
                                                             To="0.96" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnScaleTransform" Storyboard.TargetProperty="ScaleX"
                                                             To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnScaleTransform" Storyboard.TargetProperty="ScaleY"
                                                             To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Button Wrapper with locally declared non-frozen brush to avoid frozen brush exceptions -->
        <Button Content="{Binding ButtonContent, ElementName=self}"
                Command="{Binding Command, ElementName=self}"
                Style="{StaticResource FuturisticButtonStyle}">
            <Button.Foreground>
                <SolidColorBrush Color="{DynamicResource Theme.Colors.Primary}" />
            </Button.Foreground>
        </Button>
    </Grid>
</UserControl>
