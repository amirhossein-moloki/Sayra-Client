<UserControl x:Class="Sayra.UI.Controls.GameCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="self"
             Width="180" Height="265">

    <Grid MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
        <!-- Root Card Border -->
        <Border x:Name="CardBorder"
                BorderThickness="1.5"
                CornerRadius="20"
                Background="#0DFFFFFF"
                RenderTransformOrigin="0.5,0.5">
            <Border.BorderBrush>
                <SolidColorBrush x:Name="CardBorderBrushInstance" Color="#1FFFFFFF" />
            </Border.BorderBrush>
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScaleTransform" ScaleX="1.0" ScaleY="1.0" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect x:Name="CardShadowInstance" Color="#000000" BlurRadius="15" ShadowDepth="4" Opacity="0.5" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="155" /> <!-- Cover Image Area -->
                    <RowDefinition Height="*" />   <!-- Text & Button Area -->
                </Grid.RowDefinitions>

                <!-- 1. COVER IMAGE AREA with top rounded corners -->
                <Border Grid.Row="0" CornerRadius="18,18,0,0" ClipToBounds="True" Background="#15FFFFFF">
                    <Grid>
                        <!-- Fallback Placeholder Gamepad Icon -->
                        <Grid Background="#10FFFFFF">
                            <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                  Fill="#33FFFFFF"
                                  Width="48" Height="48"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Grid>

                        <!-- Game Cover Image -->
                        <Image x:Name="CoverImage"
                               Source="{Binding ImagePath, ElementName=self, TargetNullValue={x:Null}, FallbackValue={x:Null}}"
                               ImageFailed="CoverImage_ImageFailed"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality" />

                        <!-- Dark Cinematic Gradient Overlay to blend image into the card -->
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#0008090D" Offset="0.0" />
                                    <GradientStop Color="#4408090D" Offset="0.5" />
                                    <GradientStop Color="#FF121318" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>

                <!-- 2. CARD BODY (Title, Genre, Play Button) -->
                <Grid Grid.Row="1" Margin="14,8,14,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Title -->
                        <RowDefinition Height="Auto" /> <!-- Genre -->
                        <RowDefinition Height="*" />    <!-- Space/Button -->
                    </Grid.RowDefinitions>

                    <!-- Game Title (Peyda Bold, White, Single Line) -->
                    <TextBlock Grid.Row="0"
                               Text="{Binding Title, ElementName=self}"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="15"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Right" />

                    <!-- Genre (Peyda Light, Gray, Smaller) -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding Genre, ElementName=self}"
                               FontFamily="{StaticResource PeydaLight}"
                               FontSize="11"
                               Foreground="#A1A1AA"
                               Margin="0,3,0,0"
                               HorizontalAlignment="Right" />

                    <!-- Play Button (Yellow Accent) -->
                    <Grid Grid.Row="2" VerticalAlignment="Bottom" Margin="0,8,0,0">
                        <Button Content="PLAY"
                                Style="{StaticResource GameCardPlayButtonStyle}"
                                Command="{Binding PlayCommand, ElementName=self}"
                                CommandParameter="{Binding ElementName=self}"
                                IsEnabled="{Binding IsAvailable, ElementName=self}"
                                Height="34"
                                HorizontalAlignment="Stretch" />
                    </Grid>
                </Grid>

                <!-- 3. SELECTED STATE HIGHLIGHT INDICATOR -->
                <Border x:Name="SelectedIndicator"
                        Background="#F5FF00"
                        CornerRadius="4"
                        Height="8" Width="8"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="12"
                        Opacity="0.0">
                    <Border.Effect>
                        <DropShadowEffect Color="#F5FF00" BlurRadius="8" ShadowDepth="0" Opacity="1.0" />
                    </Border.Effect>
                </Border>

                <!-- 4. DISABLED OVERLAY -->
                <Border x:Name="DisabledOverlay"
                        Grid.RowSpan="2"
                        Background="#99000000"
                        CornerRadius="20"
                        Opacity="0.0"
                        IsHitTestVisible="False" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
