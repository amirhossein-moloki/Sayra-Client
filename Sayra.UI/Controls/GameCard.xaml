<UserControl x:Class="Sayra.UI.Controls.GameCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="self"
             Width="188" Height="288">

    <Grid MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave" PreviewMouseLeftButtonUp="Card_PreviewMouseLeftButtonUp">
        <!-- Root Card Border: Background: #1F1F23, Border: #252528, CornerRadius: 5px -->
        <Border x:Name="CardBorder"
                BorderThickness="1.5"
                CornerRadius="8"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                ClipToBounds="True"
                RenderTransformOrigin="0.5,0.5">
            <Border.BorderBrush>
                <SolidColorBrush x:Name="CardBorderBrushInstance" Color="{DynamicResource Theme.Colors.Border.Default}" />
            </Border.BorderBrush>
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScaleTransform" ScaleX="1.0" ScaleY="1.0" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect x:Name="CardShadowInstance" Color="{DynamicResource Theme.Colors.Shadow}" BlurRadius="15" ShadowDepth="4" Opacity="0.5" />
            </Border.Effect>

            <Grid>
                <!-- 1. COVER IMAGE AREA filling entire card background: CornerRadius 8px to avoid overflow -->
                <Border CornerRadius="8" ClipToBounds="True" Background="{DynamicResource Theme.Brushes.White.Opacity10}">
                    <Grid>
                        <!-- Fallback Placeholder Gamepad Icon -->
                        <Grid Background="{DynamicResource Theme.Brushes.White.Opacity10}">
                            <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                  Fill="{DynamicResource Theme.Brushes.White.Opacity20}"
                                  Width="50" Height="50"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Grid>

                        <!-- Game Cover Image (High quality crop, no stretch) -->
                        <Image x:Name="CoverImage"
                               ImageFailed="CoverImage_ImageFailed"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality" />

                        <!-- Subtle bottom gradient overlay for text readability -->
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#00000000" Offset="0.0" />
                                    <GradientStop Color="#00000000" Offset="0.3" />
                                    <GradientStop Color="#B3101014" Offset="0.65" />
                                    <GradientStop Color="#FB101014" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>

                <!-- 2. HIGH RESOLUTION TRANSPARENT LOGO (Floating on Top Center) -->
                <Image Source="{Binding DataContext.LogoImage, ElementName=self}"
                       Height="32"
                       MaxWidth="130"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="0,16,0,0"
                       Stretch="Uniform"
                       IsHitTestVisible="False"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.8" />
                    </Image.Effect>
                </Image>

                <!-- 3. SMALL LAUNCHER BADGE (Secondary Info) -->
                <Border x:Name="LauncherBadge"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Left"
                        Margin="10"
                        Padding="6,2"
                        CornerRadius="5"
                        Background="#CC101014"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource Theme.Brushes.White.Opacity20}"
                        IsHitTestVisible="False">
                    <TextBlock x:Name="LauncherText"
                               Text="{Binding DataContext.Launcher, ElementName=self}"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="9"
                               Foreground="{DynamicResource SecondaryWhiteBrush}"
                               VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0.5" Opacity="0.5" />
                        </TextBlock.Effect>
                    </TextBlock>
                </Border>

                <!-- 4. DISABLED OVERLAY (Placed behind Card Body so texts/buttons are not obscured) -->
                <Border x:Name="DisabledOverlay"
                        Background="#99101014"
                        CornerRadius="8"
                        Opacity="0.0"
                        IsHitTestVisible="False" />

                <!-- 5. CARD BODY overlaying the cover image at the bottom -->
                <Grid VerticalAlignment="Bottom" Margin="10,0,10,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Title -->
                        <RowDefinition Height="Auto" /> <!-- Genre & Release Year -->
                        <RowDefinition Height="Auto" /> <!-- Developer / Publisher -->
                        <RowDefinition Height="Auto" /> <!-- Play Button -->
                    </Grid.RowDefinitions>

                    <!-- Game Title (Peyda Bold, White, Single Line with Shadow) -->
                    <TextBlock Grid.Row="0"
                               Text="{Binding Title, ElementName=self}"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="15"
                               Foreground="{DynamicResource DarkerWhiteBrush}"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Right">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1.5" Opacity="0.8" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Genre & Release Year (Peyda Light, Secondary White color with Shadow) -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding DataContext.GenreAndYear, ElementName=self}"
                               FontFamily="{StaticResource PeydaLight}"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryWhiteBrush}"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Right">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1" Opacity="0.8" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Developer / Publisher (Elegant, smaller, semi-transparent text) -->
                    <TextBlock Grid.Row="2"
                               Text="{Binding DataContext.Developer, ElementName=self}"
                               FontFamily="{StaticResource PeydaLight}"
                               FontSize="9"
                               Foreground="#B0E1E1E6"
                               Margin="0,1,0,0"
                               HorizontalAlignment="Right">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1" Opacity="0.8" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Play Button (Yellow Accent) -->
                    <Grid Grid.Row="3" Margin="0,8,0,0" Height="36">
                        <Button Content="{Binding ButtonText, ElementName=self}"
                                Style="{StaticResource GameCardPlayButtonStyle}"
                                Command="{Binding PlayCommand, ElementName=self}"
                                CommandParameter="{Binding DataContext, ElementName=self}"
                                IsEnabled="{Binding IsAvailable, ElementName=self}"
                                Tag="{Binding IsSelected, ElementName=self}"
                                HorizontalAlignment="Stretch" />
                    </Grid>
                </Grid>

                <!-- 6. SELECTED STATE HIGHLIGHT INDICATOR -->
                <Border x:Name="SelectedIndicator"
                        Background="{DynamicResource PrimaryYellowBrush}"
                        CornerRadius="4"
                        Height="8" Width="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="12"
                        Opacity="0.0">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="8" ShadowDepth="0" Opacity="1.0" />
                    </Border.Effect>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
