<UserControl x:Class="Sayra.UI.Controls.GameCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="self"
             Width="150" Height="230">

    <Grid MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
        <!-- Root Card Border: CornerRadius set to subtle 5px -->
        <Border x:Name="CardBorder"
                BorderThickness="1.5"
                CornerRadius="5"
                Background="#0DFFFFFF"
                ClipToBounds="True"
                RenderTransformOrigin="0.5,0.5">
            <Border.BorderBrush>
                <SolidColorBrush x:Name="CardBorderBrushInstance" Color="#1FFFFFFF" />
            </Border.BorderBrush>
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScaleTransform" ScaleX="1.0" ScaleY="1.0" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect x:Name="CardShadowInstance" Color="#000000" BlurRadius="15" ShadowDepth="4" Opacity="0.5" />
            </Border.Effect>

            <Grid>
                <!-- 1. COVER IMAGE AREA filling entire card background: CornerRadius 5px to avoid overflow -->
                <Border CornerRadius="5" ClipToBounds="True" Background="#15FFFFFF">
                    <Grid>
                        <!-- Fallback Placeholder Gamepad Icon -->
                        <Grid Background="#10FFFFFF">
                            <Path Data="M21,6H3C1.9,6 1,6.9 1,8V16C1,17.1 1.9,18 3,18H21C22.1,18 23,17.1 23,16V8C23,6.9 22.1,6 21,6M6,15H4V13H2V11H4V9H6V11H8V13H6V15M15,11A1.5,1.5 0 1,1 16.5,9.5A1.5,1.5 0 0,1 15,11M19,14A1.5,1.5 0 1,1 20.5,12.5A1.5,1.5 0 0,1 19,14Z"
                                  Fill="#33FFFFFF"
                                  Width="40" Height="40"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Grid>

                        <!-- Game Cover Image -->
                        <Image x:Name="CoverImage"
                               ImageFailed="CoverImage_ImageFailed"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality" />

                        <!-- Subtle bottom gradient overlay for text readability -->
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#00000000" Offset="0.0" />
                                    <GradientStop Color="#00000000" Offset="0.4" />
                                    <GradientStop Color="#9908090D" Offset="0.75" />
                                    <GradientStop Color="#F308090D" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>

                <!-- 2. CARD BODY overlaying the cover image at the bottom -->
                <Grid VerticalAlignment="Bottom" Margin="10,0,10,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Title -->
                        <RowDefinition Height="Auto" /> <!-- Genre -->
                        <RowDefinition Height="Auto" /> <!-- Play Button -->
                    </Grid.RowDefinitions>

                    <!-- Game Title (Peyda Bold, White, Single Line with Shadow) -->
                    <TextBlock Grid.Row="0"
                               Text="{Binding Title, ElementName=self}"
                               FontFamily="{StaticResource PeydaBold}"
                               FontSize="13"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Right">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1.5" Opacity="0.8" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Genre (Peyda Light, high contrast light color with Shadow) -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding Genre, ElementName=self}"
                               FontFamily="{StaticResource PeydaLight}"
                               FontSize="10"
                               Foreground="#FFFFFF"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Right">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1" Opacity="0.8" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Play Button (Yellow Accent) -->
                    <Grid Grid.Row="2" Margin="0,8,0,0" Height="30">
                        <Button Content="{Binding ButtonText, ElementName=self}"
                                Style="{StaticResource GameCardPlayButtonStyle}"
                                Command="{Binding PlayCommand, ElementName=self}"
                                CommandParameter="{Binding ElementName=self}"
                                IsEnabled="{Binding IsAvailable, ElementName=self}"
                                Tag="{Binding IsSelected, ElementName=self}"
                                HorizontalAlignment="Stretch" />
                    </Grid>
                </Grid>

                <!-- 3. SELECTED STATE HIGHLIGHT INDICATOR -->
                <Border x:Name="SelectedIndicator"
                        Background="#F5FF00"
                        CornerRadius="4"
                        Height="8" Width="8"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="12"
                        Opacity="0.0">
                    <Border.Effect>
                        <DropShadowEffect Color="#F5FF00" BlurRadius="8" ShadowDepth="0" Opacity="1.0" />
                    </Border.Effect>
                </Border>

                <!-- 4. DISABLED OVERLAY -->
                <Border x:Name="DisabledOverlay"
                        Background="#99000000"
                        CornerRadius="5"
                        Opacity="0.0"
                        IsHitTestVisible="False" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
