<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Theme Specific Color Mappings -->
    <Color x:Key="Theme.Colors.Background.Primary">#101014</Color>
    <Color x:Key="Theme.Colors.Background.Secondary">#1F1F23</Color>
    <Color x:Key="Theme.Colors.Surface.Card">#1F1F23</Color>
    <Color x:Key="Theme.Colors.Surface.Panel">#181A20</Color>
    <Color x:Key="Theme.Colors.Surface.Dialog">#A60A0A0A</Color>

    <!-- Text Colors -->
    <Color x:Key="Theme.Colors.Text.Primary">#ffffff</Color>
    <Color x:Key="Theme.Colors.Text.Secondary">#9A9A9A</Color>
    <Color x:Key="Theme.Colors.Text.Disabled">#55555A</Color>
    <Color x:Key="Theme.Colors.Text.Muted">#9A9A9A</Color>
    <Color x:Key="Theme.Colors.Text.PrimaryTranslucent">#40E1E1E6</Color>
    <Color x:Key="Theme.Colors.Track.Default">#06FFFFFF</Color>
    <Color x:Key="Theme.Colors.Track.Hover">#12FFFFFF</Color>

    <!-- Border Colors -->
    <Color x:Key="Theme.Colors.Border.Default">#252528</Color>
    <Color x:Key="Theme.Colors.Border.Active">#ffff3d</Color>
    <Color x:Key="Theme.Colors.Border.Cyan">#63E6FF</Color>
    <Color x:Key="Theme.Colors.Border.Translucent">#1AFFFFFF</Color>

    <!-- Accents / Brand -->
    <Color x:Key="Theme.Colors.Primary">#ffff3d</Color>
    <Color x:Key="Theme.Colors.PrimaryHover">#f4f46b</Color>
    <Color x:Key="Theme.Colors.Secondary">#63E6FF</Color>

    <!-- Button States -->
    <Color x:Key="Theme.Colors.Button.Primary.Default">#ffff3d</Color>
    <Color x:Key="Theme.Colors.Button.Primary.Hover">#f4f46b</Color>
    <Color x:Key="Theme.Colors.Button.Primary.Pressed">#E5A000</Color>
    <Color x:Key="Theme.Colors.Button.Primary.Disabled">#55555A</Color>

    <!-- Input Colors -->
    <Color x:Key="Theme.Colors.Input.Background">#1C1F26</Color>
    <Color x:Key="Theme.Colors.Input.Border">#4DFFFFFF</Color>

    <!-- Status -->
    <Color x:Key="Theme.Colors.Status.Success">#14BE78</Color>
    <Color x:Key="Theme.Colors.Status.Warning">#E5A000</Color>
    <Color x:Key="Theme.Colors.Status.Error">#F46B6B</Color>

    <!-- Notification Gradients & Accents -->
    <Color x:Key="Theme.Colors.Notification.Success.Start">#12461F</Color>
    <Color x:Key="Theme.Colors.Notification.Success.End">#2EE15B</Color>
    <Color x:Key="Theme.Colors.Notification.Error.Start">#341B1B</Color>
    <Color x:Key="Theme.Colors.Notification.Error.End">#F46B6B</Color>
    <Color x:Key="Theme.Colors.Notification.Warning.Start">#6D3F03</Color>
    <Color x:Key="Theme.Colors.Notification.Warning.End">#FFA023</Color>
    <Color x:Key="Theme.Colors.Notification.Info.Start">#2D2D31</Color>
    <Color x:Key="Theme.Colors.Notification.Info.End">#3A3A40</Color>
    <Color x:Key="Theme.Colors.Notification.Loading.Start">#5E5E5E</Color>
    <Color x:Key="Theme.Colors.Notification.Loading.End">#ffffff</Color>

    <!-- Navigation panel colors -->
    <Color x:Key="Theme.Colors.Navigation.Background">#171A20</Color>
    <Color x:Key="Theme.Colors.Navigation.Border">#2B3039</Color>
    <Color x:Key="Theme.Colors.Navigation.ItemHover">#252932</Color>
    <Color x:Key="Theme.Colors.Navigation.ItemActive">#303641</Color>

    <!-- Specific Admin Panel & Detail Colors -->
    <Color x:Key="Theme.Colors.SecondaryTranslucent13">#2200FFFF</Color>
    <Color x:Key="Theme.Colors.SecondaryTranslucent20">#3300FFFF</Color>
    <Color x:Key="Theme.Colors.SecondaryTranslucent26">#4400FFFF</Color>
    <Color x:Key="Theme.Colors.Purple">#8A5CFF</Color>
    <Color x:Key="Theme.Colors.PurpleTranslucent13">#228A5CFF</Color>
    <Color x:Key="Theme.Colors.PurpleTranslucent26">#448A5CFF</Color>

    <Color x:Key="Theme.Colors.CloseButton.Hover">#D9383A</Color>
    <Color x:Key="Theme.Colors.Progress.Track">#14161C</Color>

    <Color x:Key="Theme.Colors.Text.SecondaryTranslucent13">#229A9A9A</Color>
    <Color x:Key="Theme.Colors.Text.SecondaryTranslucent26">#449A9A9A</Color>

    <Color x:Key="Theme.Colors.PrimaryTranslucent13">#22ffff3d</Color>
    <Color x:Key="Theme.Colors.PrimaryTranslucent26">#44ffff3d</Color>
</ResourceDictionary>
