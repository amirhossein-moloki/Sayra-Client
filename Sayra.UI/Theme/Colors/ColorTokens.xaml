<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="AppColors.xaml"/>
        <ResourceDictionary Source="DarkTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Transparent aliases for central binding resolution -->
    <Color x:Key="Transparent">Transparent</Color>

    <!-- Semantic SolidColorBrushes mapping to Semantic Colors -->
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="Theme.Brushes.Background.Primary" Color="{DynamicResource Theme.Colors.Background.Primary}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Background.Secondary" Color="{DynamicResource Theme.Colors.Background.Secondary}"/>

    <!-- Surfaces -->
    <SolidColorBrush x:Key="Theme.Brushes.Surface.Card" Color="{DynamicResource Theme.Colors.Surface.Card}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Surface.Panel" Color="{DynamicResource Theme.Colors.Surface.Panel}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Surface.Dialog" Color="{DynamicResource Theme.Colors.Surface.Dialog}"/>

    <!-- Texts -->
    <SolidColorBrush x:Key="Theme.Brushes.Text.Primary" Color="{DynamicResource Theme.Colors.Text.Primary}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Text.Secondary" Color="{DynamicResource Theme.Colors.Text.Secondary}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Text.Disabled" Color="{DynamicResource Theme.Colors.Text.Disabled}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Text.Muted" Color="{DynamicResource Theme.Colors.Text.Muted}"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="Theme.Brushes.Border.Default" Color="{DynamicResource Theme.Colors.Border.Default}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Border.Active" Color="{DynamicResource Theme.Colors.Border.Active}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Border.Cyan" Color="{DynamicResource Theme.Colors.Border.Cyan}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Border.Translucent" Color="{DynamicResource Theme.Colors.Border.Translucent}"/>

    <!-- Accents / Brand -->
    <SolidColorBrush x:Key="Theme.Brushes.Primary" Color="{DynamicResource Theme.Colors.Primary}"/>
    <SolidColorBrush x:Key="Theme.Brushes.PrimaryHover" Color="{DynamicResource Theme.Colors.PrimaryHover}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Secondary" Color="{DynamicResource Theme.Colors.Secondary}"/>

    <!-- Button States -->
    <SolidColorBrush x:Key="Theme.Brushes.Button.Primary.Default" Color="{DynamicResource Theme.Colors.Button.Primary.Default}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Button.Primary.Hover" Color="{DynamicResource Theme.Colors.Button.Primary.Hover}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Button.Primary.Pressed" Color="{DynamicResource Theme.Colors.Button.Primary.Pressed}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Button.Primary.Disabled" Color="{DynamicResource Theme.Colors.Button.Primary.Disabled}"/>

    <!-- Inputs -->
    <SolidColorBrush x:Key="Theme.Brushes.Input.Background" Color="{DynamicResource Theme.Colors.Input.Background}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Input.Border" Color="{DynamicResource Theme.Colors.Input.Border}"/>

    <!-- Status -->
    <SolidColorBrush x:Key="Theme.Brushes.Status.Success" Color="{DynamicResource Theme.Colors.Status.Success}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Status.Warning" Color="{DynamicResource Theme.Colors.Status.Warning}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Status.Error" Color="{DynamicResource Theme.Colors.Status.Error}"/>

    <!-- Notification Brushes -->
    <SolidColorBrush x:Key="Theme.Brushes.Notification.Success.Start" Color="{DynamicResource Theme.Colors.Notification.Success.Start}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Notification.Success.End" Color="{DynamicResource Theme.Colors.Notification.Success.End}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Notification.Error.Start" Color="{DynamicResource Theme.Colors.Notification.Error.Start}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Notification.Error.End" Color="{DynamicResource Theme.Colors.Notification.Error.End}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Notification.Warning.Start" Color="{DynamicResource Theme.Colors.Notification.Warning.Start}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Notification.Warning.End" Color="{DynamicResource Theme.Colors.Notification.Warning.End}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Notification.Info.Start" Color="{DynamicResource Theme.Colors.Notification.Info.Start}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Notification.Info.End" Color="{DynamicResource Theme.Colors.Notification.Info.End}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Notification.Loading.Start" Color="{DynamicResource Theme.Colors.Notification.Loading.Start}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Notification.Loading.End" Color="{DynamicResource Theme.Colors.Notification.Loading.End}"/>

    <!-- Navigation Brushes -->
    <SolidColorBrush x:Key="Theme.Brushes.Navigation.Background" Color="{DynamicResource Theme.Colors.Navigation.Background}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Navigation.Border" Color="{DynamicResource Theme.Colors.Navigation.Border}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Navigation.ItemHover" Color="{DynamicResource Theme.Colors.Navigation.ItemHover}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Navigation.ItemActive" Color="{DynamicResource Theme.Colors.Navigation.ItemActive}"/>

    <!-- Specific Admin Panel & Detail Brushes -->
    <SolidColorBrush x:Key="Theme.Brushes.SecondaryTranslucent13" Color="{DynamicResource Theme.Colors.SecondaryTranslucent13}"/>
    <SolidColorBrush x:Key="Theme.Brushes.SecondaryTranslucent20" Color="{DynamicResource Theme.Colors.SecondaryTranslucent20}"/>
    <SolidColorBrush x:Key="Theme.Brushes.SecondaryTranslucent26" Color="{DynamicResource Theme.Colors.SecondaryTranslucent26}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Purple" Color="{DynamicResource Theme.Colors.Purple}"/>
    <SolidColorBrush x:Key="Theme.Brushes.PurpleTranslucent13" Color="{DynamicResource Theme.Colors.PurpleTranslucent13}"/>
    <SolidColorBrush x:Key="Theme.Brushes.PurpleTranslucent26" Color="{DynamicResource Theme.Colors.PurpleTranslucent26}"/>

    <SolidColorBrush x:Key="Theme.Brushes.CloseButton.Hover" Color="{DynamicResource Theme.Colors.CloseButton.Hover}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Progress.Track" Color="{DynamicResource Theme.Colors.Progress.Track}"/>

    <SolidColorBrush x:Key="Theme.Brushes.Text.SecondaryTranslucent13" Color="{DynamicResource Theme.Colors.Text.SecondaryTranslucent13}"/>
    <SolidColorBrush x:Key="Theme.Brushes.Text.SecondaryTranslucent26" Color="{DynamicResource Theme.Colors.Text.SecondaryTranslucent26}"/>

    <SolidColorBrush x:Key="Theme.Brushes.PrimaryTranslucent13" Color="{DynamicResource Theme.Colors.PrimaryTranslucent13}"/>
    <SolidColorBrush x:Key="Theme.Brushes.PrimaryTranslucent26" Color="{DynamicResource Theme.Colors.PrimaryTranslucent26}"/>

    <!-- Translucent and helper brushes for UI styling -->
    <SolidColorBrush x:Key="Theme.Brushes.Surface.PanelTranslucent" Color="{DynamicResource Theme.Colors.Surface.Panel}" Opacity="0.13" />
    <SolidColorBrush x:Key="Theme.Brushes.Status.ErrorTranslucent" Color="{DynamicResource Theme.Colors.Status.Error}" Opacity="0.13" />
    <SolidColorBrush x:Key="Theme.Brushes.Text.PrimaryTranslucent" Color="{DynamicResource Theme.Colors.Text.PrimaryTranslucent}" />
    <SolidColorBrush x:Key="Theme.Brushes.Track.Default" Color="{DynamicResource Theme.Colors.Track.Default}" />
    <SolidColorBrush x:Key="Theme.Brushes.Track.Hover" Color="{DynamicResource Theme.Colors.Track.Hover}" />

    <!-- White opacity brushes -->
    <SolidColorBrush x:Key="Theme.Brushes.White.Opacity10" Color="{DynamicResource Theme.Colors.Text.Primary}" Opacity="0.10"/>
    <SolidColorBrush x:Key="Theme.Brushes.White.Opacity20" Color="{DynamicResource Theme.Colors.Text.Primary}" Opacity="0.20"/>
    <SolidColorBrush x:Key="Theme.Brushes.White.Opacity30" Color="{DynamicResource Theme.Colors.Text.Primary}" Opacity="0.30"/>

    <!-- Primary opacity brushes -->
    <SolidColorBrush x:Key="Theme.Brushes.Primary.Opacity16" Color="{DynamicResource Theme.Colors.Primary}" Opacity="0.16"/>

    <!-- Shadow colors -->
    <Color x:Key="Theme.Colors.Shadow">#000000</Color>

    <!-- Legacy / Compatibility Mappings -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource Theme.Colors.Background.Primary}"/>
    <SolidColorBrush x:Key="BodyBrush" Color="{DynamicResource Theme.Colors.Background.Primary}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource Theme.Colors.Primary}"/>
    <SolidColorBrush x:Key="PrimaryYellowBrush" Color="{DynamicResource Theme.Colors.Primary}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{DynamicResource Theme.Colors.PrimaryHover}"/>
    <SolidColorBrush x:Key="PrimaryHoverYellowBrush" Color="{DynamicResource Theme.Colors.PrimaryHover}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{DynamicResource Theme.Colors.Text.Primary}"/>
    <SolidColorBrush x:Key="DarkerWhiteBrush" Color="{DynamicResource Theme.Colors.Text.Primary}"/>
    <SolidColorBrush x:Key="SecondaryWhiteBrush" Color="{DynamicResource Theme.Colors.Text.Secondary}"/>
    <SolidColorBrush x:Key="DarkBrush" Color="{DynamicResource Theme.Colors.Background.Primary}"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{DynamicResource Theme.Colors.Background.Secondary}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource Theme.Colors.Border.Default}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{DynamicResource Theme.Colors.Status.Warning}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{DynamicResource Theme.Colors.Status.Error}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource Theme.Colors.Status.Success}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource Theme.Colors.Status.Error}"/>
    <SolidColorBrush x:Key="MutedBrush" Color="{DynamicResource Theme.Colors.Text.Secondary}"/>

    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource Theme.Colors.Background.Secondary}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{DynamicResource Theme.Colors.Surface.Card}"/>
    <SolidColorBrush x:Key="AccentYellowBrush" Color="{DynamicResource Theme.Colors.Primary}"/>
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="{DynamicResource Theme.Colors.Status.Success}"/>
    <SolidColorBrush x:Key="DangerRedBrush" Color="{DynamicResource Theme.Colors.Status.Error}"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{DynamicResource Theme.Colors.Text.Primary}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{DynamicResource Theme.Colors.Text.Secondary}"/>
</ResourceDictionary>
