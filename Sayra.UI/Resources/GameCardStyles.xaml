<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Play Button Style inside Game Cards -->
    <Style x:Key="GameCardPlayButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#F5FF00" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="Foreground" Value="#F5FF00" />
        <Setter Property="FontFamily" Value="{StaticResource PeydaBold}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="PlayBtnBorder"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Background="#1A000000"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="PlayBtnScaleTransform" ScaleX="1.0" ScaleY="1.0" />
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect x:Name="PlayBtnGlow" Color="#F5FF00" BlurRadius="12" ShadowDepth="0" Opacity="0" />
                        </Border.Effect>

                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Hover State -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PlayBtnBorder" Property="Background" Value="#F5FF00" />
                            <Setter TargetName="PlayBtnBorder" Property="BorderBrush" Value="#F5FF00" />
                            <Setter Property="Foreground" Value="#08090D" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnGlow" Storyboard.TargetProperty="Opacity"
                                                         To="0.6" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnGlow" Storyboard.TargetProperty="Opacity"
                                                         To="0.0" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- Pressed State -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnScaleTransform" Storyboard.TargetProperty="ScaleX"
                                                         To="0.95" Duration="0:0:0.05" />
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnScaleTransform" Storyboard.TargetProperty="ScaleY"
                                                         To="0.95" Duration="0:0:0.05" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnScaleTransform" Storyboard.TargetProperty="ScaleX"
                                                         To="1.0" Duration="0:0:0.05" />
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnScaleTransform" Storyboard.TargetProperty="ScaleY"
                                                         To="1.0" Duration="0:0:0.05" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- Disabled State -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PlayBtnBorder" Property="Background" Value="#1AFFFFFF" />
                            <Setter TargetName="PlayBtnBorder" Property="BorderBrush" Value="#33FFFFFF" />
                            <Setter Property="Foreground" Value="#66FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
