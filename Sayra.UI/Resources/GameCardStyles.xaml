<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Play Button Style inside Game Cards -->
    <Style x:Key="GameCardPlayButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource PrimaryYellowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryYellowBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="Foreground" Value="Black" />
        <Setter Property="FontFamily" Value="{StaticResource PeydaBold}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="PlayBtnBorder"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="19"
                            Background="{TemplateBinding Background}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="PlayBtnScaleTransform" ScaleX="1.0" ScaleY="1.0" />
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect x:Name="PlayBtnGlow" Color="#ffff3d" BlurRadius="12" ShadowDepth="0" Opacity="0" />
                        </Border.Effect>

                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Hover State -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PlayBtnBorder" Property="Background" Value="{DynamicResource PrimaryHoverYellowBrush}" />
                            <Setter TargetName="PlayBtnBorder" Property="BorderBrush" Value="{DynamicResource PrimaryHoverYellowBrush}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnGlow" Storyboard.TargetProperty="Opacity"
                                                         To="0.85" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnGlow" Storyboard.TargetProperty="Opacity"
                                                         To="0.0" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- Pressed State -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnScaleTransform" Storyboard.TargetProperty="ScaleX"
                                                         To="0.94" Duration="0:0:0.05" />
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnScaleTransform" Storyboard.TargetProperty="ScaleY"
                                                         To="0.94" Duration="0:0:0.05" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnScaleTransform" Storyboard.TargetProperty="ScaleX"
                                                         To="1.0" Duration="0:0:0.05" />
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnScaleTransform" Storyboard.TargetProperty="ScaleY"
                                                         To="1.0" Duration="0:0:0.05" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- Selected State Glow Integration via Tag Property using Animations to prevent compile error -->
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnGlow" Storyboard.TargetProperty="Opacity"
                                                         To="0.8" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PlayBtnGlow" Storyboard.TargetProperty="Opacity"
                                                         To="0.0" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>

                        <!-- Disabled State (generic fallback - placed before specific content data triggers so they take precedence) -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PlayBtnBorder" Property="Background" Value="{DynamicResource BorderBrush}" />
                            <Setter TargetName="PlayBtnBorder" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource SecondaryWhiteBrush}" />
                        </Trigger>

                        <!-- PLAYING State: Background: Success (Green), Border: Success, Text: White for high contrast -->
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Content}" Value="PLAYING">
                            <Setter TargetName="PlayBtnBorder" Property="Background" Value="{DynamicResource SuccessBrush}" />
                            <Setter TargetName="PlayBtnBorder" Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}" />
                        </DataTrigger>

                        <!-- UNAVAILABLE State: Outlined Red appearance with high readability -->
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Content}" Value="UNAVAILABLE">
                            <Setter TargetName="PlayBtnBorder" Property="Background" Value="Transparent" />
                            <Setter TargetName="PlayBtnBorder" Property="BorderBrush" Value="{DynamicResource RedBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource RedBrush}" />
                        </DataTrigger>

                        <!-- LOCKED State: Outlined Red appearance with high readability -->
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Content}" Value="LOCKED">
                            <Setter TargetName="PlayBtnBorder" Property="Background" Value="Transparent" />
                            <Setter TargetName="PlayBtnBorder" Property="BorderBrush" Value="{DynamicResource RedBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource RedBrush}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
