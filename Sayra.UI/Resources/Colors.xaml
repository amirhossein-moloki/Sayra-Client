<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Base Color Tokens -->
    <Color x:Key="BackgroundColor">#101014</Color>
    <Color x:Key="BodyColor">#101014</Color>
    <Color x:Key="PrimaryYellowColor">#ffff3d</Color>
    <Color x:Key="PrimaryHoverYellowColor">#f4f46b</Color>
    <Color x:Key="WhiteColor">#ffffff</Color>
    <Color x:Key="SecondaryWhiteColor">#9A9A9A</Color>
    <Color x:Key="DarkColor">#101014</Color>
    <Color x:Key="SecondaryBackgroundColor">#1F1F23</Color>
    <Color x:Key="BorderColor">#252528</Color>
    <Color x:Key="PrimaryTransparentColor">#f4f46b2c</Color>
    <Color x:Key="DarkTransparentColor">#1010148a</Color>
    <Color x:Key="YellowColor">#E5A000</Color>
    <Color x:Key="RedColor">#F46B6B</Color>
    <Color x:Key="SuccessColor">#14BE78</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="MutedColor">#A6A6A6</Color>

    <!-- Legacy / Compatibility Color Tokens mapped to new Design System -->
    <Color x:Key="SurfaceColor">#1F1F23</Color>
    <Color x:Key="CardColor">#1F1F23</Color>
    <Color x:Key="AccentYellowColor">#ffff3d</Color>
    <Color x:Key="SuccessGreenColor">#14BE78</Color>
    <Color x:Key="DangerRedColor">#F46B6B</Color>
    <Color x:Key="PrimaryTextColor">#ffffff</Color>
    <Color x:Key="SecondaryTextColor">#9A9A9A</Color>
    <Color x:Key="GlassPanelColor">#1010148a</Color>

    <!-- Solid Color Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BodyBrush" Color="{StaticResource BodyColor}"/>
    <SolidColorBrush x:Key="PrimaryYellowBrush" Color="{StaticResource PrimaryYellowColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverYellowBrush" Color="{StaticResource PrimaryHoverYellowColor}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="SecondaryWhiteBrush" Color="{StaticResource SecondaryWhiteColor}"/>
    <SolidColorBrush x:Key="DarkBrush" Color="{StaticResource DarkColor}"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource SecondaryBackgroundColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="PrimaryTransparentBrush" Color="{StaticResource PrimaryTransparentColor}"/>
    <SolidColorBrush x:Key="DarkTransparentBrush" Color="{StaticResource DarkTransparentColor}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}"/>

    <!-- Legacy Solid Color Brushes mapped to new Design System -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="AccentYellowBrush" Color="{StaticResource AccentYellowColor}"/>
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="DangerRedBrush" Color="{StaticResource DangerRedColor}"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="GlassPanelBrush" Color="{StaticResource GlassPanelColor}"/>
</ResourceDictionary>
