<UserControl x:Class="Sayra.Client.UI.Controls.GameCard" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:m="clr-namespace:Sayra.Client.UI.Models" Width="150" Height="220" RenderTransformOrigin=".5,.5"><UserControl.RenderTransform><ScaleTransform/></UserControl.RenderTransform>
<UserControl.Resources><Style x:Key="PlayButton" TargetType="Button"><Setter Property="Height" Value="28"/><Setter Property="Margin" Value="10,4,10,10"/><Setter Property="Background" Value="{StaticResource PrimaryAccentBrush}"/><Setter Property="Foreground" Value="Black"/><Setter Property="FontFamily" Value="{StaticResource PeydaBold}"/><Setter Property="FontSize" Value="11"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="10"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Setter.Value></Setter><Style.Triggers><DataTrigger Binding="{Binding State}" Value="{x:Static m:GameState.Playing}"><Setter Property="Background" Value="White"/></DataTrigger><DataTrigger Binding="{Binding State}" Value="{x:Static m:GameState.Unavailable}"><Setter Property="Background" Value="#55555A"/><Setter Property="Foreground" Value="#D1D1D5"/></DataTrigger></Style.Triggers></Style></UserControl.Resources>
<Border x:Name="Root" Background="#050507" BorderBrush="#14FFFFFF" BorderThickness="1" CornerRadius="18" ClipToBounds="True"><Grid><Grid.RowDefinitions><RowDefinition Height="132"/><RowDefinition Height="*"/></Grid.RowDefinitions>
<Grid><Border CornerRadius="18,18,4,4" ClipToBounds="True"><Image Source="{Binding Cover}" Stretch="UniformToFill"/></Border><Rectangle><Rectangle.Fill><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#00000000" Offset=".35"/><GradientStop Color="#CC000000" Offset="1"/></LinearGradientBrush></Rectangle.Fill></Rectangle></Grid>
<StackPanel Grid.Row="1"><TextBlock Text="{Binding Title}" FontSize="16" FontFamily="{StaticResource PeydaBold}" Margin="12,9,12,0" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding Category}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" FontFamily="{StaticResource PeydaLight}" Margin="12,1,12,0"/><Button Content="{Binding ActionText}" Style="{StaticResource PlayButton}"/></StackPanel>
</Grid></Border>
<UserControl.Triggers><EventTrigger RoutedEvent="MouseEnter"><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:.18"/><DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:.18"/></Storyboard></BeginStoryboard></EventTrigger><EventTrigger RoutedEvent="MouseLeave"><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:.18"/><DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:.18"/></Storyboard></BeginStoryboard></EventTrigger></UserControl.Triggers>
</UserControl>
