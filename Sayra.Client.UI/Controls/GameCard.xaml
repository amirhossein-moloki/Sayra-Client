<UserControl x:Class="Sayra.Client.UI.Controls.GameCard" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:m="clr-namespace:Sayra.Client.UI.Models" Width="150" Height="220" FlowDirection="LeftToRight">
    <UserControl.Resources>
        <Style x:Key="PlayButton" TargetType="Button">
            <Setter Property="Height" Value="28"/><Setter Property="Margin" Value="10,4,10,10"/><Setter Property="Background" Value="{StaticResource PrimaryAccentBrush}"/><Setter Property="Foreground" Value="Black"/><Setter Property="FontFamily" Value="{StaticResource PeydaBold}"/><Setter Property="FontSize" Value="11"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ControlTemplate.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Style>
                        </ControlTemplate.Resources>
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{DynamicResource Theme.Colors.Primary}" BlurRadius="14" ShadowDepth="0" Opacity=".45"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers><DataTrigger Binding="{Binding State}" Value="{x:Static m:GameState.Playing}"><Setter Property="Background" Value="White"/></DataTrigger><DataTrigger Binding="{Binding State}" Value="{x:Static m:GameState.Unavailable}"><Setter Property="Background" Value="{DynamicResource Theme.Brushes.Text.Disabled}"/><Setter Property="Foreground" Value="{DynamicResource Theme.Brushes.Text.Secondary}"/></DataTrigger></Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border x:Name="Root" Background="{DynamicResource Theme.Brushes.Surface.Card}" BorderBrush="{DynamicResource Theme.Brushes.Border.Translucent}" BorderThickness="1" CornerRadius="16" ClipToBounds="True">
        <Grid><Grid.RowDefinitions><RowDefinition Height="132"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Grid><Border CornerRadius="16,16,5,5" ClipToBounds="True"><Image Source="{Binding Cover}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/></Border><Rectangle><Rectangle.Fill><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="{DynamicResource Transparent}" Offset=".34"/><GradientStop Color="{DynamicResource Theme.Colors.Background.Primary}" Offset="1"/></LinearGradientBrush></Rectangle.Fill></Rectangle></Grid>
            <StackPanel Grid.Row="1"><TextBlock Text="{Binding Title}" FontSize="16" FontFamily="{StaticResource PeydaBold}" Margin="12,9,12,0" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding Category}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" FontFamily="{StaticResource PeydaLight}" Margin="12,1,12,0"/><Button Content="{Binding ActionText}" Style="{StaticResource PlayButton}"/></StackPanel>
        </Grid>
    </Border>
</UserControl>
