<UserControl x:Class="Sayra.Client.UI.Controls.PriceCard" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Width="280" Height="90" FlowDirection="RightToLeft">
    <Border Background="#BF282823" BorderBrush="#14FFFFFF" BorderThickness="1" CornerRadius="18" Padding="18,12"><Border.Effect><DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="8" Opacity=".35"/></Border.Effect>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Width="46" Height="46" CornerRadius="14" Background="#22F5FF00" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="{Binding Icon, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="22" Foreground="{StaticResource PrimaryAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"><TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="15" Foreground="{StaticResource PrimaryAccentBrush}" FontFamily="{StaticResource PeydaLight}"/><TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="28" Foreground="{StaticResource PrimaryAccentBrush}" FontFamily="{StaticResource PeydaBold}" Margin="0,3,0,0"/></StackPanel>
        </Grid>
    </Border>
</UserControl>
