<UserControl x:Class="Sayra.Client.UI.Controls.SystemInfoCard" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Width="300" Height="260">
<Border Background="#D91E1E26" BorderBrush="#303038" BorderThickness="1" CornerRadius="22" Padding="22"><Border.Effect><DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="12" Opacity=".45"/></Border.Effect><Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/></Grid.RowDefinitions><DockPanel><TextBlock Text="PC-08" DockPanel.Dock="Right" FontFamily="{StaticResource PeydaBold}" FontSize="16" Foreground="{StaticResource PrimaryAccentBrush}"/><TextBlock Text="System Detail" FontFamily="{StaticResource PeydaBold}" FontSize="18"/></DockPanel><ItemsControl Grid.Row="1" ItemsSource="{Binding SystemInfo}"><ItemsControl.ItemTemplate><DataTemplate><Grid Height="43"><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Icon}" Foreground="{StaticResource PrimaryAccentBrush}" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="{StaticResource SecondaryTextBrush}" FontFamily="{StaticResource PeydaMedium}" VerticalAlignment="Center"/><Border Grid.Column="2" Height="1" Background="#22FFFFFF" Margin="8,0"/><TextBlock Grid.Column="3" Text="{Binding Value}" FontFamily="{StaticResource PeydaBold}" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></Grid></Border>
</UserControl>
