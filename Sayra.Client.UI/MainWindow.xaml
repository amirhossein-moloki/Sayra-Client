<Window x:Class="Sayra.Client.UI.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="clr-namespace:Sayra.Client.UI.Controls" xmlns:v="clr-namespace:Sayra.Client.UI.Views" xmlns:svgc="http://sharpvectors.codeplex.com/svgc/" Title="Sayra Gaming Center" Width="1920" Height="1080" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="CanResize" WindowState="Maximized" UseLayoutRounding="True" SnapsToDevicePixels="True">
<Grid Background="{StaticResource AppBackgroundBrush}">
    <Image Source="pack://application:,,,/Assets/photo_2026-07-08_22-07-56.jpg" Stretch="UniformToFill" Opacity=".31"><Image.Effect><BlurEffect Radius="2.5"/></Image.Effect></Image>
    <Rectangle><Rectangle.Fill><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#F0111118" Offset="0"/><GradientStop Color="#E809090D" Offset="1"/></LinearGradientBrush></Rectangle.Fill></Rectangle>
    <Canvas IsHitTestVisible="False" Opacity=".08"><Path Stroke="{StaticResource PrimaryAccentBrush}" StrokeThickness="1" Data="M80,240 L640,80 M1200,120 L1780,340 M260,900 L1020,760"/><TextBlock Canvas.Left="1180" Canvas.Top="125" Text="SAYRA" FontSize="150" FontFamily="{StaticResource PeydaBlack}" Foreground="White" Opacity=".035"/></Canvas>
    <Grid Margin="64,20,64,34"><Grid.RowDefinitions><RowDefinition Height="70"/><RowDefinition Height="260"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Grid.Row="0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <svgc:SvgViewbox Source="pack://application:,,,/Assets/sayra.svg" Width="140" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,3,0,0"><TextBlock Text="PC-08" FontFamily="{StaticResource PeydaBold}" FontSize="22" Margin="0,0,16,0"/><Border CornerRadius="13" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1" Padding="11,4" Background="#05000000"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0"><Ellipse.Effect><DropShadowEffect Color="#22C55E" BlurRadius="12" ShadowDepth="0" Opacity="1"/></Ellipse.Effect></Ellipse><TextBlock Text="Connected" Foreground="{StaticResource SuccessBrush}" FontSize="12" FontFamily="{StaticResource PeydaBold}"/></StackPanel></Border></StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"><StackPanel Margin="0,0,18,0"><TextBlock Text="{Binding ClockText}" FontFamily="{StaticResource PeydaBold}" FontSize="22" HorizontalAlignment="Right"/><TextBlock Text="{Binding DateText}" FontFamily="{StaticResource PeydaLight}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Right"/></StackPanel><Button Style="{StaticResource IconButton}" Command="{Binding PowerCommand}" Width="35" Height="35" Content="⏻" FontSize="17"/></StackPanel>
        </Grid>
        <Border Grid.Row="1" CornerRadius="28" Background="#70181820" BorderBrush="#10FFFFFF" BorderThickness="1" Padding="38,26"><Border.Effect><DropShadowEffect Color="#000000" BlurRadius="35" ShadowDepth="14" Opacity=".38"/></Border.Effect><Grid><StackPanel HorizontalAlignment="Left"><controls:SessionTimer TimeText="{Binding RemainingTimeText}"/><StackPanel Orientation="Horizontal" Margin="2,12,0,0"><controls:PriceCard Title="هزینه تاکنون" Value="110,000 تومان" Icon="◈" Margin="0,0,18,0"/><controls:PriceCard Title="نرخ ساعتی" Value="120,000 تومان" Icon="⌁"/></StackPanel></StackPanel><TextBlock Text="RTX GAMING SESSION" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="36" FontFamily="{StaticResource PeydaBlack}" Foreground="{StaticResource PrimaryAccentBrush}" Opacity=".13"/></Grid></Border>
        <Grid Grid.Row="2" Margin="0,30,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="30"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
            <Grid FlowDirection="RightToLeft"><Grid.RowDefinitions><RowDefinition Height="52"/><RowDefinition Height="*"/></Grid.RowDefinitions><DockPanel><TextBlock Text="🎮" FontSize="23" DockPanel.Dock="Right" Margin="0,0,0,0"/><TextBlock Text="بخش بازی های" FontFamily="{StaticResource PeydaBold}" FontSize="26" DockPanel.Dock="Right" Margin="10,0,0,0"/><Border Width="280" Height="40" Background="#202027" CornerRadius="20" HorizontalAlignment="Left" DockPanel.Dock="Left" Padding="14,0"><DockPanel LastChildFill="True"><TextBlock Text="⌕" FontSize="16" Foreground="#9CA3AF" VerticalAlignment="Center" DockPanel.Dock="Right"/><TextBlock Text="نام بازی را جستجو کنید..." FontFamily="{StaticResource PeydaLight}" FontSize="13" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="8,0"/></DockPanel></Border></DockPanel><ItemsControl Grid.Row="1" ItemsSource="{Binding Games}" FlowDirection="LeftToRight"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="5" Rows="1"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><controls:GameCard Margin="0,0,20,22"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></Grid>
            <StackPanel Grid.Column="2" HorizontalAlignment="Right"><controls:SystemInfoCard/><Button Content="پایان دادن به استفاده" Command="{Binding ShutdownCommand}" Style="{StaticResource DangerButton}" Width="300" Margin="0,22,0,0" FlowDirection="RightToLeft"/></StackPanel>
        </Grid>
    </Grid>
    <v:WarningOverlay Visibility="{Binding Warnings.IsWarningVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
</Grid>
</Window>
