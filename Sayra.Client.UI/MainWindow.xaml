<Window x:Class="Sayra.Client.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sayra.Client.UI"
        xmlns:vm="clr-namespace:Sayra.Client.UI.ViewModels"
        xmlns:v="clr-namespace:Sayra.Client.UI.Views"
        mc:Ignorable="d"
        Title="Sayra Client" Height="720" Width="1280"
        Background="#121212" Foreground="White"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
            <RowDefinition Height="*"/>    <!-- Content Area -->
        </Grid.RowDefinitions>

        <!-- Status Bar -->
        <Border Grid.Row="0" Padding="15,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#1E1E1E"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Warnings.IsSoftWarningVisible}" Value="True">
                            <Setter Property="Background" Value="#885500"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Ellipse Width="10" Height="10" Margin="0,0,10,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Connecting">
                                        <Setter Property="Fill" Value="Orange"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Connected">
                                        <Setter Property="Fill" Value="LimeGreen"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Disconnected">
                                        <Setter Property="Fill" Value="Red"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center" FontWeight="Bold"/>
                    <Separator Width="20" Background="Transparent"/>
                    <TextBlock Text="User: " VerticalAlignment="Center" Foreground="#AAA"/>
                    <TextBlock Text="{Binding UserName}" VerticalAlignment="Center" FontWeight="SemiBold"/>

                    <Separator Width="30" Background="Transparent"/>
                    <ContentControl Content="{Binding Billing}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <!-- Soft Warning Text -->
                    <TextBlock Text="{Binding Warnings.WarningMessage}"
                               VerticalAlignment="Center" Margin="0,0,20,0"
                               FontWeight="Bold" Foreground="Yellow"
                               Visibility="{Binding Warnings.IsSoftWarningVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <ContentControl Content="{Binding Session}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Status: " VerticalAlignment="Center" Foreground="#AAA"/>
                    <TextBlock Text="{Binding SessionState}" VerticalAlignment="Center" FontWeight="SemiBold" Width="80"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}"/>

        <!-- Warning Overlay -->
        <v:WarningOverlay Grid.RowSpan="2"
                          Visibility="{Binding Warnings.IsWarningVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</Window>
