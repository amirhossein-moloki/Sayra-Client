<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="PeydaBold">pack://application:,,,/Fonts/Peyda-Bold.woff2#Peyda</FontFamily>
    <FontFamily x:Key="PeydaMedium">pack://application:,,,/Fonts/Peyda-Medium.woff2#Peyda</FontFamily>
    <FontFamily x:Key="PeydaLight">pack://application:,,,/Fonts/peyda-light.woff2#Peyda</FontFamily>
    <FontFamily x:Key="PeydaBlack">pack://application:,,,/Fonts/Peyda-black.woff2#Peyda</FontFamily>
    <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/><Setter Property="FontFamily" Value="{StaticResource PeydaMedium}"/><Setter Property="TextOptions.TextFormattingMode" Value="Display"/></Style>
</ResourceDictionary>
