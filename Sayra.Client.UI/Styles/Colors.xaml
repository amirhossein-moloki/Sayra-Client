<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#0D0D12</Color><Color x:Key="DarkSurfaceColor">#181820</Color><Color x:Key="CardSurfaceColor">#050507</Color><Color x:Key="PrimaryAccentColor">#F5FF00</Color><Color x:Key="SuccessColor">#22C55E</Color><Color x:Key="DangerColor">#EF4444</Color><Color x:Key="PrimaryTextColor">#FFFFFF</Color><Color x:Key="SecondaryTextColor">#A1A1AA</Color>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}"/><SolidColorBrush x:Key="DarkSurfaceBrush" Color="{StaticResource DarkSurfaceColor}"/><SolidColorBrush x:Key="CardSurfaceBrush" Color="{StaticResource CardSurfaceColor}"/><SolidColorBrush x:Key="PrimaryAccentBrush" Color="{StaticResource PrimaryAccentColor}"/><SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/><SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/><SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}"/><SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
</ResourceDictionary>
