<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Theme Specific Color Mappings -->
    <Color x:Key="Theme.Colors.Background.Primary">#0D0D12</Color>
    <Color x:Key="Theme.Colors.Background.Secondary">#252525</Color>
    <Color x:Key="Theme.Colors.Surface.Card">#050507</Color>
    <Color x:Key="Theme.Colors.Surface.Panel">#181820</Color>
    <Color x:Key="Theme.Colors.Surface.Dialog">#2D2D2D</Color>

    <!-- Text Colors -->
    <Color x:Key="Theme.Colors.Text.Primary">#FFFFFF</Color>
    <Color x:Key="Theme.Colors.Text.Secondary">#A1A1AA</Color>
    <Color x:Key="Theme.Colors.Text.Disabled">#55555A</Color>
    <Color x:Key="Theme.Colors.Text.Muted">#888888</Color>

    <!-- Border Colors -->
    <Color x:Key="Theme.Colors.Border.Default">#333333</Color>
    <Color x:Key="Theme.Colors.Border.Active">#F5FF00</Color>
    <Color x:Key="Theme.Colors.Border.Cyan">#00FFFF</Color>
    <Color x:Key="Theme.Colors.Border.Translucent">#24FFFFFF</Color>

    <!-- Accents / Brand -->
    <Color x:Key="Theme.Colors.Primary">#F5FF00</Color>
    <Color x:Key="Theme.Colors.PrimaryHover">#FFFF3D</Color>
    <Color x:Key="Theme.Colors.Secondary">#00FFFF</Color>

    <!-- Button States -->
    <Color x:Key="Theme.Colors.Button.Primary.Default">#F5FF00</Color>
    <Color x:Key="Theme.Colors.Button.Primary.Hover">#FFFF3D</Color>
    <Color x:Key="Theme.Colors.Button.Primary.Pressed">#E5A000</Color>
    <Color x:Key="Theme.Colors.Button.Primary.Disabled">#55555A</Color>

    <!-- Input Colors -->
    <Color x:Key="Theme.Colors.Input.Background">#1C1F26</Color>
    <Color x:Key="Theme.Colors.Input.Border">#4DFFFFFF</Color>

    <!-- Status -->
    <Color x:Key="Theme.Colors.Status.Success">#22C55E</Color>
    <Color x:Key="Theme.Colors.Status.Warning">#FFA500</Color>
    <Color x:Key="Theme.Colors.Status.Error">#EF4444</Color>
</ResourceDictionary>
