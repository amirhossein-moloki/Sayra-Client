<Application x:Class="Sayra.Client.UI.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="clr-namespace:Sayra.Client.UI.ViewModels" xmlns:v="clr-namespace:Sayra.Client.UI.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme/Colors/ColorTokens.xaml"/>
                <ResourceDictionary Source="Styles/Typography.xaml"/>
                <ResourceDictionary Source="Styles/Controls.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <DataTemplate DataType="{x:Type vm:LoginViewModel}"><v:LoginView/></DataTemplate>
            <DataTemplate DataType="{x:Type vm:LauncherViewModel}"><v:LauncherView/></DataTemplate>
            <DataTemplate DataType="{x:Type vm:SessionViewModel}"><v:SessionView/></DataTemplate>
            <DataTemplate DataType="{x:Type vm:BillingViewModel}"><v:BillingView/></DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
